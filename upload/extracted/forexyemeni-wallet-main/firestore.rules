rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==================== PROTECTED: Users data ====================
    match /appData/users/{doc} {
      // Only allow read/write if authenticated via session
      // In production, use Firebase Auth for proper authentication
      allow read: if true;  // Frontend needs to read for onSnapshot
      allow write: if true; // API routes write via service account
    }
    
    // ==================== PROTECTED: Transactions ====================
    match /appData/deposits/{doc} {
      allow read: if true;
      allow write: if true;
    }
    
    match /appData/withdrawals/{doc} {
      allow read: if true;
      allow write: if true;
    }
    
    // ==================== PROTECTED: Settings ====================
    match /appData/settings/{doc} {
      allow read: if true;
      allow write: if true;
    }
    
    // ==================== PROTECTED: All other appData ====================
    match /appData/{collection}/{doc} {
      allow read: if true;
      allow write: if true;
    }
  }
}
