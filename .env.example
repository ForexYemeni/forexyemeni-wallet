# Firebase Configuration
# Go to Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}

# Email Service (Google Apps Script - FREE)
# See GOOGLE_APPS_SCRIPT_CODE.gs for the script to deploy
# Deploy the script as web app and paste the URL here
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Secret key to authenticate with the Google Apps Script (change this to any random string)
EMAIL_SECRET=fxwallet2024
