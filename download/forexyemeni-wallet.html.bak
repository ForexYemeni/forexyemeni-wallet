<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ForexYemeni Wallet - محفظة العملات الرقمية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#F0B90B',
                        'primary-dark': '#F8D12F',
                        success: '#0ECB81',
                        danger: '#F6465D',
                        warning: '#FCD535',
                        info: '#2E75B6',
                        dark: { bg: '#0B0E11', card: '#1E2329', sidebar: '#1E2329', border: '#2B3139', text: '#EAECEF', muted: '#848E9C' },
                        light: { bg: '#F0F4F8', card: '#FFFFFF', sidebar: '#FFFFFF', border: '#E2E8F0', text: '#1A202C', muted: '#6B7280' }
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');
        * { font-family: 'Tajawal', system-ui, sans-serif; margin: 0; padding: 0; box-sizing: border-box; }
        body { transition: background-color .3s, color .3s; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #2B3139; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #3B3F48; }
        input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
        .dark input[type=number] { -moz-appearance: textfield; }
        .fade-in { animation: fadeIn .3s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .slide-in { animation: slideIn .3s ease-out; }
        @keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
        .toast { animation: toastIn .3s ease-out, toastOut .3s ease-in 2.7s forwards; }
        @keyframes toastIn { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes toastOut { from { opacity: 1; } to { opacity: 0; } }
        .btn { transition: all .2s; cursor: pointer; user-select: none; }
        .btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.15); }
        .btn:active:not(:disabled) { transform: translateY(0); }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .overlay { background: rgba(0,0,0,.5); backdrop-filter: blur(4px); }
        .chat-bubble-me { background: #F0B90B; color: #0B0E11; border-radius: 12px 12px 0 12px; }
        .chat-bubble-other { background: #2B3139; color: #EAECEF; border-radius: 12px 12px 12px 0; }
        .light .chat-bubble-other { background: #E2E8F0; color: #1A202C; }
        .chat-bubble-me p, .chat-bubble-other p { font-size: 0.85rem; line-height: 1.5; }
        .camera-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 99999; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16px; }
        .camera-modal video { max-width: 100%; max-height: 55vh; border-radius: 12px; }
        .camera-modal canvas { display: none; }
        .copy-btn { display: inline-flex; align-items: center; gap: 2px; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; background: rgba(240,185,11,0.15); color: #F0B90B; cursor: pointer; border: none; transition: all 0.2s; }
        .copy-btn:hover { background: rgba(240,185,11,0.3); }
    </style>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-firestore-compat.js"></script>
    <link rel="manifest" href="manifest.json">
    <link rel="apple-touch-icon" href="icon.png">
    <meta name="theme-color" content="#0B0E11">
</head>
<body class="dark">
    <audio id="app-notif-sound" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3"></audio>
    <div id="app"></div>
    <div id="toast-container" class="fixed top-4 left-1/2 -translate-x-1/2 z-[9999] flex flex-col gap-2 pointer-events-none"></div>
    <div id="modal-container" class="hidden fixed inset-0 z-[9998] overlay flex items-center justify-center p-4" onclick="if(event.target===this)closeModal()">
        <div id="modal-content" class="bg-dark-card dark:bg-dark-card bg-light-card rounded-xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-6 slide-in"></div>
    </div>
    <div id="confirm-container" class="hidden fixed inset-0 z-[9998] overlay flex items-center justify-center p-4">
        <div class="bg-dark-card dark:bg-dark-card bg-light-card rounded-xl shadow-2xl max-w-sm w-full p-6 text-center slide-in">
            <div id="confirm-icon" class="text-5xl mb-4"></div>
            <h3 id="confirm-title" class="text-lg font-bold mb-2 text-dark-text dark:text-dark-text text-light-text"></h3>
            <p id="confirm-msg" class="text-dark-muted dark:text-dark-muted text-light-muted mb-6"></p>
            <div class="flex gap-3">
                <button onclick="confirmAction(false)" class="flex-1 px-4 py-2 rounded-lg border border-dark-border dark:border-dark-border border-light-border text-dark-text dark:text-dark-text text-light-text btn">إلغاء</button>
                <button onclick="confirmAction(true)" id="confirm-btn" class="flex-1 px-4 py-2 rounded-lg text-dark-bg btn"></button>
            </div>
        </div>
    </div>
    <div id="camera-modal" class="camera-modal hidden">
        <div class="w-full max-w-lg">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-white">📸 التقاط صورة</h3>
                <button onclick="closeCameraModal()" class="text-gray-400 hover:text-white text-2xl">&times;</button>
            </div>
            <video id="camera-video" autoplay playsinline muted class="w-full rounded-xl bg-black mb-4" style="max-height:55vh;object-fit:cover"></video>
            <canvas id="camera-canvas"></canvas>
            <div class="flex gap-3 justify-center">
                <button onclick="capturePhoto()" class="bg-primary text-dark-bg px-6 py-3 rounded-xl font-bold text-lg btn">📷 التقط</button>
                <button id="camera-flip-btn" onclick="flipCamera()" class="bg-dark-card text-dark-text border border-dark-border px-4 py-3 rounded-xl font-bold btn">🔄</button>
            </div>
            <p class="text-dark-muted text-center text-sm mt-3" id="camera-fallback-note"></p>
        </div>
    </div>

    <script>
        // ==================== FIREBASE SETUP ====================
        var defaultFirebaseConfig = {
            apiKey: "AIzaSyD-WgZiMm2tCcLSy6e265F_u4yahaWlCd0",
            authDomain: "forexyemeni-wallet.firebaseapp.com",
            projectId: "forexyemeni-wallet",
            storageBucket: "forexyemeni-wallet.firebasestorage.app",
            messagingSenderId: "52486252073",
            appId: "1:52486252073:web:0e8e590a77ba0b82399e38"
        };
        var firebaseConfig = defaultFirebaseConfig;
        try {
            var savedConfig = localStorage.getItem('fy_firebase_config');
            if (savedConfig) firebaseConfig = JSON.parse(savedConfig);
        } catch (e) { console.error('Error loading firebase config', e); }
        firebase.initializeApp(firebaseConfig);
        var db = firebase.firestore();

        // ==================== SOUND UTILITY ====================
        function playNotifSound() {
            var audio = document.getElementById('app-notif-sound');
            if (audio) { audio.currentTime = 0; audio.play().catch(function(){}); }
        }

        // ==================== IMAGE COMPRESSION ====================
        function compressImage(file, maxSize) {
            maxSize = maxSize || 500;
            return new Promise(function(resolve) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    var img = new Image();
                    img.onload = function() {
                        var canvas = document.createElement('canvas');
                        var w = img.width, h = img.height;
                        if (w > h && w > maxSize) { h *= maxSize / w; w = maxSize; }
                        else if (h > maxSize) { w *= maxSize / h; h = maxSize; }
                        canvas.width = w; canvas.height = h;
                        canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                        resolve(canvas.toDataURL('image/jpeg', 0.5));
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        // ==================== CAMERA UTILITY ====================
        var cameraStream = null, cameraCallback = null, cameraFacing = 'environment';
        function openCameraModal(callback) { cameraCallback = callback; document.getElementById('camera-modal').classList.remove('hidden'); startCamera(); }
        function closeCameraModal() { stopCamera(); document.getElementById('camera-modal').classList.add('hidden'); cameraCallback = null; }
        async function startCamera() {
            stopCamera();
            var video = document.getElementById('camera-video');
            var fallbackNote = document.getElementById('camera-fallback-note');
            var flipBtn = document.getElementById('camera-flip-btn');
            fallbackNote.textContent = '';
            try {
                var stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: cameraFacing, width: { ideal: 1280 }, height: { ideal: 720 } } });
                cameraStream = stream; video.srcObject = stream; video.style.display = 'block'; flipBtn.style.display = 'block';
            } catch(e) {
                fallbackNote.textContent = '⚠️ لا يمكن الوصول للكاميرا.';
                flipBtn.style.display = 'none'; video.style.display = 'none';
            }
        }
        function stopCamera() { if(cameraStream) { cameraStream.getTracks().forEach(function(t){t.stop();}); cameraStream = null; } }
        function flipCamera() { cameraFacing = cameraFacing === 'environment' ? 'user' : 'environment'; startCamera(); }
        function capturePhoto() {
            var video = document.getElementById('camera-video');
            var canvas = document.getElementById('camera-canvas');
            if(!video.srcObject) return;
            canvas.width = video.videoWidth; canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            var dataUrl = canvas.toDataURL('image/jpeg', 0.7);
            stopCamera(); document.getElementById('camera-modal').classList.add('hidden');
            var img = new Image();
            img.onload = function() {
                var c = document.createElement('canvas'); var maxSz = 800;
                var w = img.width, h = img.height;
                if(w > h && w > maxSz) { h *= maxSz / w; w = maxSz; } else if(h > maxSz) { w *= maxSz / h; h = maxSz; }
                c.width = w; c.height = h; c.getContext('2d').drawImage(img, 0, 0, w, h);
                var compressed = c.toDataURL('image/jpeg', 0.7);
                if(cameraCallback) { cameraCallback(compressed); cameraCallback = null; }
            };
            img.src = dataUrl;
        }

        // ==================== GENERIC FIELD IMAGE SYSTEM ====================
        window._fieldImages = {};
        function setFieldImage(fieldName, imgSrc) {
            window._fieldImages[fieldName] = imgSrc;
            renderFieldPreview(fieldName);
        }
        function clearFieldImage(fieldName) {
            window._fieldImages[fieldName] = null;
            renderFieldPreview(fieldName);
        }
        function getFieldImage(fieldName) {
            return window._fieldImages[fieldName] || null;
        }
        function renderFieldPreview(fieldName) {
            var previewId = 'preview-' + fieldName;
            var preview = document.getElementById(previewId);
            if (!preview) return;
            var imgSrc = window._fieldImages[fieldName];
            if (imgSrc) {
                preview.innerHTML = '<div class="relative inline-block"><img src="' + imgSrc + '" class="h-20 rounded-lg border object-cover"><button onclick="clearFieldImage(\'' + fieldName + '\')" class="absolute -top-2 -left-2 w-6 h-6 bg-danger text-white rounded-full text-xs flex items-center justify-center btn">✕</button></div>';
            } else {
                preview.innerHTML = '';
            }
        }
        function captureForField(fieldName) {
            openCameraModal(function(img) {
                setFieldImage(fieldName, img);
                toast('تم التقاط الصورة', 'success', false);
            });
        }
        function fileForField(fieldName, inputEl) {
            var file = inputEl.files[0];
            if (file) {
                compressImage(file, 500).then(function(compressed) {
                    setFieldImage(fieldName, compressed);
                    toast('تم رفع الصورة', 'success', false);
                });
            }
        }
        function captureForFieldWithCallback(fieldName, callback) {
            openCameraModal(function(img) {
                setFieldImage(fieldName, img);
                toast('تم التقاط الصورة', 'success', false);
                if (callback) callback(img);
            });
        }

        // ==================== DATABASE ====================
        window.appData = {
            users: null, paymentMethods: null, deposits: null, withdrawals: null,
            kycDocuments: null, notifications: null, userWithdrawalMethods: null,
            transactionLog: null, messages: null, settings: null, merchantRequests: null,
            merchantTransactions: null, profileChangeRequests: null, merchants: null,
            merchantPaymentData: null
        };
        var DB = {
            get: function(k) { return window.appData[k] || []; },
            set: function(k, v) { window.appData[k] = v; db.collection("appData").doc(k).set({ data: v }).catch(console.error); },
            getSetting: function(k) { var s = this.get('settings'); if(!s || typeof s !== 'object') return ''; return s[k] || ''; },
            setSetting: function(k, v) { var s = this.get('settings'); if(!s || typeof s !== 'object') s = {}; s[k] = v; this.set('settings', s); },
            uid: function() { return 'id_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9); },
            ensureUserFields: function(user) {
                if(!user) return user;
                if(!user.affiliateStatus) user.affiliateStatus = 'NONE';
                if(user.referredBy === undefined) user.referredBy = null;
                if(user.affiliateBalance === undefined) user.affiliateBalance = 0;
                if(!user.merchantStatus) user.merchantStatus = 'NONE';
                if(!user.localBalance) user.localBalance = 0;
                if(!user.usdtBalance) user.usdtBalance = 0;
                return user;
            }
        };

        function getDefaultData(key) {
            if (key === 'users') return [{ id: 'admin1', email: 'mshay2024m@gmail.com', name: 'مدير ForexYemeni', password: 'm773057153M@#$778288150omy', phone: '770000000', countryCode: '+967', role: 'ADMIN', usdtBalance: 0, localBalance: 0, affiliateBalance: 0, isBlocked: false, kycStatus: 'NOT_SUBMITTED', pendingEmail: null, affiliateStatus: 'NONE', affiliateCode: null, referredBy: null, merchantStatus: 'NONE', createdAt: new Date().toISOString() }];
            if (key === 'paymentMethods') return [
                { id: 'pm1', title: 'USDT TRC20', type: 'CRYPTO', subtype: '', network: 'TRC20', address: 'TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx', recipientName: '', accountNumber: '', bankName: '', isActive: true, sortOrder: 0, minDeposit: 10, minWithdraw: 5 },
                { id: 'pm2', title: 'حساب بنك اليمن والكويت', type: 'BANK', subtype: 'wallet', network: '', address: '', recipientName: 'ForexYemeni', accountNumber: '1234567890', bankName: 'بنك اليمن والكويت', isActive: true, sortOrder: 1, minDeposit: 1000, minWithdraw: 500 }
            ];
            if (key === 'settings') return { exchange_rate: '535', exchange_fee: '0', aff_l1: '5', aff_l2: '3', aff_l3: '1', admin_phone: '', admin_whatsapp: '', merchant_commission: '2' };
            if (key === 'merchantRequests') return [];
            if (key === 'merchantTransactions') return [];
            if (key === 'profileChangeRequests') return [];
            if (key === 'merchantPaymentData') return {};
            return [];
        }

        // ==================== STATE ====================
        var state = { view: 'loading', user: null, theme: 'dark', sidebarOpen: false, confirmCb: null, editId: null, settingsEditMode: false, activeChatUserId: null, affTab: 'requests', dbConfigEditMode: false, depPmId: '', wdMethodType: '' };
        function setView(v) { state.view = v; state.sidebarOpen = false; render(); }
        function setTheme(t) { state.theme = t; document.body.className = t; localStorage.setItem('fy_theme', t); render(); }
        function getUser() { return DB.ensureUserFields(DB.get('users').find(function(u) { return u.id === (state.user && state.user.id); })); }

        // ==================== TOAST ====================
        function toast(msg, type, withSound) {
            type = type || 'success'; withSound = (withSound !== undefined) ? withSound : true;
            var c = document.getElementById('toast-container');
            var colors = { success: 'bg-success text-dark-bg', error: 'bg-danger text-white', warning: 'bg-warning text-dark-bg', info: 'bg-info text-white' };
            var icons = { success: '✓', error: '✕', warning: '⚠', info: 'ℹ' };
            var el = document.createElement('div');
            el.className = 'toast ' + (colors[type]||colors.info) + ' px-5 py-3 rounded-lg shadow-lg flex items-center gap-2 font-medium text-sm pointer-events-auto';
            el.innerHTML = '<span class="text-lg font-bold">' + (icons[type]||'ℹ') + '</span><span>' + msg + '</span>';
            c.appendChild(el);
            if(withSound) playNotifSound();
            setTimeout(function() { el.remove(); }, 3000);
        }

        // ==================== MODAL ====================
        function showModal(html) { document.getElementById('modal-content').innerHTML = html; document.getElementById('modal-container').classList.remove('hidden'); }
        function closeModal() { document.getElementById('modal-container').classList.add('hidden'); }
        function showImageModal(src) { showModal('<div class="flex flex-col items-center"><img src="'+src+'" class="max-w-full rounded-lg max-h-[70vh] object-contain"><button onclick="closeModal()" class="mt-4 px-6 py-2 bg-primary text-dark-bg font-bold rounded-lg w-full btn">إغلاق</button></div>'); }
        function showConfirm(icon, title, msg, btnText, btnClass, cb) {
            document.getElementById('confirm-icon').textContent = icon;
            document.getElementById('confirm-title').textContent = title;
            document.getElementById('confirm-msg').textContent = msg;
            var btn = document.getElementById('confirm-btn'); btn.textContent = btnText; btn.className = 'flex-1 px-4 py-2 rounded-lg btn ' + btnClass;
            state.confirmCb = cb; document.getElementById('confirm-container').classList.remove('hidden');
        }
        function confirmAction(yes) { document.getElementById('confirm-container').classList.add('hidden'); if(state.confirmCb) state.confirmCb(yes); state.confirmCb = null; }

        // ==================== NOTIFICATIONS & LOGS ====================
        function addNotif(userId, title, msg, type) {
            type = type || 'INFO';
            var ns = DB.get('notifications') || [];
            ns.unshift({ id: DB.uid(), userId: userId, title: title, message: msg, type: type, isRead: false, createdAt: new Date().toISOString() });
            DB.set('notifications', ns);
            var currentUser = getUser();
            if(currentUser && currentUser.id === userId) toast(title, type.toLowerCase(), true);
        }
        function addLog(userId, type, amount, currency, desc) {
            var logs = DB.get('transactionLog') || [];
            logs.unshift({ id: DB.uid(), userId: userId, type: type, amount: parseFloat(amount)||0, currency: currency||'USDT', description: desc, createdAt: new Date().toISOString() });
            DB.set('transactionLog', logs);
        }

        // ==================== UTILITIES ====================
        function fmtDate(d) { if(!d) return ''; var dt = new Date(d); return dt.toLocaleDateString('ar-YE',{year:'numeric',month:'short',day:'numeric'}) + ' ' + dt.toLocaleTimeString('ar-YE',{hour:'2-digit',minute:'2-digit'}); }
        function fmtNum(n) { return Number(n||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}); }
        function fmtInt(n) { return Number(n||0).toLocaleString('en-US'); }
        function statusBadge(s) {
            var m = { PENDING:['معلق','bg-warning/20 text-warning'], PROCESSING:['قيد المعالجة','bg-info/20 text-info'], APPROVED:['موافق','bg-success/20 text-success'], COMPLETED:['مكتمل','bg-success/20 text-success'], REJECTED:['مرفوض','bg-danger/20 text-danger'], NOT_SUBMITTED:['لم يقدم','bg-gray-500/20 text-gray-400'], NONE:['—','bg-gray-500/20 text-gray-400'], ACTIVE:['نشط','bg-success/20 text-success'], BLOCKED:['محظور','bg-danger/20 text-danger'] };
            var item = m[s] || [s,'bg-gray-500/20 text-gray-500'];
            return '<span class="px-2 py-1 rounded-full text-xs font-bold whitespace-nowrap '+item[1]+'">'+item[0]+'</span>';
        }
        function copyText(t) {
            if(!t) return;
            var ta = document.createElement("textarea"); ta.value = t; document.body.appendChild(ta); ta.select();
            try { document.execCommand('copy'); toast('تم النسخ','success',false); } catch(e) { toast('فشل النسخ','error',false); }
            document.body.removeChild(ta);
        }
        function escHtml(s) { if(s===null||s===undefined) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

        var countries = [
            {code:'+967',name:'اليمن',flag:'🇾🇪',len:9},{code:'+966',name:'السعودية',flag:'🇸🇦',len:9},
            {code:'+971',name:'الإمارات',flag:'🇦🇪',len:9},{code:'+968',name:'عمان',flag:'🇴🇲',len:8},
            {code:'+974',name:'قطر',flag:'🇶🇦',len:8},{code:'+965',name:'الكويت',flag:'🇰🇼',len:8},
            {code:'+973',name:'البحرين',flag:'🇧🇭',len:8},{code:'+20',name:'مصر',flag:'🇪🇬',len:10},
            {code:'+962',name:'الأردن',flag:'🇯🇴',len:9},{code:'+961',name:'لبنان',flag:'🇱🇧',len:8},
            {code:'+964',name:'العراق',flag:'🇮🇶',len:10}
        ];

        // ==================== THEME INIT ====================
        state.theme = localStorage.getItem('fy_theme') || 'dark';
        document.body.className = state.theme;

        // ==================== RENDER ENGINE ====================
        function render() {
            var app = document.getElementById('app');
            var isDark = state.theme === 'dark';
            var C = {
                bg: isDark?'bg-dark-bg':'bg-light-bg', text: isDark?'text-dark-text':'text-light-text',
                muted: isDark?'text-dark-muted':'text-light-muted', card: isDark?'bg-dark-card':'bg-light-card',
                border: isDark?'border-dark-border':'border-light-border',
                input: isDark?'bg-dark-bg border-dark-border text-dark-text':'bg-light-bg border-light-border text-light-text',
                btn: 'bg-primary text-dark-bg hover:bg-primary-dark',
                btnOutline: 'border '+(isDark?'border-dark-border':'border-light-border')+' '+(isDark?'text-dark-text':'text-light-text')+' hover:bg-primary/10',
                danger: 'bg-danger text-white', success: 'bg-success text-dark-bg'
            };
            switch(state.view) {
                case 'login': app.innerHTML = renderLogin(C); break;
                case 'register': app.innerHTML = renderRegister(C); setTimeout(updateRegPhoneLength,50); break;
                case 'loading': app.innerHTML = renderLoading(C); break;
                default:
                    var currentUser = getUser();
                    if(state.view.indexOf('admin-')===0) app.innerHTML = renderLayout(C,'admin');
                    else if(currentUser && currentUser.role === 'ADMIN') app.innerHTML = renderLayout(C,'admin');
                    else if(currentUser && (currentUser.role === 'MERCHANT' || currentUser.merchantStatus === 'APPROVED')) app.innerHTML = renderLayout(C,'merchant');
                    else app.innerHTML = renderLayout(C,'user');
            }
            // Initialize merchant selection sections for deposit/withdraw pages
            if(state.view === 'user-deposit' || state.view === 'user-withdraw') {
                setTimeout(function(){
                    if(state.view === 'user-deposit') renderDepMerchantSection();
                    if(state.view === 'user-withdraw') renderWdMerchantSection();
                    if(state.depPmId) renderDepPmDetails();
                }, 100);
            }
        }

        function getThemeColors() {
            var isDark = state.theme === 'dark';
            return {bg:isDark?'bg-dark-bg':'bg-light-bg',text:isDark?'text-dark-text':'text-light-text',muted:isDark?'text-dark-muted':'text-light-muted',card:isDark?'bg-dark-card':'bg-light-card',border:isDark?'border-dark-border':'border-light-border',input:isDark?'bg-dark-bg border-dark-border text-dark-text':'bg-light-bg border-light-border text-light-text',btn:'bg-primary text-dark-bg hover:bg-primary-dark',btnOutline:'border '+(isDark?'border-dark-border':'border-light-border')+' '+(isDark?'text-dark-text':'text-light-text')+' hover:bg-primary/10',danger:'bg-danger text-white',success:'bg-success text-dark-bg'};
        }
        // ==================== AUTH PAGES ====================
        function renderLogin(C) {
            return '<div class="min-h-screen '+C.bg+' flex items-center justify-center p-4"><div class="'+C.card+' rounded-2xl shadow-2xl p-8 w-full max-w-md fade-in border '+C.border+'">'+
            '<div class="text-center mb-8"><div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary/10 mb-4">'+
            '<svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01M6 12h.01M18 12h.01"/></svg></div>'+
            '<h1 class="text-2xl font-bold '+C.text+'">ForexYemeni Wallet</h1><p class="'+C.muted+' mt-1">تسجيل الدخول إلى محفظتك</p></div>'+
            '<form onsubmit="handleLogin(event)" class="space-y-4">'+
            '<div><label class="block text-sm font-medium '+C.text+' mb-1">البريد الإلكتروني أو رقم الهاتف</label>'+
            '<input type="text" id="login-email" required class="w-full px-4 py-3 rounded-lg border '+C.input+' focus:ring-2 focus:ring-primary/50 outline-none" placeholder="رقم الهاتف أو البريد"></div>'+
            '<div><label class="block text-sm font-medium '+C.text+' mb-1">كلمة المرور</label>'+
            '<input type="password" id="login-pass" required class="w-full px-4 py-3 rounded-lg border '+C.input+' focus:ring-2 focus:ring-primary/50 outline-none" placeholder="••••••••"></div>'+
            '<button type="submit" class="'+C.btn+' w-full py-3 rounded-lg font-bold text-lg btn">تسجيل الدخول</button></form>'+
            '<p class="text-center '+C.muted+' mt-6">ليس لديك حساب؟ <a onclick="setView(\'register\')" class="text-primary cursor-pointer font-medium hover:underline">إنشاء حساب جديد</a></p>'+
            '<div class="mt-6 flex justify-end"><button onclick="setTheme(state.theme===\'dark\'?\'light\':\'dark\')" class="p-2 rounded-full '+C.btnOutline+' btn text-lg">'+(state.theme==='dark'?'☀️':'🌙')+'</button></div>'+
            '</div></div>';
        }

        function updateRegPhoneLength() {
            var sel = document.getElementById('reg-country'), inp = document.getElementById('reg-phone');
            if(sel && inp) { var c = countries.find(function(x){return x.code===sel.value;}); if(c){inp.placeholder='أدخل '+c.len+' أرقام';inp.maxLength=c.len;} }
        }

        function renderRegister(C) {
            var opts = countries.map(function(c){return '<option value="'+c.code+'" '+(c.code==='+967'?'selected':'')+'>'+c.flag+' ('+c.code+')</option>';}).join('');
            return '<div class="min-h-screen '+C.bg+' flex items-center justify-center p-4"><div class="'+C.card+' rounded-2xl shadow-2xl p-8 w-full max-w-md fade-in border '+C.border+'">'+
            '<div class="text-center mb-6"><h1 class="text-2xl font-bold '+C.text+'">إنشاء حساب جديد</h1><p class="'+C.muted+' mt-1">انضم إلى ForexYemeni Wallet</p></div>'+
            '<form onsubmit="handleRegister(event)" class="space-y-3">'+
            '<div><label class="block text-sm font-medium '+C.text+' mb-1">الاسم الكامل</label><input type="text" id="reg-name" required class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none focus:ring-2 focus:ring-primary/50" placeholder="محمد أحمد"></div>'+
            '<div class="flex gap-3"><div class="w-1/3"><label class="block text-sm font-medium '+C.text+' mb-1">الدولة</label><select id="reg-country" class="w-full px-2 py-2.5 rounded-lg border '+C.input+' outline-none text-center" onchange="updateRegPhoneLength()">'+opts+'</select></div>'+
            '<div class="w-2/3"><label class="block text-sm font-medium '+C.text+' mb-1">رقم الهاتف <span class="text-danger">*</span></label><input type="tel" id="reg-phone" required class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none focus:ring-2 focus:ring-primary/50" pattern="[0-9]+"></div></div>'+
            '<div><label class="block text-sm font-medium '+C.text+' mb-1">البريد الإلكتروني</label><input type="email" id="reg-email" required class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none focus:ring-2 focus:ring-primary/50" placeholder="example@email.com"></div>'+
            '<div><label class="block text-sm font-medium '+C.text+' mb-1">كلمة المرور</label><input type="password" id="reg-pass" required minlength="6" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none focus:ring-2 focus:ring-primary/50" placeholder="6 أحرف على الأقل"></div>'+
            '<div><label class="block text-sm font-medium '+C.text+' mb-1">تأكيد كلمة المرور</label><input type="password" id="reg-pass2" required class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none focus:ring-2 focus:ring-primary/50" placeholder="أعد كتابة كلمة المرور"></div>'+
            '<div><label class="block text-sm font-medium '+C.text+' mb-1">كود الإحالة (اختياري)</label><input type="text" id="reg-ref" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none focus:ring-2 focus:ring-primary/50" placeholder="إذا دعاك شخص أدخل رمزه"></div>'+
            '<button type="submit" class="'+C.btn+' w-full py-3 rounded-lg font-bold text-lg btn mt-2">إنشاء الحساب</button></form>'+
            '<p class="text-center '+C.muted+' mt-4">لديك حساب؟ <a onclick="setView(\'login\')" class="text-primary cursor-pointer font-medium hover:underline">تسجيل الدخول</a></p>'+
            '<div class="mt-4 flex justify-end"><button onclick="setTheme(state.theme===\'dark\'?\'light\':\'dark\')" class="p-2 rounded-full '+C.btnOutline+' btn text-lg">'+(state.theme==='dark'?'☀️':'🌙')+'</button></div>'+
            '</div></div>';
        }

        function handleLogin(e) {
            e.preventDefault();
            var loginId = document.getElementById('login-email').value.trim();
            var pass = document.getElementById('login-pass').value;
            var users = DB.get('users');
            var user = users.find(function(u) {
                var phoneOnly = u.phone ? u.phone.replace(u.countryCode||'','') : '';
                return (u.email === loginId || u.phone === loginId || phoneOnly === loginId) && u.password === pass;
            });
            if(!user) { toast('البيانات غير صحيحة','error'); return; }
            if(user.isBlocked) { toast('هذا الحساب محظور','error'); return; }
            DB.ensureUserFields(user);
            state.user = {id:user.id};
            localStorage.setItem('fy_auth_user', JSON.stringify({id:user.id}));
            playNotifSound();
            if(user.role === 'ADMIN') setView('admin-home');
            else if(user.role === 'MERCHANT' || user.merchantStatus === 'APPROVED') setView('merchant-dashboard');
            else setView('user-home');
            toast('مرحباً '+user.name,'success');
        }

        function logout() { state.user = null; localStorage.removeItem('fy_auth_user'); setView('login'); }

        function handleRegister(e) {
            e.preventDefault();
            var name = document.getElementById('reg-name').value.trim();
            var email = document.getElementById('reg-email').value.trim();
            var pass = document.getElementById('reg-pass').value;
            var pass2 = document.getElementById('reg-pass2').value;
            var phoneVal = document.getElementById('reg-phone').value.trim();
            var cc = document.getElementById('reg-country').value;
            var fullPhone = cc + phoneVal;
            var refCode = document.getElementById('reg-ref').value.trim();
            if(pass !== pass2) { toast('كلمات المرور غير متطابقة','error'); return; }
            var users = DB.get('users');
            if(users.find(function(u){return u.email===email;})) { toast('البريد الإلكتروني مسجل مسبقاً','error'); return; }
            if(users.find(function(u){return u.phone===fullPhone;})) { toast('رقم الهاتف مسجل مسبقاً','error'); return; }
            var referredBy = null;
            if(refCode) { var ref = users.find(function(u){return u.affiliateCode===refCode && u.affiliateStatus==='APPROVED';}); if(ref) referredBy = ref.id; else toast('كود الإحالة غير صحيح','warning'); }
            var user = {id:DB.uid(),email:email,name:name,password:pass,phone:fullPhone,countryCode:cc,role:'USER',usdtBalance:0,localBalance:0,affiliateBalance:0,isBlocked:false,kycStatus:'NOT_SUBMITTED',affiliateStatus:'NONE',affiliateCode:null,referredBy:referredBy,pendingEmail:null,merchantStatus:'NONE',createdAt:new Date().toISOString()};
            users.push(user); DB.set('users',users);
            state.user = {id:user.id}; localStorage.setItem('fy_auth_user',JSON.stringify({id:user.id}));
            setView('user-home'); toast('تم إنشاء الحساب بنجاح','success');
            setTimeout(function(){ addNotif(user.id,'مرحباً بك','تم إنشاء حسابك بنجاح في ForexYemeni Wallet','INFO'); }, 1000);
        }

        // ==================== LOADING ====================
        function renderLoading(C) {
            return '<div class="min-h-screen '+C.bg+' flex items-center justify-center"><div class="text-center">'+
            '<div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary/20 mb-4">'+
            '<svg class="w-8 h-8 text-primary animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/></svg></div>'+
            '<h2 class="text-xl font-bold '+C.text+'">ForexYemeni</h2><p class="text-sm mt-2 '+C.muted+'">جاري الاتصال بالخادم السحابي...</p>'+
            '<div class="w-32 h-1 '+C.card+' rounded-full mx-auto mt-4 overflow-hidden"><div class="h-full bg-primary rounded-full animate-pulse" style="width:60%"></div></div>'+
            '</div></div>';
        }

        // ==================== CAMERA BUTTON HELPER ====================
        function camBtn(fieldName, C, flexClass) {
            return '<button type="button" onclick="captureForField(\'' + fieldName + '\')" class="px-4 py-2.5 rounded-lg border ' + C.border + ' ' + C.text + ' btn text-sm font-medium ' + (flexClass||'flex-1') + '">📸 كاميرا</button>';
        }
        function fileBtn(fieldName, C, flexClass) {
            return '<label class="px-4 py-2.5 rounded-lg border ' + C.border + ' ' + C.text + ' btn text-sm font-medium ' + (flexClass||'flex-1') + ' text-center cursor-pointer">📁 رفع<input type="file" accept="image/*" class="hidden" onchange="fileForField(\'' + fieldName + '\', this)"></label>';
        }
        function previewDiv(fieldName) {
            return '<div id="preview-' + fieldName + '"></div>';
        }
        // ==================== LAYOUT ====================
        function renderLayout(C, role) {
            var user = getUser();
            if(!user) { logout(); return ''; }
            var isAdmin = role === 'admin';
            var isMerchant = role === 'merchant';
            var navItems = [];

            if(isAdmin) {
                navItems = [
                    {id:'admin-home',icon:'🏠',label:'الرئيسية'},
                    {id:'admin-users',icon:'👥',label:'المستخدمين'},
                    {id:'admin-deposits',icon:'💰',label:'الإيداعات'},
                    {id:'admin-withdrawals',icon:'🏧',label:'السحوبات'},
                    {id:'admin-kyc',icon:'🪪',label:'توثيق الهوية'},
                    {id:'admin-payment-methods',icon:'💳',label:'طرق الدفع'},
                    {id:'admin-affiliate',icon:'🔗',label:'العمولة'},
                    {id:'admin-chat',icon:'💬',label:'الدعم'},
                    {id:'admin-merchants',icon:'🏪',label:'طلبات التجار'},
                    {id:'admin-merchant-transactions',icon:'📊',label:'معاملات التجار'},
                    {id:'admin-profile-changes',icon:'📝',label:'طلبات تغيير البيانات'},
                    {id:'admin-reports',icon:'📈',label:'التقارير'},
                    {id:'admin-db-config',icon:'🗄️',label:'قاعدة البيانات'},
                    {id:'admin-settings',icon:'⚙️',label:'الإعدادات'}
                ];
            } else if(isMerchant) {
                navItems = [
                    {id:'merchant-dashboard',icon:'🏪',label:'الرئيسية'},
                    {id:'merchant-pending-deposits',icon:'💰',label:'إيداعات معلقة'},
                    {id:'merchant-pending-withdrawals',icon:'🏧',label:'سحوبات معلقة'},
                    {id:'merchant-transactions',icon:'📊',label:'المعاملات'},
                    {id:'merchant-settings',icon:'⚙️',label:'بيانات الإيداع'},
                    {id:'merchant-chat',icon:'💬',label:'الدعم'}
                ];
            } else {
                navItems = [
                    {id:'user-home',icon:'🏠',label:'الرئيسية'},
                    {id:'user-deposit',icon:'💰',label:'إيداع'},
                    {id:'user-withdraw',icon:'🏧',label:'سحب'},
                    {id:'user-kyc',icon:'🪪',label:'توثيق الهوية'},
                    {id:'user-history',icon:'📋',label:'السجل'},
                    {id:'user-notifications',icon:'🔔',label:'الإشعارات'},
                    {id:'user-settings',icon:'⚙️',label:'الإعدادات'},
                    {id:'user-withdrawal-methods',icon:'🏦',label:'حسابات السحب'},
                    {id:'user-chat',icon:'💬',label:'الدعم'},
                    {id:'user-affiliate',icon:'🔗',label:'العمولة'},
                    {id:'user-merchant',icon:'🏪',label:'طلب تاجر'}
                ];
            }

            var unreadNotifs = (DB.get('notifications')||[]).filter(function(n){return n.userId===user.id && !n.isRead;}).length;
            var unreadMsgs = (DB.get('messages')||[]).filter(function(m){return m.toId===user.id && !m.isRead;}).length;
            var roleLabel = isAdmin ? 'مدير' : (isMerchant ? 'تاجر' : 'مستخدم');

            var navHtml = navItems.map(function(item) {
                var active = state.view === item.id;
                var badge = '';
                if(item.id==='user-notifications' && unreadNotifs > 0) badge = '<span class="mr-auto bg-danger text-white text-xs w-5 h-5 rounded-full flex items-center justify-center">'+unreadNotifs+'</span>';
                if((item.id==='user-chat'||item.id==='merchant-chat') && unreadMsgs > 0) badge = '<span class="mr-auto bg-primary text-dark-bg text-xs w-5 h-5 rounded-full flex items-center justify-center">'+unreadMsgs+'</span>';
                if(item.id==='admin-chat' && unreadMsgs > 0) badge = '<span class="mr-auto bg-primary text-dark-bg text-xs w-5 h-5 rounded-full flex items-center justify-center">'+unreadMsgs+'</span>';
                if(item.id==='admin-profile-changes') {
                    var pendingChanges = (DB.get('profileChangeRequests')||[]).filter(function(r){return r.status==='PENDING';}).length;
                    if(pendingChanges > 0) badge = '<span class="mr-auto bg-danger text-white text-xs w-5 h-5 rounded-full flex items-center justify-center">'+pendingChanges+'</span>';
                }
                return '<button onclick="setView(\''+item.id+'\')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm btn '+(active?'bg-primary/15 text-primary font-bold':C.text+' hover:bg-primary/5')+'">'+
                    '<span class="text-lg">'+item.icon+'</span><span>'+item.label+'</span>'+badge+'</button>';
            }).join('');

            var sidebarHtml = '<aside class="fixed right-0 top-0 h-full w-60 '+C.card+' border-l '+C.border+' z-40 transform transition-transform duration-300 '+(state.sidebarOpen?'translate-x-0':'translate-x-full')+' lg:translate-x-0 overflow-y-auto">'+
                '<div class="p-4 border-b '+C.border+' flex items-center justify-between">'+
                '<div class="flex items-center gap-2"><div class="w-8 h-8 rounded-lg bg-primary/20 flex items-center justify-center text-primary font-bold text-sm">FX</div><span class="font-bold text-sm '+C.text+'">ForexYemeni</span></div>'+
                '<button onclick="state.sidebarOpen=false;render()" class="lg:hidden '+C.muted+' text-xl">&times;</button></div>'+
                '<div class="p-3 border-b '+C.border+'"><div class="flex items-center gap-2"><div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-sm">'+(isMerchant?'🏪':'👤')+'</div><div><p class="text-sm font-medium '+C.text+'">'+escHtml(user.name)+'</p><p class="text-xs '+C.muted+'">'+escHtml(roleLabel)+'</p></div></div></div>'+
                '<nav class="p-3 space-y-1 flex-1">'+navHtml+'</nav>'+
                '<div class="p-3 border-t '+C.border+'"><button onclick="logout()" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-danger hover:bg-danger/10 btn"><span>🚪</span><span>تسجيل الخروج</span></button></div>'+
                '</aside>';

            var contentHtml = '';
            switch(state.view) {
                case 'user-home': contentHtml = renderUserHome(C); break;
                case 'user-deposit': contentHtml = renderUserDeposit(C); break;
                case 'user-withdraw': contentHtml = renderUserWithdraw(C); break;
                case 'user-kyc': contentHtml = renderUserKYC(C); break;
                case 'user-history': contentHtml = renderUserHistory(C); break;
                case 'user-notifications': contentHtml = renderUserNotifications(C); break;
                case 'user-settings': contentHtml = renderUserSettings(C); break;
                case 'user-withdrawal-methods': contentHtml = renderUserWithdrawalMethods(C); break;
                case 'user-chat': contentHtml = renderUserChat(C); break;
                case 'user-affiliate': contentHtml = renderUserAffiliate(C); break;
                case 'user-merchant': contentHtml = renderUserMerchant(C); break;
                case 'merchant-dashboard': contentHtml = renderMerchantDashboard(C); break;
                case 'merchant-pending-deposits': contentHtml = renderMerchantPendingDeposits(C); break;
                case 'merchant-pending-withdrawals': contentHtml = renderMerchantPendingWithdrawals(C); break;
                case 'merchant-transactions': contentHtml = renderMerchantTransactions(C); break;
                case 'merchant-settings': contentHtml = renderMerchantSettings(C); break;
                case 'merchant-deposit': contentHtml = renderMerchantDeposit(C); break;
                case 'merchant-withdraw': contentHtml = renderMerchantWithdraw(C); break;
                case 'merchant-chat': contentHtml = renderMerchantChat(C); break;
                case 'admin-home': contentHtml = renderAdminHome(C); break;
                case 'admin-users': contentHtml = renderAdminUsers(C); break;
                case 'admin-deposits': contentHtml = renderAdminDeposits(C); break;
                case 'admin-withdrawals': contentHtml = renderAdminWithdrawals(C); break;
                case 'admin-kyc': contentHtml = renderAdminKYC(C); break;
                case 'admin-payment-methods': contentHtml = renderAdminPaymentMethods(C); break;
                case 'admin-affiliate': contentHtml = renderAdminAffiliate(C); break;
                case 'admin-chat': contentHtml = renderAdminChat(C); break;
                case 'admin-merchants': contentHtml = renderAdminMerchants(C); break;
                case 'admin-merchant-transactions': contentHtml = renderAdminMerchantTransactions(C); break;
                case 'admin-profile-changes': contentHtml = renderAdminProfileChanges(C); break;
                case 'admin-reports': contentHtml = renderAdminReports(C); break;
                case 'admin-db-config': contentHtml = renderAdminDbConfig(C); break;
                case 'admin-settings': contentHtml = renderAdminSettings(C); break;
                default: contentHtml = '<p class="'+C.text+'">صفحة غير موجودة</p>';
            }

            var floatingContactHtml = '';
            if(!isAdmin && !isMerchant && state.view !== 'user-chat') {
                var adminPhone = DB.getSetting('admin_phone');
                var adminWA = DB.getSetting('admin_whatsapp');
                if(adminPhone || adminWA) {
                    var phoneBtn = adminPhone ? '<a href="tel:'+escHtml(adminPhone)+'" class="w-14 h-14 rounded-full bg-blue-500 text-white flex items-center justify-center shadow-lg shadow-blue-500/30 btn text-xl hover:scale-110 transition-transform">📞</a>' : '';
                    var waBtn = adminWA ? '<a href="https://wa.me/'+adminWA.replace(/[^0-9]/g,'')+'" target="_blank" class="w-14 h-14 rounded-full bg-green-500 text-white flex items-center justify-center shadow-lg shadow-green-500/30 btn text-xl hover:scale-110 transition-transform">💬</a>' : '';
                    floatingContactHtml = '<div class="fixed bottom-6 left-6 z-50 flex flex-col gap-3">'+waBtn+phoneBtn+'</div>';
                }
            }

            return '<div class="min-h-screen '+C.bg+'">'+
                (state.sidebarOpen ? '<div class="fixed inset-0 bg-black/50 z-30 lg:hidden" onclick="state.sidebarOpen=false;render()"></div>' : '')+
                sidebarHtml+
                '<main class="lg:mr-60 p-4 lg:p-6 pb-24 lg:pb-6">'+
                '<div class="flex items-center justify-between mb-6">'+
                '<button onclick="state.sidebarOpen=true;render()" class="lg:hidden p-2 rounded-lg border '+C.border+' '+C.text+' btn">☰</button>'+
                '<div class="flex items-center gap-3">'+
                '<button onclick="setTheme(state.theme===\'dark\'?\'light\':\'dark\')" class="p-2 rounded-lg '+C.btnOutline+' btn text-sm">'+(state.theme==='dark'?'☀️':'🌙')+'</button>'+
                '</div></div>'+
                '<div class="fade-in">'+contentHtml+'</div></main></div>'+
                floatingContactHtml;
        }
        // ==================== USER: HOME ====================
        function renderUserHome(C) {
            var user = getUser();
            var rate = parseFloat(DB.getSetting('exchange_rate')) || 535;
            var usdtBal = user.usdtBalance || 0;
            var localEquiv = usdtBal * rate;
            var deposits = DB.get('deposits').filter(function(d){return d.userId===user.id;});
            var withdrawals = DB.get('withdrawals').filter(function(w){return w.userId===user.id;});
            var totalDep = deposits.filter(function(d){return d.status==='APPROVED';}).reduce(function(s,d){return s+(d.usdtAmount||0);},0);
            var totalWd = withdrawals.filter(function(w){return w.status==='APPROVED';}).reduce(function(s,w){return s+(w.net||0);},0);
            var pendingDep = deposits.filter(function(d){return d.status==='PENDING';}).length;
            var pendingWd = withdrawals.filter(function(w){return w.status==='PENDING';}).length;
            var recentLogs = (DB.get('transactionLog')||[]).filter(function(l){return l.userId===user.id;}).slice(0,5);
            var logsHtml = recentLogs.length === 0 ? '<p class="'+C.muted+' text-sm text-center py-4">لا توجد عمليات بعد</p>' :
                recentLogs.map(function(l) {
                    var isDeposit = l.type === 'DEPOSIT';
                    return '<div class="flex items-center justify-between py-2 border-b '+C.border+' last:border-0">'+
                        '<div><p class="text-sm '+C.text+'">'+escHtml(l.description)+'</p><p class="text-xs '+C.muted+'">'+fmtDate(l.createdAt)+'</p></div>'+
                        '<span class="font-bold text-sm '+(isDeposit?'text-success':'text-danger')+'">'+(isDeposit?'+':'-')+fmtNum(l.amount)+' '+l.currency+'</span></div>';
                }).join('');
            return '<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">'+
                '<div class="'+C.card+' rounded-xl p-5 border '+C.border+'"><p class="'+C.muted+' text-sm mb-1">رصيد USDT</p><h2 class="text-3xl font-bold text-success">'+fmtNum(usdtBal)+' <span class="text-lg">USDT</span></h2></div>'+
                '<div class="'+C.card+' rounded-xl p-5 border '+C.border+'"><p class="'+C.muted+' text-sm mb-1">المعادل بالعملة المحلية</p><h2 class="text-3xl font-bold text-primary">'+fmtInt(Math.round(localEquiv))+' <span class="text-lg">YER</span></h2>'+
                '<p class="'+C.muted+' text-xs mt-1">سعر الصرف: 1 USDT = '+fmtNum(rate)+' YER</p></div></div>'+
                '<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">'+
                '<div class="'+C.card+' rounded-xl p-3 text-center border '+C.border+'"><p class="text-xs '+C.muted+' mb-1">إجمالي الإيداعات</p><p class="font-bold text-success text-sm">'+fmtNum(totalDep)+'</p></div>'+
                '<div class="'+C.card+' rounded-xl p-3 text-center border '+C.border+'"><p class="text-xs '+C.muted+' mb-1">إجمالي السحوبات</p><p class="font-bold text-danger text-sm">'+fmtNum(totalWd)+'</p></div>'+
                '<div class="'+C.card+' rounded-xl p-3 text-center border '+C.border+'"><p class="text-xs '+C.muted+' mb-1">إيداعات معلقة</p><p class="font-bold text-warning text-sm">'+pendingDep+'</p></div>'+
                '<div class="'+C.card+' rounded-xl p-3 text-center border '+C.border+'"><p class="text-xs '+C.muted+' mb-1">سحوبات معلقة</p><p class="font-bold text-warning text-sm">'+pendingWd+'</p></div></div>'+
                '<div class="grid grid-cols-2 gap-3 mb-4">'+
                '<div class="'+C.card+' rounded-xl p-3 border '+C.border+' flex items-center justify-between"><span class="'+C.muted+' text-xs">حالة التوثيق</span>'+statusBadge(user.kycStatus||'NOT_SUBMITTED')+'</div>'+
                '<div class="'+C.card+' rounded-xl p-3 border '+C.border+' flex items-center justify-between"><span class="'+C.muted+' text-xs">حالة التاجر</span>'+statusBadge(user.merchantStatus||'NONE')+'</div></div>'+
                '<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">'+
                '<button onclick="setView(\'user-deposit\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">💰</span><p class="text-sm mt-2 font-medium '+C.text+'">إيداع</p></button>'+
                '<button onclick="setView(\'user-withdraw\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">🏧</span><p class="text-sm mt-2 font-medium '+C.text+'">سحب</p></button>'+
                '<button onclick="setView(\'user-kyc\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">🪪</span><p class="text-sm mt-2 font-medium '+C.text+'">توثيق</p></button>'+
                '<button onclick="setView(\'user-chat\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">💬</span><p class="text-sm mt-2 font-medium '+C.text+'">دعم</p></button></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">📋 آخر العمليات</h3>'+logsHtml+'</div>';
        }

        // ==================== USER: DEPOSIT ====================
        function renderUserDeposit(C) {
            var user = getUser();
            if(user.kycStatus !== 'APPROVED') { return '<div class="'+C.card+' rounded-xl p-8 max-w-lg mx-auto border '+C.border+' text-center"><p class="text-4xl mb-4">🪪</p><p class="'+C.text+' font-bold text-lg mb-2">يجب توثيق الهوية أولاً</p><p class="'+C.muted+' mb-4">لا يمكنك إجراء إيداع قبل توثيق هويتك</p><button onclick="setView(\'user-kyc\')" class="'+C.btn+' px-6 py-3 rounded-lg font-bold btn">🪪 توثيق الهوية</button></div>'; }
            var pms = DB.get('paymentMethods').filter(function(p){return p.isActive;}).sort(function(a,b){return (a.sortOrder||0)-(b.sortOrder||0);});
            var selectedPmId = state.depPmId || (pms.length > 0 ? pms[0].id : '');
            var pmOpts = pms.map(function(p){return '<option value="'+p.id+'" '+(p.id===selectedPmId?'selected':'')+'>'+escHtml(p.title)+'</option>';}).join('');
            return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-6 text-center">💰 إيداع رصيد</h2>'+
                '<div class="space-y-4">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">طريقة الإيداع</label><select id="dep-pm" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" onchange="onDepPmChange()"><option value="">-- اختر طريقة --</option>'+pmOpts+'</select></div>'+
                '<div id="dep-merchant-section"></div>'+
                '<div id="dep-pm-details"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">المبلغ <span class="text-danger">*</span></label><input type="number" id="dep-amount" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="أدخل المبلغ" min="1" step="0.01"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">رقم العملية</label><input type="text" id="dep-txid" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اختياري - رقم العملية أو TXID"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">صورة الإيصال <span class="text-danger">*</span></label>'+
                previewDiv('depReceipt')+
                '<div class="flex gap-2 mt-2">'+camBtn('depReceipt',C)+fileBtn('depReceipt',C)+'</div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">ملاحظات</label><textarea id="dep-notes" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none h-20" placeholder="اختياري"></textarea></div>'+
                '<button onclick="submitDeposit()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn text-lg">إرسال طلب الإيداع</button></div></div>';
        }

        function onDepPmChange() {
            var sel = document.getElementById('dep-pm');
            if(!sel) return;
            state.depPmId = sel.value;
            clearFieldImage('depReceipt');
            renderDepPmDetails();
            renderDepMerchantSection();
        }

        function renderDepMerchantSection() {
            var el = document.getElementById('dep-merchant-section');
            if(!el) return;
            var allUsers = DB.get('users');
            var approvedMerchants = allUsers.filter(function(m){return m.role==='MERCHANT' && m.merchantStatus==='APPROVED';});
            if(approvedMerchants.length === 0) { el.innerHTML = ''; return; }
            var C = getThemeColors();
            var opts = approvedMerchants.map(function(m){return '<option value="'+m.id+'">'+escHtml(m.name)+' (معاملات: '+(DB.get('merchantTransactions').filter(function(t){return t.merchantId===m.id && t.status==='APPROVED';}).length)+')</option>';}).join('');
            el.innerHTML = '<div><label class="block text-sm font-medium '+C.text+' mb-1">🏪 اختيار التاجر <span class="text-xs '+C.muted+'">(اختياري)</span></label><select id="dep-merchant" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" onchange="renderDepPmDetails()"><option value="">-- بدون تاجر (إيداع مباشر) --</option>'+opts+'</select><p class="text-xs '+C.muted+' mt-1">اختر التاجر الذي تريد التعامل معه أو اتركه للإيداع المباشر</p></div>';
        }

        function renderDepPmDetails() {
            var el = document.getElementById('dep-pm-details');
            if(!el) return;
            var C = getThemeColors();
            // Check if a merchant is selected - show merchant's payment data
            var merchantSelect = document.getElementById('dep-merchant');
            var merchantId = merchantSelect ? merchantSelect.value : '';
            if(merchantId) {
                var mData = getMerchantPaymentData(merchantId);
                if(mData) {
                    var allUsers = DB.get('users');
                    var merchantObj = allUsers.find(function(u){return u.id===merchantId;});
                    var merchantName = merchantObj ? merchantObj.name : 'تاجر';
                    var h = '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' space-y-3">';
                    h += '<div class="flex items-center gap-2 mb-2"><span class="text-lg">🏪</span><h3 class="font-bold '+C.text+' text-sm">بيانات التاجر: '+escHtml(merchantName)+'</h3></div>';
                    if(mData.usdtAddress) {
                        h += '<div class="'+C.card+' rounded-lg p-3 border '+C.border+' space-y-2">';
                        h += '<p class="text-xs font-bold text-primary mb-1">💳 محفظة USDT - '+escHtml(mData.usdtNetwork||'TRC20')+'</p>';
                        h += '<div class="flex items-center gap-2"><p class="font-mono text-xs '+C.text+' break-all flex-1">'+escHtml(mData.usdtAddress)+'</p><button onclick="copyText(\''+escHtml(mData.usdtAddress).replace(/'/g,"\\'")+'\')" class="copy-btn">📋 نسخ</button></div>';
                        h += '</div>';
                    }
                    if(mData.bankAccount) {
                        h += '<div class="'+C.card+' rounded-lg p-3 border '+C.border+' space-y-2 mt-2">';
                        h += '<p class="text-xs font-bold text-primary mb-1">🏦 تحويل بنكي</p>';
                        if(mData.bankName) h += '<div class="flex justify-between py-1"><span class="text-xs '+C.muted+'">البنك:</span><span class="text-xs font-medium '+C.text+'">'+escHtml(mData.bankName)+'</span></div>';
                        h += '<div class="flex justify-between py-1"><span class="text-xs '+C.muted+'">رقم الحساب:</span><div class="flex items-center gap-1"><span class="text-xs font-mono font-bold '+C.text+'">'+escHtml(mData.bankAccount)+'</span><button onclick="copyText(\''+escHtml(mData.bankAccount).replace(/'/g,"\\'")+'\')" class="copy-btn">📋</button></div></div>';
                        if(mData.bankRecipient) h += '<div class="flex justify-between py-1"><span class="text-xs '+C.muted+'">اسم صاحب الحساب:</span><span class="text-xs font-medium '+C.text+'">'+escHtml(mData.bankRecipient)+'</span></div>';
                        h += '</div>';
                    }
                    if(!mData.usdtAddress && !mData.bankAccount) {
                        h += '<p class="text-warning text-xs text-center py-3">⚠️ التاجر لم يقم بإعداد بيانات الإيداع بعد</p>';
                    }
                    h += '</div>';
                    el.innerHTML = h;
                    return;
                }
            }
            // Default: show admin payment method details
            var pmId = state.depPmId || (document.getElementById('dep-pm') ? document.getElementById('dep-pm').value : '');
            if(!pmId) { el.innerHTML = ''; return; }
            var pm = DB.get('paymentMethods').find(function(p){return p.id===pmId;});
            if(!pm) { el.innerHTML = ''; return; }
            var isCrypto = pm.type === 'CRYPTO';
            var currency = isCrypto ? 'USDT' : 'YER';
            var addressLabel = isCrypto ? 'عنوان المحفظة' : 'رقم الحساب';
            var addressVal = isCrypto ? (pm.address || '') : (pm.accountNumber || pm.address || '');
            var h = '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' space-y-3">';
            h += '<h3 class="font-bold '+C.text+' text-sm">تفاصيل طريقة الإيداع</h3>';
            h += '<div class="flex justify-between py-1 border-b '+C.border+'"><span class="'+C.muted+' text-sm">طريقة الإيداع</span><span class="font-medium text-sm '+C.text+'">'+escHtml(pm.title)+'</span></div>';
            h += '<div class="flex justify-between py-1 border-b '+C.border+'"><span class="'+C.muted+' text-sm">العملة</span><span class="font-medium text-sm text-primary">'+currency+'</span></div>';
            if(!isCrypto && pm.recipientName) {
                h += '<div class="flex justify-between py-1 border-b '+C.border+'"><span class="'+C.muted+' text-sm">اسم صاحب الحساب</span><span class="font-medium text-sm '+C.text+'">'+escHtml(pm.recipientName)+'</span></div>';
            }
            if(addressVal) {
                h += '<div class="py-1 border-b '+C.border+'"><p class="'+C.muted+' text-sm mb-1">'+addressLabel+'</p><div class="flex items-center gap-2"><p class="font-mono text-xs '+C.text+' break-all flex-1">'+escHtml(addressVal)+'</p><button onclick="copyText(\''+escHtml(addressVal).replace(/'/g,"\\'")+'\')" class="copy-btn">📋 نسخ</button></div></div>';
            }
            if(isCrypto && pm.network) {
                h += '<div class="flex justify-between py-1 border-b '+C.border+'"><span class="'+C.muted+' text-sm">الشبكة</span><span class="font-medium text-sm '+C.text+'">'+escHtml(pm.network)+'</span></div>';
            }
            if(!isCrypto && pm.bankName) {
                h += '<div class="flex justify-between py-1"><span class="'+C.muted+' text-sm">البنك/المحفظة</span><span class="font-medium text-sm '+C.text+'">'+escHtml(pm.bankName)+'</span></div>';
            }
            h += '</div>';
            el.innerHTML = h;
        }

        function submitDeposit() {
            var user = getUser();
            var pmId = document.getElementById('dep-pm').value;
            var amount = parseFloat(document.getElementById('dep-amount').value);
            var txid = document.getElementById('dep-txid').value.trim();
            var receipt = getFieldImage('depReceipt');
            var notes = document.getElementById('dep-notes').value.trim();
            var rate = parseFloat(DB.getSetting('exchange_rate')) || 535;
            // Get selected merchant
            var merchantSelect = document.getElementById('dep-merchant');
            var merchantId = merchantSelect ? merchantSelect.value : '';
            if(!pmId) { toast('اختر طريقة الإيداع','error'); return; }
            if(!amount || amount <= 0) { toast('أدخل مبلغاً صحيحاً','error'); return; }
            if(!receipt) { toast('يجب إرفاق صورة الإيصال','error'); return; }
            var pm = DB.get('paymentMethods').find(function(p){return p.id===pmId;});
            if(pm && amount < (pm.minDeposit||0)) { toast('الحد الأدنى للإيداع: '+pm.minDeposit,'error'); return; }
            var isCrypto = pm && pm.type === 'CRYPTO';
            var currency = isCrypto ? 'USDT' : 'YER';
            var usdtAmount = isCrypto ? amount : amount / rate;
            var deposits = DB.get('deposits');
            deposits.unshift({id:DB.uid(),userId:user.id,paymentMethodId:pmId,currency:currency,amount:amount,usdtAmount:usdtAmount,localAmount:isCrypto?amount*rate:amount,txid:txid,receipt:receipt,notes:notes,status:'PENDING',assignedMerchantId:merchantId||null,createdAt:new Date().toISOString()});
            DB.set('deposits', deposits);
            addLog(user.id,'DEPOSIT',usdtAmount,'USDT','طلب إيداع '+fmtNum(amount)+' '+currency+(merchantId?' - عبر تاجر':''));
            addNotif(user.id,'طلب إيداع','تم إرسال طلب إيداع '+fmtNum(usdtAmount)+' USDT بنجاح. سيتم مراجعته.','INFO');
            clearFieldImage('depReceipt');
            toast('تم إرسال طلب الإيداع'+(merchantId?' بنجاح - تم تعيين التاجر':''),'success');
            setView('user-home');
        }

        // Initialize deposit/withdraw merchant sections after render
        function initMerchantSections() {
            setTimeout(function(){
                renderDepMerchantSection();
                if(state.depPmId) renderDepPmDetails();
                renderWdMerchantSection();
            }, 300);
        }
        initMerchantSections();
        // ==================== USER: WITHDRAW ====================
        function renderUserWithdraw(C) {
            var user = getUser();
            if(user.kycStatus !== 'APPROVED') { var C2 = getThemeColors(); return '<div class="'+getThemeColors().card+' rounded-xl p-8 max-w-lg mx-auto border '+getThemeColors().border+' text-center"><p class="text-4xl mb-4">🪪</p><p class="'+getThemeColors().text+' font-bold text-lg mb-2">يجب توثيق الهوية أولاً</p><p class="'+getThemeColors().muted+' mb-4">لا يمكنك إجراء سحب قبل توثيق هويتك</p><button onclick="setView(\'user-kyc\')" class="'+getThemeColors().btn+' px-6 py-3 rounded-lg font-bold btn">🪪 توثيق الهوية</button></div>'; }
            var rate = parseFloat(DB.getSetting('exchange_rate')) || 535;
            var fee = parseFloat(DB.getSetting('exchange_fee')) || 0;
            var wms = DB.get('userWithdrawalMethods').filter(function(w){return w.userId===user.id;});
            var pmOpts = wms.map(function(w){var label = w.type==='BANK' ? (w.bankName||'تحويل بنكي')+' - '+(w.accountNumber||'').substr(0,8)+'...' : (w.network||'USDT')+' - '+(w.address||'').substr(0,12)+'...'; return '<option value="'+w.id+'">'+escHtml(label)+'</option>';}).join('');
            return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-6 text-center">🏧 سحب رصيد</h2>'+
                '<div class="grid grid-cols-2 gap-3 mb-4">'+
                '<div class="'+C.card+' rounded-lg p-3 text-center border '+C.border+'"><p class="'+C.muted+' text-xs">رصيد USDT</p><p class="font-bold text-success">'+fmtNum(user.usdtBalance)+'</p></div>'+
                '<div class="'+C.card+' rounded-lg p-3 text-center border '+C.border+'"><p class="'+C.muted+' text-xs">المعادل YER</p><p class="font-bold text-primary">'+fmtInt(Math.round(user.usdtBalance*rate))+'</p></div></div>'+
                '<div class="space-y-4">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">عملة السحب</label><select id="wd-currency" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" onchange="updateWdCalc()"><option value="USDT">USDT</option><option value="YER">YER (عملة محلية)</option></select></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">طريقة السحب</label><select id="wd-method" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" onchange="updateWdCalc()"><option value="">-- اختر طريقة سحب --</option>'+pmOpts+'</select></div>'+
                '<div id="wd-merchant-section"></div>'+
                '<div id="wd-method-details"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">المبلغ <span class="text-danger">*</span></label><input type="number" id="wd-amount" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="أدخل المبلغ" min="1" step="0.01" oninput="updateWdCalc()"></div>'+
                '<div class="flex gap-2">'+
                '<button onclick="document.getElementById(\'wd-amount\').value=\''+user.usdtBalance+'\';updateWdCalc()" class="flex-1 px-3 py-2 rounded-lg border '+C.border+' '+C.text+' btn text-xs">100%</button>'+
                '<button onclick="document.getElementById(\'wd-amount\').value=\''+(user.usdtBalance*0.75)+'\';updateWdCalc()" class="flex-1 px-3 py-2 rounded-lg border '+C.border+' '+C.text+' btn text-xs">75%</button>'+
                '<button onclick="document.getElementById(\'wd-amount\').value=\''+(user.usdtBalance*0.5)+'\';updateWdCalc()" class="flex-1 px-3 py-2 rounded-lg border '+C.border+' '+C.text+' btn text-xs">50%</button>'+
                '<button onclick="document.getElementById(\'wd-amount\').value=\''+(user.usdtBalance*0.25)+'\';updateWdCalc()" class="flex-1 px-3 py-2 rounded-lg border '+C.border+' '+C.text+' btn text-xs">25%</button></div>'+
                '<div id="wd-calc" class="'+C.card+' rounded-lg p-4 border '+C.border+' space-y-2">'+
                '<p class="'+C.muted+' text-sm">💰 المبلغ المطلوب: <span class="'+C.text+' font-bold">0.00 USDT</span></p>'+
                '<p class="'+C.muted+' text-sm">📊 الرسوم ('+fee+'%): <span class="'+C.text+' font-bold">0.00 USDT</span></p>'+
                '<div class="border-t '+C.border+' pt-2"><p class="text-success font-bold text-lg">✅ الصافي الذي ستستلمه: 0.00 USDT</p>'+
                '<p class="'+C.muted+' text-xs mt-1">المعادل: 0 YER</p></div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">ملاحظات</label><textarea id="wd-notes" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none h-20" placeholder="اختياري"></textarea></div>'+
                (wms.length === 0 ? '<p class="text-warning text-sm text-center">لا توجد طرق سحب محفوظة. <a onclick="setView(\'user-withdrawal-methods\')" class="text-primary cursor-pointer underline">أضف طريقة سحب</a></p>' : '')+
                '<button onclick="submitWithdraw()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn text-lg">إرسال طلب السحب</button></div></div>';
        }

        function updateWdCalc() {
            var calcEl = document.getElementById('wd-calc');
            if(!calcEl) return;
            var user = getUser();
            var amount = parseFloat(document.getElementById('wd-amount').value) || 0;
            var fee = parseFloat(DB.getSetting('exchange_fee')) || 0;
            var rate = parseFloat(DB.getSetting('exchange_rate')) || 535;
            var feeAmount = amount * fee / 100;
            var net = amount - feeAmount;
            var netYER = net * rate;
            var C = getThemeColors();
            calcEl.innerHTML = '<p class="'+C.muted+' text-sm">💰 المبلغ المطلوب: <span class="'+C.text+' font-bold">'+fmtNum(amount)+' USDT</span></p>'+
                '<p class="'+C.muted+' text-sm">📊 الرسوم ('+fee+'%): <span class="text-danger font-bold">'+fmtNum(feeAmount)+' USDT</span></p>'+
                '<div class="border-t '+C.border+' pt-2"><p class="text-success font-bold text-lg">✅ الصافي الذي ستستلمه: '+fmtNum(net)+' USDT</p>'+
                '<p class="'+C.muted+' text-xs mt-1">المعادل: '+fmtInt(Math.round(netYER))+' YER</p></div>';
            var methodId = document.getElementById('wd-method').value;
            var method = DB.get('userWithdrawalMethods').find(function(m){return m.id===methodId;});
            var detailsEl = document.getElementById('wd-method-details');
            if(detailsEl && method) {
                var info = '';
                if(method.type==='BANK') info = '<p class="text-sm '+C.muted+'">البنك: <span class="'+C.text+'">'+escHtml(method.bankName||'')+'</span></p><p class="text-sm '+C.muted+'">رقم الحساب: <span class="'+C.text+'">'+escHtml(method.accountNumber||'')+'</span></p><p class="text-sm '+C.muted+'">اسم صاحب الحساب: <span class="'+C.text+'">'+escHtml(method.recipientName||'')+'</span></p>';
                else info = '<p class="text-sm '+C.muted+'">العملة: <span class="'+C.text+'">'+escHtml(method.currencyName||'USDT')+'</span></p><p class="text-sm '+C.muted+'">الشبكة: <span class="'+C.text+'">'+escHtml(method.network||'')+'</span></p><p class="text-sm '+C.muted+'">العنوان: <span class="font-mono text-xs '+C.text+'">'+escHtml((method.address||'').substr(0,20))+'...</span></p>';
                detailsEl.innerHTML = '<div class="'+C.card+' rounded-lg p-3 border '+C.border+'">'+info+'</div>';
            } else if(detailsEl) { detailsEl.innerHTML = ''; }
        }

        function renderWdMerchantSection() {
            var el = document.getElementById('wd-merchant-section');
            if(!el) return;
            var allUsers = DB.get('users');
            var approvedMerchants = allUsers.filter(function(m){return m.role==='MERCHANT' && m.merchantStatus==='APPROVED';});
            if(approvedMerchants.length === 0) { el.innerHTML = ''; return; }
            var C = getThemeColors();
            var opts = approvedMerchants.map(function(m){return '<option value="'+m.id+'">'+escHtml(m.name)+' (معاملات: '+(DB.get('merchantTransactions').filter(function(t){return t.merchantId===m.id && t.status==='APPROVED';}).length)+')</option>';}).join('');
            el.innerHTML = '<div><label class="block text-sm font-medium '+C.text+' mb-1">🏪 اختيار التاجر <span class="text-xs '+C.muted+'">(اختياري)</span></label><select id="wd-merchant" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"><option value="">-- بدون تاجر (سحب مباشر) --</option>'+opts+'</select><p class="text-xs '+C.muted+' mt-1">اختر التاجر الذي تريد التعامل معه أو اتركه للسحب المباشر</p></div>';
        }

        function submitWithdraw() {
            var user = getUser();
            var methodId = document.getElementById('wd-method').value;
            var amount = parseFloat(document.getElementById('wd-amount').value);
            var notes = document.getElementById('wd-notes').value.trim();
            var fee = parseFloat(DB.getSetting('exchange_fee')) || 0;
            // Get selected merchant
            var merchantSelect = document.getElementById('wd-merchant');
            var merchantId = merchantSelect ? merchantSelect.value : '';
            if(!methodId) { toast('اختر طريقة السحب','error'); return; }
            if(!amount || amount <= 0) { toast('أدخل مبلغاً صحيحاً','error'); return; }
            var feeAmount = amount * fee / 100;
            var net = amount - feeAmount;
            if(net <= 0) { toast('المبلغ بعد الرسوم صفر أو أقل','error'); return; }
            if(amount > user.usdtBalance) { toast('رصيدك غير كافٍ','error'); return; }
            var method = DB.get('userWithdrawalMethods').find(function(m){return m.id===methodId;});
            if(!method) { toast('طريقة السحب غير موجودة','error'); return; }
            var withdrawals = DB.get('withdrawals');
            withdrawals.unshift({id:DB.uid(),userId:user.id,withdrawalMethodId:methodId,amount:amount,fee:feeAmount,net:net,currency:'USDT',notes:notes,status:'PENDING',assignedMerchantId:merchantId||null,createdAt:new Date().toISOString()});
            DB.set('withdrawals', withdrawals);
            addLog(user.id,'WITHDRAW',net,'USDT','طلب سحب '+fmtNum(net)+' USDT'+(merchantId?' - عبر تاجر':''));
            addNotif(user.id,'طلب سحب','تم إرسال طلب سحب '+fmtNum(net)+' USDT بنجاح. سيتم مراجعته.','INFO');
            toast('تم إرسال طلب السحب'+(merchantId?' - تم تعيين التاجر':''),'success');
            setView('user-home');
        }
        // ==================== USER: KYC ====================
        function renderUserKYC(C) {
            var user = getUser();
            var kycDoc = DB.get('kycDocuments').find(function(k){return k.userId===user.id;});
            var statusHtml = '';
            if(kycDoc && kycDoc.status !== 'PENDING') {
                statusHtml = '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' mb-4 text-center"><p class="'+C.muted+' text-sm">حالة التوثيق</p>'+statusBadge(kycDoc.status)+(kycDoc.status==='REJECTED' && kycDoc.rejectReason ? '<p class="text-danger text-xs mt-2">سبب الرفض: '+escHtml(kycDoc.rejectReason)+'</p>' : '')+'</div>';
            }
            if(kycDoc && kycDoc.status === 'PENDING') {
                return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+' text-center">'+
                    '<h2 class="text-xl font-bold '+C.text+' mb-4">🪪 توثيق الهوية</h2>'+statusHtml+
                    '<div class="py-8"><p class="text-4xl mb-4">⏳</p><p class="'+C.muted+'">طلب التوثيق قيد المراجعة</p><p class="'+C.muted+' text-sm mt-2">سيتم إشعارك بالنتيجة</p></div></div>';
            }
            if(kycDoc && kycDoc.status === 'APPROVED') {
                return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+' text-center">'+
                    '<h2 class="text-xl font-bold '+C.text+' mb-4">🪪 توثيق الهوية</h2>'+statusHtml+
                    '<div class="py-8"><p class="text-4xl mb-4">✅</p><p class="'+C.muted+'">تم توثيق هويتك بنجاح</p></div></div>';
            }
            return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4 text-center">🪪 توثيق الهوية</h2>'+
                (kycDoc ? statusHtml : '')+
                '<div class="space-y-4">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">صورة الهوية (الوجه الأمامي) <span class="text-danger">*</span></label>'+
                previewDiv('kycFront')+
                '<div class="flex gap-2 mt-2">'+camBtn('kycFront',C)+fileBtn('kycFront',C)+'</div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">صورة الهوية (الوجه الخلفي) <span class="text-danger">*</span></label>'+
                previewDiv('kycBack')+
                '<div class="flex gap-2 mt-2">'+camBtn('kycBack',C)+fileBtn('kycBack',C)+'</div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">صورة سيلفي مع الهوية <span class="text-danger">*</span></label>'+
                previewDiv('kycSelfie')+
                '<div class="flex gap-2 mt-2">'+camBtn('kycSelfie',C)+fileBtn('kycSelfie',C)+'</div></div>'+
                '<button onclick="submitKYC()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn text-lg">إرسال طلب التوثيق</button></div></div>';
        }

        function submitKYC() {
            var user = getUser();
            var front = getFieldImage('kycFront');
            var back = getFieldImage('kycBack');
            var selfie = getFieldImage('kycSelfie');
            if(!front || !back || !selfie) { toast('يجب رفع جميع الصور','error'); return; }
            var docs = DB.get('kycDocuments');
            var existing = docs.findIndex(function(k){return k.userId===user.id;});
            var doc = {id:existing>=0?docs[existing].id:DB.uid(),userId:user.id,frontId:front,backId:back,selfieWithId:selfie,status:'PENDING',rejectReason:'',createdAt:new Date().toISOString()};
            if(existing>=0) docs[existing] = doc; else docs.unshift(doc);
            DB.set('kycDocuments', docs);
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===user.id;});
            if(u) { u.kycStatus = 'PENDING'; DB.set('users', users); }
            clearFieldImage('kycFront'); clearFieldImage('kycBack'); clearFieldImage('kycSelfie');
            toast('تم إرسال طلب التوثيق','success');
            addNotif(user.id,'طلب توثيق','تم إرسال طلب توثيق الهوية بنجاح','INFO');
            render();
        }

        // ==================== USER: HISTORY ====================
        function renderUserHistory(C) {
            var user = getUser();
            var deposits = DB.get('deposits').filter(function(d){return d.userId===user.id;});
            var withdrawals = DB.get('withdrawals').filter(function(w){return w.userId===user.id;});
            var all = [];
            deposits.forEach(function(d){ all.push({id:d.id,type:'DEPOSIT',amount:d.usdtAmount||0,currency:'USDT',status:d.status,date:d.createdAt,desc:'إيداع '+fmtNum(d.amount)+' '+(d.currency||''),approveProof:d.approveProof||null}); });
            withdrawals.forEach(function(w){ all.push({id:w.id,type:'WITHDRAW',amount:w.net||0,currency:'USDT',status:w.status,date:w.createdAt,desc:'سحب '+fmtNum(w.net)+' USDT',confirmScreenshot:w.confirmScreenshot||null}); });
            all.sort(function(a,b){ return new Date(b.date)-new Date(a.date); });
            if(all.length===0) return '<div class="'+C.card+' rounded-xl p-8 border '+C.border+' text-center"><p class="text-4xl mb-4">📋</p><p class="'+C.muted+'">لا توجد عمليات بعد</p></div>';
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'"><h2 class="text-xl font-bold '+C.text+' mb-4">📋 سجل العمليات</h2><div class="space-y-3 max-h-[70vh] overflow-y-auto">';
            all.forEach(function(item) {
                var isDep = item.type === 'DEPOSIT';
                html += '<div class="py-3 border-b '+C.border+' last:border-0">'+
                    '<div class="flex items-center justify-between">'+
                    '<div class="flex items-center gap-3"><span class="text-xl">'+(isDep?'💰':'🏧')+'</span><div><p class="text-sm font-medium '+C.text+'">'+item.desc+'</p><p class="text-xs '+C.muted+'">'+fmtDate(item.date)+'</p></div></div>'+
                    '<div class="text-left"><p class="font-bold text-sm '+(isDep?'text-success':'text-danger')+'">'+(isDep?'+':'-')+fmtNum(item.amount)+' '+item.currency+'</p>'+statusBadge(item.status)+'</div></div>'+
                    (item.confirmScreenshot?'<div class="mt-2"><p class="text-xs '+C.muted+' mb-1">📸 إثبات تنفيذ السحب:</p><img src="'+item.confirmScreenshot+'" class="h-20 rounded-lg border cursor-pointer object-cover" onclick="showImageModal(this.src)"></div>':'')+
                    (item.approveProof?'<div class="mt-2"><p class="text-xs '+C.muted+' mb-1">✅ إثبات تنفيذ الإيداع:</p><img src="'+item.approveProof+'" class="h-20 rounded-lg border cursor-pointer object-cover" onclick="showImageModal(this.src)"></div>':'')+
                    '</div>';
            });
            html += '</div></div>';
            return html;
        }

        // ==================== USER: NOTIFICATIONS ====================
        function renderUserNotifications(C) {
            var user = getUser();
            var notifs = (DB.get('notifications')||[]).filter(function(n){return n.userId===user.id;});
            var unread = notifs.filter(function(n){return !n.isRead;}).length;
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'"><div class="flex items-center justify-between mb-4"><h2 class="text-xl font-bold '+C.text+'">🔔 الإشعارات</h2>';
            if(unread > 0) html += '<button onclick="markAllNotifsRead()" class="text-sm text-primary btn hover:underline">تعيين الكل كمقروء ('+unread+')</button>';
            html += '</div>';
            if(notifs.length===0) html += '<p class="'+C.muted+' text-center py-8">لا توجد إشعارات</p>';
            else {
                html += '<div class="space-y-3 max-h-[70vh] overflow-y-auto">';
                notifs.forEach(function(n) {
                    var icons = {INFO:'ℹ️',DEPOSIT:'💰',WITHDRAW:'🏧',KYC:'🪪',MERCHANT:'🏪',AFFILIATE:'🔗'};
                    html += '<div class="flex gap-3 p-3 rounded-lg border '+C.border+' '+(n.isRead?'opacity-60':'')+'">'+
                        '<span class="text-xl">'+(icons[n.type]||'🔔')+'</span>'+
                        '<div class="flex-1"><p class="text-sm font-medium '+C.text+'">'+escHtml(n.title)+'</p><p class="text-xs '+C.muted+'">'+escHtml(n.message)+'</p><p class="text-xs '+C.muted+' mt-1">'+fmtDate(n.createdAt)+'</p></div>'+
                        (!n.isRead ? '<span class="w-2.5 h-2.5 bg-primary rounded-full shrink-0 mt-2"></span>' : '')+'</div>';
                });
                html += '</div>';
            }
            html += '</div>';
            return html;
        }

        function markAllNotifsRead() {
            var user = getUser();
            var notifs = DB.get('notifications');
            var changed = false;
            notifs.forEach(function(n){ if(n.userId===user.id && !n.isRead) { n.isRead = true; changed = true; } });
            if(changed) { DB.set('notifications', notifs); toast('تم تعيين الكل كمقروء','success',false); render(); }
        }

        // ==================== USER: SETTINGS ====================
        function renderUserSettings(C) {
            var user = getUser();
            return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-6 text-center">⚙️ الإعدادات</h2>'+
                '<div class="space-y-4">'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">معلومات الحساب</h3>'+
                '<div class="space-y-2 text-sm"><p class="'+C.muted+'">الاسم: <span class="'+C.text+'">'+escHtml(user.name)+'</span></p>'+
                '<p class="'+C.muted+'">البريد: <span class="'+C.text+'">'+escHtml(user.email)+'</span></p>'+
                '<p class="'+C.muted+'">الهاتف: <span class="'+C.text+'">'+escHtml(user.phone)+'</span></p>'+
                '<p class="'+C.muted+'">الدولة: <span class="'+C.text+'">'+escHtml(user.countryCode||'')+'</span></p></div></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">تغيير كلمة المرور</h3>'+
                '<div class="space-y-3"><input type="password" id="set-old-pass" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="كلمة المرور الحالية">'+
                '<input type="password" id="set-new-pass" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="كلمة المرور الجديدة">'+
                '<input type="password" id="set-new-pass2" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="تأكيد كلمة المرور الجديدة">'+
                '<button onclick="changePassword()" class="'+C.btn+' w-full py-2.5 rounded-lg font-bold btn">تغيير كلمة المرور</button></div></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">تغيير رقم الهاتف</h3>'+
                '<p class="'+C.muted+' text-xs mb-2">يتطلب التقاط صورة سيلفي مع الهوية للتحقق</p>'+
                '<input type="text" id="set-new-phone" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none mb-2" placeholder="رقم الهاتف الجديد">'+
                previewDiv('phoneChangeSelfie')+
                '<div class="mt-2"><button type="button" onclick="captureForField(\'phoneChangeSelfie\')" class="w-full px-4 py-2.5 rounded-lg border '+C.border+' '+C.text+' btn text-sm font-medium">📸 التقاط صورة سيلفي بالكاميرا (إلزامي)</button></div>'+
                '<button onclick="requestPhoneChange()" class="w-full py-2.5 rounded-lg font-bold btn bg-info text-white">طلب تغيير رقم الهاتف</button></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">تغيير البريد الإلكتروني</h3>'+
                '<p class="'+C.muted+' text-xs mb-2">يتطلب التقاط صورة سيلفي مع الهوية للتحقق</p>'+
                '<input type="email" id="set-new-email" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none mb-2" placeholder="البريد الجديد">'+
                previewDiv('emailChangeSelfie')+
                '<div class="mt-2"><button type="button" onclick="captureForField(\'emailChangeSelfie\')" class="w-full px-4 py-2.5 rounded-lg border '+C.border+' '+C.text+' btn text-sm font-medium">📸 التقاط صورة سيلفي بالكاميرا (إلزامي)</button></div>'+
                '<button onclick="requestEmailChange()" class="w-full py-2.5 rounded-lg font-bold btn bg-info text-white">طلب تغيير البريد</button></div></div></div>';
        }

        function changePassword() {
            var user = getUser();
            var oldPass = document.getElementById('set-old-pass').value;
            var newPass = document.getElementById('set-new-pass').value;
            var newPass2 = document.getElementById('set-new-pass2').value;
            if(!oldPass || !newPass) { toast('أكمل جميع الحقول','error'); return; }
            if(newPass !== newPass2) { toast('كلمات المرور غير متطابقة','error'); return; }
            if(newPass.length < 6) { toast('كلمة المرور يجب أن تكون 6 أحرف على الأقل','error'); return; }
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===user.id;});
            if(!u || u.password !== oldPass) { toast('كلمة المرور الحالية غير صحيحة','error'); return; }
            u.password = newPass;
            DB.set('users', users);
            toast('تم تغيير كلمة المرور','success');
            document.getElementById('set-old-pass').value = '';
            document.getElementById('set-new-pass').value = '';
            document.getElementById('set-new-pass2').value = '';
        }

        function requestPhoneChange() {
            var user = getUser();
            var newPhone = document.getElementById('set-new-phone').value.trim();
            var selfie = getFieldImage('phoneChangeSelfie');
            if(!newPhone) { toast('أدخل رقم الهاتف الجديد','error'); return; }
            if(!selfie) { toast('يجب التقاط صورة سيلفي مع الهوية','error'); return; }
            var requests = DB.get('profileChangeRequests');
            requests.unshift({id:DB.uid(),userId:user.id,type:'CHANGE_PHONE',newValue:newPhone,selfie:selfie,status:'PENDING',createdAt:new Date().toISOString()});
            DB.set('profileChangeRequests', requests);
            clearFieldImage('phoneChangeSelfie');
            toast('تم إرسال طلب تغيير رقم الهاتف','success');
            addNotif(user.id,'طلب تغيير','تم إرسال طلب تغيير رقم الهاتف، بانتظار مراجعة الإدارة','INFO');
            render();
        }

        function requestEmailChange() {
            var user = getUser();
            var newEmail = document.getElementById('set-new-email').value.trim();
            var selfie = getFieldImage('emailChangeSelfie');
            if(!newEmail) { toast('أدخل البريد الجديد','error'); return; }
            if(!selfie) { toast('يجب التقاط صورة سيلفي مع الهوية','error'); return; }
            var requests = DB.get('profileChangeRequests');
            requests.unshift({id:DB.uid(),userId:user.id,type:'CHANGE_EMAIL',newValue:newEmail,selfie:selfie,status:'PENDING',createdAt:new Date().toISOString()});
            DB.set('profileChangeRequests', requests);
            clearFieldImage('emailChangeSelfie');
            toast('تم إرسال طلب تغيير البريد','success');
            addNotif(user.id,'طلب تغيير','تم إرسال طلب تغيير البريد الإلكتروني، بانتظار مراجعة الإدارة','INFO');
            render();
        }
        // ==================== USER: WITHDRAWAL METHODS ====================
        function renderUserWithdrawalMethods(C) {
            var user = getUser();
            var wms = DB.get('userWithdrawalMethods').filter(function(w){return w.userId===user.id;});
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'"><div class="flex items-center justify-between mb-4"><h2 class="text-xl font-bold '+C.text+'">🏦 حسابات السحب</h2>'+
                '<button onclick="showAddWmModal()" class="'+C.btn+' px-4 py-2 rounded-lg font-bold btn text-sm">+ إضافة</button></div>';
            if(wms.length===0) html += '<p class="'+C.muted+' text-center py-8">لا توجد حسابات سحب محفوظة</p>';
            else {
                html += '<div class="space-y-3">';
                wms.forEach(function(w) {
                    var info = '';
                    if(w.type==='BANK') info = '<p class="text-sm font-medium '+C.text+'">'+escHtml(w.bankName||'تحويل بنكي')+'</p><p class="text-xs '+C.muted+'">رقم الحساب: '+escHtml(w.accountNumber||'')+'</p><p class="text-xs '+C.muted+'">الاسم: '+escHtml(w.recipientName||'')+'</p>';
                    else info = '<p class="text-sm font-medium '+C.text+'">'+escHtml(w.currencyName||'USDT')+' ('+escHtml(w.network||'') +')</p><p class="text-xs '+C.muted+' font-mono">'+escHtml((w.address||'').substr(0,24))+'...</p>';
                    html += '<div class="flex items-center justify-between p-4 rounded-lg border '+C.border+'"><div>'+info+'</div>'+
                        '<button onclick="requestDeleteWm(\''+w.id+'\')" class="text-danger text-sm btn hover:underline px-2 py-1">🗑️ حذف</button></div>';
                });
                html += '</div>';
            }
            html += '</div>';
            return html;
        }

        function showAddWmModal() {
            var C = getThemeColors();
            var html = '<h3 class="text-lg font-bold '+C.text+' mb-4">إضافة طريقة سحب</h3>'+
                '<div class="space-y-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">نوع الطريقة</label><select id="wm-type" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" onchange="toggleWmFields()"><option value="BANK">تحويل بنكي</option><option value="CRYPTO">عملات رقمية</option></select></div>'+
                '<div id="wm-bank-fields"><div class="space-y-3"><input type="text" id="wm-bank-name" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اسم المحفظة/البنك"><input type="text" id="wm-account" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="رقم الحساب"><input type="text" id="wm-recipient" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اسم صاحب الحساب"></div></div>'+
                '<div id="wm-crypto-fields" class="hidden"><div class="space-y-3"><input type="text" id="wm-currency-name" value="USDT" readonly class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none opacity-70"><select id="wm-network" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"><option value="TRC20">TRC20</option><option value="BEP20">BEP20</option><option value="ERC20">ERC20</option></select><input type="text" id="wm-address" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="عنوان المحفظة"></div></div>'+
                '<button onclick="submitWm()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn">إضافة</button>'+
                '<button onclick="closeModal()" class="w-full py-2.5 rounded-lg border '+C.border+' '+C.text+' btn">إلغاء</button></div>';
            showModal(html);
        }

        function toggleWmFields() {
            var type = document.getElementById('wm-type').value;
            document.getElementById('wm-bank-fields').classList.toggle('hidden', type !== 'BANK');
            document.getElementById('wm-crypto-fields').classList.toggle('hidden', type !== 'CRYPTO');
        }

        function submitWm() {
            var user = getUser();
            var type = document.getElementById('wm-type').value;
            var wms = DB.get('userWithdrawalMethods');
            var method = { id: DB.uid(), userId: user.id, type: type };
            if(type === 'BANK') {
                var bankName = document.getElementById('wm-bank-name').value.trim();
                var account = document.getElementById('wm-account').value.trim();
                var recipient = document.getElementById('wm-recipient').value.trim();
                if(!bankName || !account || !recipient) { toast('أكمل جميع الحقول','error'); return; }
                method.bankName = bankName; method.accountNumber = account; method.recipientName = recipient;
            } else {
                var network = document.getElementById('wm-network').value;
                var address = document.getElementById('wm-address').value.trim();
                if(!address) { toast('أدخل عنوان المحفظة','error'); return; }
                method.currencyName = 'USDT'; method.network = network; method.address = address;
            }
            method.createdAt = new Date().toISOString();
            wms.push(method);
            DB.set('userWithdrawalMethods', wms);
            toast('تم إضافة طريقة السحب','success');
            closeModal();
            render();
        }

        function requestDeleteWm(wmId) {
            showConfirm('🗑️','حذف طريقة السحب','سيتم إرسال طلب حذف للموافقة. هل تريد المتابعة؟','نعم، احذف','bg-danger text-white',function(yes){
                if(!yes) return;
                captureForFieldWithCallback('deleteWmSelfie', function(img) {
                    var user = getUser();
                    var requests = DB.get('profileChangeRequests');
                    requests.unshift({id:DB.uid(),userId:user.id,type:'DELETE_WD_METHOD',targetId:wmId,selfie:img,status:'PENDING',createdAt:new Date().toISOString()});
                    DB.set('profileChangeRequests', requests);
                    toast('تم إرسال طلب الحذف للموافقة','success');
                    addNotif(user.id,'طلب حذف','تم إرسال طلب حذف طريقة سحب، بانتظار مراجعة الإدارة','INFO');
                });
            });
        }

        // ==================== USER: CHAT ====================
        function renderUserChat(C) {
            var user = getUser();
            var adminUser = DB.get('users').find(function(u){return u.role==='ADMIN';});
            if(!adminUser) return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+' text-center"><p class="'+C.muted+'">لا يوجد مشرف متاح</p></div>';
            var adminId = adminUser.id;
            var messages = DB.get('messages').filter(function(m){return (m.fromId===user.id && m.toId===adminId)||(m.fromId===adminId && m.toId===user.id);});
            messages.sort(function(a,b){return new Date(a.createdAt)-new Date(b.createdAt);});
            var msgsHtml = '';
            if(messages.length===0) msgsHtml = '<p class="'+C.muted+' text-center py-8 text-sm">ابدأ المحادثة مع فريق الدعم</p>';
            else {
                messages.forEach(function(m) {
                    var isMe = m.fromId === user.id;
                    msgsHtml += '<div class="flex '+(isMe?'justify-start':'justify-end')+' mb-3">'+
                        '<div class="max-w-[75%] px-4 py-2.5 rounded-xl '+(isMe?'chat-bubble-me':'chat-bubble-other')+'"><p>'+escHtml(m.text)+'</p><p class="text-[10px] opacity-60 mt-1">'+fmtDate(m.createdAt)+'</p></div></div>';
                });
            }
            var msgsUnread = messages.filter(function(m){return m.fromId===adminId && !m.isRead;});
            if(msgsUnread.length>0) {
                var allMsgs = DB.get('messages');
                msgsUnread.forEach(function(m) {
                    var idx = allMsgs.findIndex(function(x){return x.id===m.id;});
                    if(idx>=0) allMsgs[idx].isRead = true;
                });
                DB.set('messages', allMsgs);
            }
            setTimeout(function(){
                var chatBox = document.getElementById('user-chat-messages');
                if(chatBox) chatBox.scrollTop = chatBox.scrollHeight;
            }, 100);
            return '<div class="'+C.card+' rounded-xl border '+C.border+' flex flex-col" style="height:calc(100vh - 160px)">'+
                '<div class="p-4 border-b '+C.border+' flex items-center gap-3"><span class="text-2xl">💬</span><div><p class="font-bold '+C.text+'">الدعم الفني</p><p class="text-xs '+C.muted+'">فريق ForexYemeni</p></div></div>'+
                '<div id="user-chat-messages" class="flex-1 overflow-y-auto p-4 space-y-1">'+msgsHtml+'</div>'+
                '<div class="p-3 border-t '+C.border+' flex gap-2"><input type="text" id="user-chat-input" class="flex-1 px-4 py-2.5 rounded-lg border '+C.input+' outline-none text-sm" placeholder="اكتب رسالتك..." onkeydown="if(event.key===\'Enter\')sendUserChat()">'+
                '<button onclick="sendUserChat()" class="'+C.btn+' px-5 py-2.5 rounded-lg btn text-sm">إرسال</button></div></div>';
        }

        function sendUserChat() {
            var user = getUser();
            var input = document.getElementById('user-chat-input');
            if(!input) return;
            var text = input.value.trim();
            if(!text) return;
            var adminUser = DB.get('users').find(function(u){return u.role==='ADMIN';});
            if(!adminUser) { toast('لا يوجد مشرف','error'); return; }
            var msgs = DB.get('messages');
            msgs.push({id:DB.uid(),fromId:user.id,toId:adminUser.id,text:text,isRead:false,createdAt:new Date().toISOString()});
            DB.set('messages', msgs);
            input.value = '';
            render();
        }

        // ==================== USER: AFFILIATE ====================
        function renderUserAffiliate(C) {
            var user = getUser();
            var status = user.affiliateStatus || 'NONE';
            if(status === 'NONE') {
                return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+' text-center">'+
                    '<h2 class="text-xl font-bold '+C.text+' mb-4">🔗 نظام العمولة</h2>'+
                    '<div class="py-8"><p class="text-4xl mb-4">🔗</p><p class="'+C.muted+' mb-6">يمكنك كسب عمولة من خلال دعوة أصدقائك</p>'+
                    '<button onclick="requestAffiliate()" class="'+C.btn+' px-8 py-3 rounded-lg font-bold btn text-lg">طلب الانضمام</button></div></div>';
            }
            if(status === 'PENDING') {
                return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+' text-center">'+
                    '<h2 class="text-xl font-bold '+C.text+' mb-4">🔗 نظام العمولة</h2>'+
                    '<div class="py-8"><p class="text-4xl mb-4">⏳</p><p class="'+C.muted+'">طلب الانضمام قيد المراجعة</p></div></div>';
            }
            var users = DB.get('users');
            var referrals = users.filter(function(u){return u.referredBy===user.id;});
            var code = user.affiliateCode || '';
            var balance = user.affiliateBalance || 0;
            var refHtml = referrals.length===0 ? '<p class="'+C.muted+' text-sm text-center py-4">لا يوجد مدعوين بعد</p>' :
                referrals.map(function(r) {
                    return '<div class="flex items-center justify-between py-2 border-b '+C.border+' last:border-0">'+
                        '<div><p class="text-sm '+C.text+'">'+escHtml(r.name)+'</p><p class="text-xs '+C.muted+'">'+escHtml(r.phone)+'</p></div>'+
                        '<span class="text-xs '+C.muted+'">'+fmtDate(r.createdAt)+'</span></div>';
                }).join('');
            return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4 text-center">🔗 نظام العمولة</h2>'+
                '<div class="grid grid-cols-2 gap-3 mb-4">'+
                '<div class="'+C.card+' rounded-lg p-3 text-center border '+C.border+'"><p class="'+C.muted+' text-xs">كود الإحالة</p><p class="font-bold text-primary text-lg font-mono">'+escHtml(code)+'</p><button onclick="copyText(\''+escHtml(code)+'\')" class="text-xs text-primary btn mt-1">نسخ</button></div>'+
                '<div class="'+C.card+' rounded-lg p-3 text-center border '+C.border+'"><p class="'+C.muted+' text-xs">رصيد العمولات</p><p class="font-bold text-success text-lg">'+fmtNum(balance)+' USDT</p></div></div>'+
                '<div class="'+C.card+' rounded-lg p-3 border '+C.border+' mb-4"><p class="'+C.muted+' text-xs">عدد المدعوين: <span class="'+C.text+' font-bold">'+referrals.length+'</span></p></div>'+
                '<button onclick="withdrawAffiliateBalance()" class="w-full py-2.5 rounded-lg font-bold btn bg-info text-white mb-4">سحب أرباح العمولات إلى رصيدي</button>'+
                '<h3 class="font-bold '+C.text+' mb-3">قائمة المدعوين</h3>'+
                '<div class="max-h-64 overflow-y-auto">'+refHtml+'</div></div>';
        }

        function requestAffiliate() {
            var user = getUser();
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===user.id;});
            if(!u) return;
            u.affiliateStatus = 'PENDING';
            u.affiliateCode = 'FX' + Math.random().toString(36).substr(2, 6).toUpperCase();
            DB.set('users', users);
            toast('تم إرسال طلب الانضمام لنظام العمولة','success');
            addNotif(user.id,'طلب عمولة','تم إرسال طلب الانضمام لنظام العمولة','INFO');
            render();
        }

        function withdrawAffiliateBalance() {
            var user = getUser();
            var balance = user.affiliateBalance || 0;
            if(balance <= 0) { toast('لا يوجد رصيد عمولات للسحب','warning'); return; }
            showConfirm('💰','سحب العمولات','سيتم تحويل '+fmtNum(balance)+' USDT من أرباح العمولات إلى رصيدك. متابعة؟','نعم، سحب','bg-success text-dark-bg',function(yes){
                if(!yes) return;
                var users = DB.get('users');
                var u = users.find(function(x){return x.id===user.id;});
                if(!u) return;
                u.usdtBalance = (u.usdtBalance||0) + balance;
                u.affiliateBalance = 0;
                DB.set('users', users);
                addLog(user.id,'AFFILIATE_WITHDRAW',balance,'USDT','سحب أرباح عمولات إلى الرصيد');
                toast('تم تحويل العمولات إلى رصيدك','success');
                render();
            });
        }

        // ==================== USER: MERCHANT ====================
        function renderUserMerchant(C) {
            var user = getUser();
            var status = user.merchantStatus || 'NONE';
            var mReq = DB.get('merchantRequests').find(function(r){return r.userId===user.id;});
            var statusHtml = '';
            if(mReq) {
                statusHtml = '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' mb-4 text-center">'+
                    '<p class="'+C.muted+' text-sm mb-2">حالة الطلب</p>'+statusBadge(mReq.status)+
                    (mReq.status==='REJECTED'&&mReq.rejectReason?'<p class="text-danger text-xs mt-2">السبب: '+escHtml(mReq.rejectReason)+'</p>':'')+'</div>';
            }
            if(status === 'PENDING' || (mReq && mReq.status === 'PENDING')) {
                return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+' text-center">'+
                    '<h2 class="text-xl font-bold '+C.text+' mb-4">🏪 طلب تاجر</h2>'+statusHtml+
                    '<div class="py-8"><p class="text-4xl mb-4">⏳</p><p class="'+C.muted+'">طلب التاجر قيد المراجعة</p></div></div>';
            }
            if(status === 'APPROVED') {
                return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+' text-center">'+
                    '<h2 class="text-xl font-bold '+C.text+' mb-4">🏪 مرحباً بك كتاجر</h2>'+statusHtml+
                    '<div class="py-6"><p class="text-4xl mb-4">✅</p><p class="'+C.muted+' mb-2">تم تحويل حسابك إلى حساب تاجر بنجاح</p><p class="'+C.muted+' mb-4">سيتم توجيهك تلقائياً إلى لوحة تحكم التاجر. أو قم بتسجيل الخروج وتسجيل الدخول مجدداً.</p>'+
                    '<button onclick="setView(\'merchant-dashboard\')" class="'+C.btn+' px-8 py-3 rounded-lg font-bold btn text-lg mb-3 w-full">🏪 لوحة تحكم التاجر</button>'+
                    '<button onclick="logout()" class="px-8 py-3 rounded-lg font-bold btn border '+C.border+' '+C.text+' w-full">🔓 تسجيل الخروج</button></div></div>';
            }
            return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4 text-center">🏪 طلب التاجر</h2>'+
                '<div class="bg-danger/10 border border-danger/30 rounded-xl p-4 mb-4">'+
                '<div class="flex items-start gap-3">'+
                '<span class="text-2xl shrink-0">⚠️</span>'+
                '<div><p class="text-danger font-bold text-sm mb-1">تنبيه هام جداً</p>'+
                '<p class="text-xs text-danger/80 leading-relaxed">عند الموافقة على طلبك كتاجر، سيتم <span class="font-bold">تحويل حسابك بالكامل</span> من حساب مستخدم عادي إلى حساب تاجر. لن تتمكن من استخدام الميزات العادية للمستخدم (الإيداع المباشر، السحب المباشر) وسيتم توجيهك إلى لوحة تحكم التاجر. هذا الإجراء <span class="font-bold">لا يمكن التراجع عنه</span>.</p></div></div></div>'+
                statusHtml+
                '<div class="space-y-4">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">صورة الهوية (الوجه الأمامي) <span class="text-danger">*</span></label>'+
                previewDiv('merchFront')+
                '<div class="flex gap-2 mt-2">'+camBtn('merchFront',C)+fileBtn('merchFront',C)+'</div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">صورة الهوية (الوجه الخلفي) <span class="text-danger">*</span></label>'+
                previewDiv('merchBack')+
                '<div class="flex gap-2 mt-2">'+camBtn('merchBack',C)+fileBtn('merchBack',C)+'</div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">صورة سيلفي مع الهوية <span class="text-danger">*</span></label>'+
                previewDiv('merchSelfie')+
                '<div class="flex gap-2 mt-2">'+camBtn('merchSelfie',C)+fileBtn('merchSelfie',C)+'</div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">إثبات العنوان (فاتورة أو كشف حساب أقل من 3 أشهر) <span class="text-danger">*</span></label>'+
                previewDiv('merchAddress')+
                '<div class="flex gap-2 mt-2">'+camBtn('merchAddress',C)+fileBtn('merchAddress',C)+'</div></div>'+
                '<div class="flex items-start gap-2"><input type="checkbox" id="merch-declaration" class="mt-1"><label for="merch-declaration" class="text-sm '+C.muted+'">أقر بأن البيانات المقدمة صحيحة وأن إثبات العنوان لا يتجاوز 3 أشهر</label></div>'+
                '<button onclick="submitMerchantRequest()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn text-lg">إرسال طلب التاجر</button></div></div>'+
                renderMerchantMarketplace(C);
        }

        function submitMerchantRequest() {
            var user = getUser();
            var front = getFieldImage('merchFront');
            var back = getFieldImage('merchBack');
            var selfie = getFieldImage('merchSelfie');
            var address = getFieldImage('merchAddress');
            if(!front || !back || !selfie || !address) { toast('يجب رفع جميع المستندات','error'); return; }
            var declaration = document.getElementById('merch-declaration');
            if(!declaration || !declaration.checked) { toast('يجب الموافقة على الإقرار','error'); return; }
            var reqs = DB.get('merchantRequests');
            reqs.unshift({id:DB.uid(),userId:user.id,frontId:front,backId:back,selfieWithId:selfie,proofOfAddress:address,status:'PENDING',rejectReason:'',createdAt:new Date().toISOString()});
            DB.set('merchantRequests', reqs);
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===user.id;});
            if(u) { u.merchantStatus = 'PENDING'; DB.set('users', users); }
            clearFieldImage('merchFront'); clearFieldImage('merchBack'); clearFieldImage('merchSelfie'); clearFieldImage('merchAddress');
            toast('تم إرسال طلب التاجر','success');
            addNotif(user.id,'طلب تاجر','تم إرسال طلب الانضمام كتاجر بنجاح','INFO');
            render();
        }

        function renderMerchantMarketplace(C) {
            var allUsers = DB.get('users');
            var approvedMerchants = allUsers.filter(function(u){return u.role==='MERCHANT' && u.merchantStatus==='APPROVED';});
            if(approvedMerchants.length === 0) return '';
            var html = '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+' mt-4">'+
                '<h3 class="text-lg font-bold '+C.text+' mb-3 text-center">🏪 سوق التجار المعتمدين</h3>'+
                '<p class="text-xs '+C.muted+' text-center mb-3">اختر تاجراً للتعامل معه عند الإيداع أو السحب</p>'+
                '<div class="space-y-3">';
            approvedMerchants.forEach(function(m) {
                var rate = parseFloat(DB.getSetting('exchange_rate')) || 535;
                var txns = DB.get('merchantTransactions').filter(function(t){return t.merchantId===m.id;});
                var completedTxns = txns.filter(function(t){return t.status==='APPROVED';}).length;
                html += '<div class="p-3 rounded-lg border '+C.border+' overflow-hidden">'+
                    '<div class="flex items-center gap-3 mb-2">'+
                    '<div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-sm shrink-0">🏪</div>'+
                    '<div class="min-w-0 flex-1"><p class="font-medium text-sm '+C.text+' truncate">'+escHtml(m.name)+'</p>'+
                    '<p class="text-xs '+C.muted+'">عملات: <span class="text-success font-bold">'+fmtNum(m.usdtBalance||0)+' USDT</span></p></div></div>'+
                    '<div class="flex gap-3 text-xs '+C.muted+'">'+
                    '<span>📊 معاملات: '+completedTxns+'</span>'+
                    '<span>💱 سعر الصرف: '+rate+' YER</span></div></div>';
            });
            html += '</div></div>';
            return html;
        }

        // ==================== MERCHANT: DASHBOARD ====================
        function renderMerchantDashboard(C) {
            var user = getUser();
            var rate = parseFloat(DB.getSetting('exchange_rate')) || 535;
            var allDeposits = DB.get('deposits');
            var allWithdrawals = DB.get('withdrawals');
            var merchantDeposits = allDeposits.filter(function(d){return d.assignedMerchantId === user.id;});
            var merchantWithdrawals = allWithdrawals.filter(function(w){return w.assignedMerchantId === user.id;});
            var pendingDepCount = merchantDeposits.filter(function(d){return d.status==='PENDING';}).length;
            var pendingWdCount = merchantWithdrawals.filter(function(w){return w.status==='PENDING';}).length;
            var totalProcessed = merchantDeposits.filter(function(d){return d.status==='APPROVED';}).length + merchantWithdrawals.filter(function(w){return w.status==='APPROVED';}).length;
            return '<div class="space-y-4">'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-sm">مرحباً، التاجر</p><h2 class="text-xl font-bold '+C.text+'">'+escHtml(user.name)+'</h2><p class="text-xs '+C.muted+'">سعر الصرف: 1 USDT = '+fmtNum(rate)+' YER</p></div>'+
                '<div class="grid grid-cols-2 md:grid-cols-4 gap-3">'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="text-3xl mb-1">💰</p><p class="text-2xl font-bold text-warning">'+pendingDepCount+'</p><p class="'+C.muted+' text-xs">إيداعات معلقة</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="text-3xl mb-1">🏧</p><p class="text-2xl font-bold text-warning">'+pendingWdCount+'</p><p class="'+C.muted+' text-xs">سحوبات معلقة</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="text-3xl mb-1">✅</p><p class="text-2xl font-bold text-success">'+totalProcessed+'</p><p class="'+C.muted+' text-xs">معاملات تمت</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="text-3xl mb-1">💳</p><p class="text-2xl font-bold text-primary">'+fmtNum(user.usdtBalance||0)+'</p><p class="'+C.muted+' text-xs">رصيدك USDT</p></div></div>'+
                '<div class="grid grid-cols-2 gap-3">'+
                '<button onclick="setView(\'merchant-pending-deposits\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">💰</span><p class="text-sm mt-2 font-medium '+C.text+'">إيداعاتي المعلقة</p></button>'+
                '<button onclick="setView(\'merchant-pending-withdrawals\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">🏧</span><p class="text-sm mt-2 font-medium '+C.text+'">سحوباتي المعلقة</p></button>'+
                '<button onclick="setView(\'merchant-settings\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">⚙️</span><p class="text-sm mt-2 font-medium '+C.text+'">بيانات الإيداع</p></button>'+
                '<button onclick="setView(\'merchant-transactions\')" class="'+C.card+' rounded-xl p-4 text-center border '+C.border+' hover:border-primary btn"><span class="text-2xl">📊</span><p class="text-sm mt-2 font-medium '+C.text+'">معاملاتي</p></button></div></div>';
        }

        // ==================== MERCHANT: PENDING DEPOSITS ====================
        function renderMerchantPendingDeposits(C) {
            var user = getUser();
            var deposits = DB.get('deposits').filter(function(d){return d.status==='PENDING' && d.assignedMerchantId === user.id;});
            deposits.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">💰 الإيداعات المعلقة ('+deposits.length+')</h2>';
            if(deposits.length===0) html += '<p class="'+C.muted+' text-center py-8">لا توجد إيداعات معلقة</p>';
            else {
                html += '<div class="space-y-3 max-h-[70vh] overflow-y-auto">';
                var users = DB.get('users');
                var pms = DB.get('paymentMethods');
                deposits.forEach(function(d) {
                    var u = users.find(function(x){return x.id===d.userId;});
                    var pm = pms.find(function(x){return x.id===d.paymentMethodId;});
                    html += '<div class="p-4 rounded-lg border '+C.border+'">'+
                        '<div class="flex items-center justify-between mb-2"><div><p class="font-medium text-sm '+C.text+'">'+escHtml(u?u.name:'مستخدم')+'</p><p class="text-xs '+C.muted+'">'+fmtDate(d.createdAt)+'</p></div>'+statusBadge('PENDING')+'</div>'+
                        '<div class="grid grid-cols-2 gap-2 text-xs mb-3">'+
                        '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">المبلغ</p><p class="font-bold">'+fmtNum(d.amount)+' '+(d.currency||'')+'</p></div>'+
                        '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">USDT</p><p class="font-bold text-success">'+fmtNum(d.usdtAmount||0)+'</p></div></div>'+
                        (d.receipt?'<div class="mb-3"><p class="text-xs '+C.muted+' mb-1">📄 إيصال المستخدم:</p><img src="'+d.receipt+'" class="h-32 w-full rounded-lg border cursor-pointer object-cover" onclick="showImageModal(this.src)"></div>':'')+
                        '<div class="flex gap-2"><button onclick="merchantApproveDeposit(\''+d.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-success text-dark-bg text-sm">✅ قبول</button><button onclick="merchantRejectDeposit(\''+d.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div></div>';
                });
                html += '</div>';
            }
            html += '</div>';
            return html;
        }

        function merchantApproveDeposit(depId) {
            var C = getThemeColors();
            showModal('<h3 class="text-lg font-bold '+C.text+' mb-4">✅ رفع إثبات الإيداع</h3>'+
                '<p class="'+C.muted+' text-sm mb-4">ارفع إثبات تنفيذ الإيداع (صورة تحويل أو لقطة شاشة) لكي يراها المستخدم</p>'+
                '<div id="merchant-proof-preview"></div>'+
                '<div class="flex gap-2 mb-4">'+
                '<button type="button" onclick="captureForField(\'merchDepProof\');showImagePreviewAfterCapture(\'merchDepProof\',\'merchant-proof-preview\')" class="flex-1 px-4 py-3 rounded-lg border '+C.border+' '+C.text+' btn text-sm font-medium">📸 كاميرا</button>'+
                '<label class="flex-1 px-4 py-3 rounded-lg border '+C.border+' '+C.text+' btn text-sm font-medium text-center cursor-pointer">📁 رفع ملف<input type="file" accept="image/*" class="hidden" onchange="fileForFieldWithPreview(\'merchDepProof\',this,\'merchant-proof-preview\')"></label>'+
                '</div>'+
                '<div id="merchant-proof-actions" class="hidden">'+
                '<button onclick="confirmMerchantApproveDeposit(\''+depId+'\')" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn text-lg">✅ تأكيد القبول</button>'+
                '</div>'+
                '<button onclick="closeModal()" class="w-full py-2.5 rounded-lg border '+C.border+' '+C.text+' btn mt-2">إلغاء</button>');
        }

        function showImagePreviewAfterCapture(fieldName, previewId) {
            setTimeout(function(){
                var imgSrc = getFieldImage(fieldName);
                if(imgSrc) {
                    var el = document.getElementById(previewId);
                    if(el) el.innerHTML = '<div class="relative inline-block mb-3"><img src="'+imgSrc+'" class="h-32 rounded-lg border object-cover"><button onclick="clearFieldImage(\''+fieldName+'\');document.getElementById(\''+previewId+'\').innerHTML=\'\';document.getElementById(\'merchant-proof-actions\').classList.add(\'hidden\')" class="absolute -top-2 -left-2 w-6 h-6 bg-danger text-white rounded-full text-xs flex items-center justify-center btn">✕</button></div>';
                    var actEl = document.getElementById('merchant-proof-actions');
                    if(actEl) actEl.classList.remove('hidden');
                }
            }, 500);
        }

        function fileForFieldWithPreview(fieldName, inputEl, previewId) {
            var file = inputEl.files[0];
            if(file) {
                compressImage(file, 500).then(function(compressed){
                    setFieldImage(fieldName, compressed);
                    toast('تم رفع الصورة','success',false);
                    showImagePreviewAfterCapture(fieldName, previewId);
                });
            }
        }

        function confirmMerchantApproveDeposit(depId) {
            var proofImg = getFieldImage('merchDepProof');
            if(!proofImg) { toast('يجب رفع إثبات الإيداع أولاً','error'); return; }
            closeModal();
            showConfirm('✅','قبول الإيداع','هل تريد قبول هذا الإيداع؟ سيتم حفظ إثبات التنفيذ.','نعم، قبول','bg-success text-dark-bg',function(yes){
                if(!yes) return;
                var user = getUser();
                var deposits = DB.get('deposits');
                var d = deposits.find(function(x){return x.id===depId;});
                if(!d) return;
                d.status = 'APPROVED';
                d.processedBy = user.id;
                d.approveProof = proofImg;
                var users = DB.get('users');
                var u = users.find(function(x){return x.id===d.userId;});
                if(u) { u.usdtBalance = (u.usdtBalance||0) + (d.usdtAmount||0); DB.set('users', users); }
                DB.set('deposits', deposits);
                var mTxns = DB.get('merchantTransactions');
                mTxns.unshift({id:DB.uid(),merchantId:user.id,userId:d.userId,type:'DEPOSIT',amount:d.usdtAmount,status:'APPROVED',screenshot:proofImg,createdAt:new Date().toISOString()});
                DB.set('merchantTransactions', mTxns);
                addLog(d.userId,'DEPOSIT_APPROVED',d.usdtAmount,'USDT','تم قبول إيداع '+fmtNum(d.usdtAmount)+' USDT');
                addNotif(d.userId,'إيداع مقبول','تم قبول إيداعك بمبلغ '+fmtNum(d.usdtAmount)+' USDT','DEPOSIT');
                clearFieldImage('merchDepProof');
                toast('تم قبول الإيداع','success');
                render();
            });
        }

        function merchantRejectDeposit(depId) {
            var user = getUser();
            showConfirm('❌','رفض الإيداع','هل تريد رفض هذا الإيداع؟','نعم، رفض','bg-danger text-white',function(yes){
                if(!yes) return;
                var deposits = DB.get('deposits');
                var d = deposits.find(function(x){return x.id===depId;});
                if(!d) return;
                d.status = 'REJECTED';
                d.processedBy = user.id;
                DB.set('deposits', deposits);
                var mTxns = DB.get('merchantTransactions');
                mTxns.unshift({id:DB.uid(),merchantId:user.id,userId:d.userId,type:'DEPOSIT',amount:d.usdtAmount,status:'REJECTED',createdAt:new Date().toISOString()});
                DB.set('merchantTransactions', mTxns);
                addNotif(d.userId,'إيداع مرفوض','تم رفض إيداعك بمبلغ '+fmtNum(d.usdtAmount)+' USDT','DEPOSIT');
                toast('تم رفض الإيداع','success');
                render();
            });
        }

        // ==================== MERCHANT: PENDING WITHDRAWALS ====================
        function renderMerchantPendingWithdrawals(C) {
            var user = getUser();
            var withdrawals = DB.get('withdrawals').filter(function(w){return w.status==='PENDING' && w.assignedMerchantId === user.id;});
            withdrawals.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">🏧 السحوبات المعلقة ('+withdrawals.length+')</h2>';
            if(withdrawals.length===0) html += '<p class="'+C.muted+' text-center py-8">لا توجد سحوبات معلقة</p>';
            else {
                html += '<div class="space-y-3 max-h-[70vh] overflow-y-auto">';
                var users = DB.get('users');
                var wms = DB.get('userWithdrawalMethods');
                withdrawals.forEach(function(w) {
                    var u = users.find(function(x){return x.id===w.userId;});
                    var method = wms.find(function(x){return x.id===w.withdrawalMethodId;});
                    var methodInfo = '';
                    if(method) {
                        if(method.type==='BANK') methodInfo = escHtml(method.bankName||'')+' | '+escHtml(method.accountNumber||'')+' | '+escHtml(method.recipientName||'');
                        else methodInfo = escHtml(method.network||'')+' | '+(method.address||'').substr(0,16)+'...';
                    }
                    html += '<div class="p-4 rounded-lg border '+C.border+'">'+
                        '<div class="flex items-center justify-between mb-2"><div><p class="font-medium text-sm '+C.text+'">'+escHtml(u?u.name:'مستخدم')+'</p><p class="text-xs '+C.muted+'">'+fmtDate(w.createdAt)+'</p></div>'+statusBadge('PENDING')+'</div>'+
                        '<div class="grid grid-cols-3 gap-2 text-xs mb-3">'+
                        '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">المبلغ</p><p class="font-bold text-danger">'+fmtNum(w.amount)+'</p></div>'+
                        '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">الرسوم</p><p class="font-bold">'+fmtNum(w.fee||0)+'</p></div>'+
                        '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">الصافي</p><p class="font-bold text-danger">'+fmtNum(w.net||0)+'</p></div></div>'+
                        (methodInfo?'<p class="text-xs '+C.muted+' mb-3">طريقة السحب: <span class="'+C.text+'">'+methodInfo+'</span></p>':'')+
                        '<div class="flex gap-2"><button onclick="merchantApproveWithdrawal(\''+w.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-success text-dark-bg text-sm">✅ تأكيد التنفيذ</button><button onclick="merchantRejectWithdrawal(\''+w.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div></div>';
                });
                html += '</div>';
            }
            html += '</div>';
            return html;
        }

        function merchantApproveWithdrawal(wdId) {
            var user = getUser();
            captureForFieldWithCallback('wdConfirmScreenshot', function(screenshot) {
                showConfirm('✅','تأكيد التنفيذ','هل تم تحويل المبلغ بنجاح؟','نعم، تأكيد','bg-success text-dark-bg',function(yes){
                    if(!yes) return;
                    var withdrawals = DB.get('withdrawals');
                    var w = withdrawals.find(function(x){return x.id===wdId;});
                    if(!w) return;
                    w.status = 'APPROVED';
                    w.confirmScreenshot = screenshot;
                    w.processedBy = user.id;
                    var users = DB.get('users');
                    var u = users.find(function(x){return x.id===w.userId;});
                    if(u) { u.usdtBalance = Math.max(0, (u.usdtBalance||0) - (w.amount||0)); DB.set('users', users); }
                    DB.set('withdrawals', withdrawals);
                    var mTxns = DB.get('merchantTransactions');
                    mTxns.unshift({id:DB.uid(),merchantId:user.id,userId:w.userId,type:'WITHDRAW',amount:w.net,status:'APPROVED',screenshot:screenshot,createdAt:new Date().toISOString()});
                    DB.set('merchantTransactions', mTxns);
                    addLog(w.userId,'WITHDRAW_APPROVED',w.net,'USDT','تم قبول سحب '+fmtNum(w.net)+' USDT');
                    addNotif(w.userId,'سحب مقبول','تم قبول سحبك بمبلغ '+fmtNum(w.net)+' USDT','WITHDRAW');
                    toast('تم تأكيد السحب','success');
                    render();
                });
            });
        }

        function merchantRejectWithdrawal(wdId) {
            var user = getUser();
            showConfirm('❌','رفض السحب','سيتم استرداد الرصيد للمستخدم. متابعة؟','نعم، رفض','bg-danger text-white',function(yes){
                if(!yes) return;
                var withdrawals = DB.get('withdrawals');
                var w = withdrawals.find(function(x){return x.id===wdId;});
                if(!w) return;
                w.status = 'REJECTED';
                w.processedBy = user.id;
                var users = DB.get('users');
                var u = users.find(function(x){return x.id===w.userId;});
                if(u) { u.usdtBalance = (u.usdtBalance||0) + (w.amount||0); DB.set('users', users); }
                DB.set('withdrawals', withdrawals);
                addLog(w.userId,'WITHDRAW_REJECTED',w.amount,'USDT','تم رفض السحب واسترداد '+fmtNum(w.amount)+' USDT');
                addNotif(w.userId,'سحب مرفوض','تم رفض سحبك. تم استرداد المبلغ إلى رصيدك.','WITHDRAW');
                toast('تم رفض السحب واسترداد الرصيد','success');
                render();
            });
        }

        // ==================== MERCHANT: TRANSACTIONS ====================
        function renderMerchantTransactions(C) {
            var user = getUser();
            var txns = DB.get('merchantTransactions').filter(function(t){return t.merchantId===user.id;});
            txns.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">📊 معاملاتي ('+txns.length+')</h2>';
            if(txns.length===0) html += '<p class="'+C.muted+' text-center py-8">لا توجد معاملات</p>';
            else {
                html += '<div class="space-y-3 max-h-[70vh] overflow-y-auto">';
                var users = DB.get('users');
                txns.forEach(function(t) {
                    var u = users.find(function(x){return x.id===t.userId;});
                    var isDep = t.type === 'DEPOSIT';
                    html += '<div class="flex items-center justify-between p-3 rounded-lg border '+C.border+'">'+
                        '<div><p class="text-sm font-medium '+C.text+'">'+(isDep?'💰':'🏧')+' '+(isDep?'إيداع':'سحب')+' - '+escHtml(u?u.name:'مستخدم')+'</p><p class="text-xs '+C.muted+'">'+fmtDate(t.createdAt)+'</p></div>'+
                        '<div class="text-left"><p class="font-bold text-sm '+(isDep?'text-success':'text-danger')+'">'+fmtNum(t.amount)+' USDT</p>'+statusBadge(t.status)+'</div></div>';
                });
                html += '</div>';
            }
            html += '</div>';
            return html;
        }

        // ==================== MERCHANT: PAYMENT SETTINGS ====================
        function renderMerchantSettings(C) {
            var user = getUser();
            var allData = DB.get('merchantPaymentData');
            var myData = allData[user.id] || {};
            var usdtAddr = myData.usdtAddress || '';
            var usdtNetwork = myData.usdtNetwork || 'TRC20';
            var bankName = myData.bankName || '';
            var bankAccount = myData.bankAccount || '';
            var bankRecipient = myData.bankRecipient || '';
            return '<div class="'+C.card+' rounded-xl p-6 max-w-lg mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-2 text-center">⚙️ بيانات الإيداع والتحويل</h2>'+
                '<p class="text-xs '+C.muted+' text-center mb-6">هذه البيانات ستظهر للمستخدمين عند اختيارك كتاجر للإيداع أو السحب</p>'+
                '<div class="space-y-4">'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'">'+
                '<h3 class="font-bold '+C.text+' mb-3">💳 محفظة USDT</h3>'+
                '<div class="space-y-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">الشبكة</label>'+
                '<select id="mp-network" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none">'+
                '<option value="TRC20" '+(usdtNetwork==='TRC20'?'selected':'')+'>TRC20 (Tron)</option>'+
                '<option value="ERC20" '+(usdtNetwork==='ERC20'?'selected':'')+'>ERC20 (Ethereum)</option>'+
                '<option value="BEP20" '+(usdtNetwork==='BEP20'?'selected':'')+'>BEP20 (BSC)</option>'+
                '</select></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">عنوان المحفظة</label>'+
                '<input type="text" id="mp-usdt-addr" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none font-mono text-sm" value="'+escHtml(usdtAddr)+'" placeholder="TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"></div>'+
                '</div></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'">'+
                '<h3 class="font-bold '+C.text+' mb-3">🏦 حساب بنكي</h3>'+
                '<div class="space-y-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">اسم البنك</label>'+
                '<input type="text" id="mp-bank-name" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" value="'+escHtml(bankName)+'" placeholder="مثال: بنك اليمن والكويت"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">رقم الحساب</label>'+
                '<input type="text" id="mp-bank-account" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none font-mono" value="'+escHtml(bankAccount)+'" placeholder="رقم الحساب البنكي"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">اسم صاحب الحساب</label>'+
                '<input type="text" id="mp-bank-recipient" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" value="'+escHtml(bankRecipient)+'" placeholder="الاسم كما يظهر في البنك"></div>'+
                '</div></div>'+
                '<button onclick="saveMerchantPaymentData()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn text-lg">💾 حفظ البيانات</button></div></div>';
        }

        function saveMerchantPaymentData() {
            var user = getUser();
            var usdtAddress = document.getElementById('mp-usdt-addr').value.trim();
            var usdtNetwork = document.getElementById('mp-network').value;
            var bankName = document.getElementById('mp-bank-name').value.trim();
            var bankAccount = document.getElementById('mp-bank-account').value.trim();
            var bankRecipient = document.getElementById('mp-bank-recipient').value.trim();
            if(!usdtAddress && !bankAccount) { toast('أدخل بيانات المحفظة أو الحساب البنكي على الأقل','error'); return; }
            var allData = DB.get('merchantPaymentData');
            if(!allData || typeof allData !== 'object') allData = {};
            allData[user.id] = {
                usdtAddress: usdtAddress,
                usdtNetwork: usdtNetwork,
                bankName: bankName,
                bankAccount: bankAccount,
                bankRecipient: bankRecipient,
                updatedAt: new Date().toISOString()
            };
            DB.set('merchantPaymentData', allData);
            toast('تم حفظ بيانات الإيداع بنجاح','success');
            addLog(user.id,'MERCHANT_DATA_UPDATE',0,'','تم تحديث بيانات الإيداع للتاجر');
        }

        function getMerchantPaymentData(merchantId) {
            var allData = DB.get('merchantPaymentData');
            if(!allData || typeof allData !== 'object') return null;
            return allData[merchantId] || null;
        }

        // ==================== MERCHANT: DEPOSIT/WITHDRAW (own) ====================
        function renderMerchantDeposit(C) { return renderUserDeposit(C); }
        function renderMerchantWithdraw(C) { return renderUserWithdraw(C); }
        function renderMerchantChat(C) { return renderUserChat(C); }
        // ==================== ADMIN: HOME ====================
        function renderAdminHome(C) {
            var users = DB.get('users').filter(function(u){return u.role!=='ADMIN';});
            var deposits = DB.get('deposits');
            var withdrawals = DB.get('withdrawals');
            var pendingKyc = DB.get('kycDocuments').filter(function(k){return k.status==='PENDING';}).length;
            var pendingMerchants = DB.get('merchantRequests').filter(function(r){return r.status==='PENDING';}).length;
            var unreadMsgs = DB.get('messages').filter(function(m){return m.toId==='admin1' && !m.isRead;}).length;
            var totalUsers = users.length;
            var totalDep = deposits.reduce(function(s,d){return s+(d.usdtAmount||0);},0);
            var totalWd = withdrawals.reduce(function(s,w){return s+(w.net||0);},0);
            var pendingDep = deposits.filter(function(d){return d.status==='PENDING';}).length;
            var pendingWd = withdrawals.filter(function(w){return w.status==='PENDING';}).length;
            return '<div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="text-3xl mb-1">👥</p><p class="text-2xl font-bold text-primary">'+totalUsers+'</p><p class="'+C.muted+' text-sm">المستخدمين</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="text-3xl mb-1">💰</p><p class="text-2xl font-bold text-success">'+fmtNum(totalDep)+'</p><p class="'+C.muted+' text-sm">إجمالي الإيداعات</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center"><p class="text-3xl mb-1">🏧</p><p class="text-2xl font-bold text-danger">'+fmtNum(totalWd)+'</p><p class="'+C.muted+' text-sm">إجمالي السحوبات</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center cursor-pointer btn hover:border-warning" onclick="setView(\'admin-deposits\')"><p class="text-3xl mb-1">⏳</p><p class="text-2xl font-bold text-warning">'+pendingDep+'</p><p class="'+C.muted+' text-sm">إيداعات معلقة</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center cursor-pointer btn hover:border-warning" onclick="setView(\'admin-withdrawals\')"><p class="text-3xl mb-1">⏳</p><p class="text-2xl font-bold text-warning">'+pendingWd+'</p><p class="'+C.muted+' text-sm">سحوبات معلقة</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center cursor-pointer btn hover:border-warning" onclick="setView(\'admin-kyc\')"><p class="text-3xl mb-1">🪪</p><p class="text-2xl font-bold text-warning">'+pendingKyc+'</p><p class="'+C.muted+' text-sm">توثيق معلق</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center cursor-pointer btn hover:border-warning" onclick="setView(\'admin-merchants\')"><p class="text-3xl mb-1">🏪</p><p class="text-2xl font-bold text-warning">'+pendingMerchants+'</p><p class="'+C.muted+' text-sm">طلبات تجار</p></div>'+
                '<div class="'+C.card+' rounded-xl p-4 border '+C.border+' text-center cursor-pointer btn hover:border-primary" onclick="setView(\'admin-chat\')"><p class="text-3xl mb-1">💬</p><p class="text-2xl font-bold text-primary">'+unreadMsgs+'</p><p class="'+C.muted+' text-sm">رسائل غير مقروءة</p></div></div>';
        }

        // ==================== ADMIN: USERS ====================
        function renderAdminUsers(C) {
            var users = DB.get('users').filter(function(u){return u.role !== 'MERCHANT';});
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">👥 المستخدمين ('+users.length+')</h2>'+
                '<input type="text" id="admin-user-search" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none mb-4" placeholder="بحث بالاسم أو البريد أو الهاتف..." oninput="filterAdminUsers()">'+
                '<div id="admin-users-list" class="space-y-3 max-h-[70vh] overflow-y-auto">'+renderAdminUsersList(users, C)+'</div></div>';
        }

        function renderAdminUsersList(users, C) {
            if(!C) C = getThemeColors();
            var searchVal = '';
            var searchEl = document.getElementById('admin-user-search');
            if(searchEl) searchVal = searchEl.value.trim().toLowerCase();
            var filtered = users.filter(function(u){
                if(!searchVal) return true;
                return (u.name||'').toLowerCase().indexOf(searchVal)>=0 || (u.email||'').toLowerCase().indexOf(searchVal)>=0 || (u.phone||'').indexOf(searchVal)>=0;
            });
            if(filtered.length===0) return '<p class="'+C.muted+' text-center py-4">لا يوجد مستخدمين</p>';
            return filtered.map(function(u) {
                return '<div class="p-4 rounded-lg border '+C.border+' hover:border-primary/50 overflow-hidden">'+
                    '<div class="mb-2">'+
                    '<div class="flex items-center gap-3 mb-2"><div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-sm shrink-0">'+(u.merchantStatus==='APPROVED'?'🏪':'👤')+'</div>'+
                    '<div class="min-w-0"><p class="font-medium text-sm '+C.text+' truncate">'+escHtml(u.name)+'</p><p class="text-xs '+C.muted+' truncate">'+escHtml(u.email)+' | '+escHtml(u.phone)+'</p></div></div>'+
                    '<div class="flex flex-wrap gap-1 mb-2">'+statusBadge(u.isBlocked?'BLOCKED':'ACTIVE')+statusBadge(u.kycStatus||'NOT_SUBMITTED')+(u.merchantStatus==='APPROVED'?statusBadge('APPROVED'):statusBadge(u.merchantStatus||'NONE'))+'</div></div>'+
                    '<div class="grid grid-cols-3 gap-2 text-center text-xs mb-3">'+
                    '<div class="p-2 rounded"><p class="'+C.muted+' text-[10px]">USDT</p><p class="font-bold text-success text-xs">'+fmtNum(u.usdtBalance||0)+'</p></div>'+
                    '<div class="p-2 rounded"><p class="'+C.muted+' text-[10px]">محلي</p><p class="font-bold text-primary text-xs">'+fmtNum(u.localBalance||0)+'</p></div>'+
                    '<div class="p-2 rounded"><p class="'+C.muted+' text-[10px]">عمولات</p><p class="font-bold text-info text-xs">'+fmtNum(u.affiliateBalance||0)+'</p></div></div>'+
                    '<div class="flex flex-wrap gap-2">'+
                    '<button onclick="showEditUserModal(\''+u.id+'\')" class="flex-1 min-w-0 px-2 py-2 rounded-lg border '+C.border+' '+C.text+' btn text-xs truncate">✏️ تعديل</button>'+
                    '<button onclick="adjustUserBalance(\''+u.id+'\')" class="flex-1 min-w-0 px-2 py-2 rounded-lg border '+C.border+' '+C.text+' btn text-xs truncate">💰 رصيد</button>'+
                    '<button onclick="toggleBlockUser(\''+u.id+'\')" class="px-3 py-2 rounded-lg btn text-xs shrink-0 '+(u.isBlocked?'bg-success text-dark-bg':'bg-danger text-white')+'">'+(u.isBlocked?'🔓':'🔒')+'</button>'+
                    '<button onclick="deleteUser(\''+u.id+'\')" class="px-3 py-2 rounded-lg btn text-xs bg-danger text-white shrink-0">🗑️</button></div></div>';
            }).join('');
        }

        function filterAdminUsers() { render(); }

        function showEditUserModal(userId) {
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===userId;});
            if(!u) return;
            var C = getThemeColors();
            showModal('<h3 class="text-lg font-bold '+C.text+' mb-4">✏️ تعديل المستخدم</h3>'+
                '<div class="space-y-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">الاسم</label><input type="text" id="edit-user-name" value="'+escHtml(u.name)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">البريد</label><input type="email" id="edit-user-email" value="'+escHtml(u.email)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">الهاتف</label><input type="text" id="edit-user-phone" value="'+escHtml(u.phone)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>'+
                '<button onclick="saveEditUser(\''+userId+'\')" class="'+C.btn+' w-full py-2.5 rounded-lg font-bold btn">حفظ</button>'+
                '<button onclick="closeModal()" class="w-full py-2.5 rounded-lg border '+C.border+' '+C.text+' btn">إلغاء</button></div>');
        }

        function saveEditUser(userId) {
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===userId;});
            if(!u) return;
            u.name = document.getElementById('edit-user-name').value.trim();
            u.email = document.getElementById('edit-user-email').value.trim();
            u.phone = document.getElementById('edit-user-phone').value.trim();
            DB.set('users', users);
            closeModal();
            toast('تم تحديث بيانات المستخدم','success');
            render();
        }

        function adjustUserBalance(userId) {
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===userId;});
            if(!u) return;
            var C = getThemeColors();
            showModal('<h3 class="text-lg font-bold '+C.text+' mb-4">💰 تعديل رصيد '+escHtml(u.name)+'</h3>'+
                '<p class="'+C.muted+' text-sm mb-3">رصيد USDT الحالي: <span class="text-success font-bold">'+fmtNum(u.usdtBalance||0)+'</span></p>'+
                '<div class="space-y-3">'+
                '<select id="adj-type" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"><option value="add">إضافة</option><option value="subtract">خصم</option><option value="set">تحديد</option></select>'+
                '<input type="number" id="adj-amount" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="المبلغ" min="0" step="0.01">'+
                '<input type="text" id="adj-reason" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="السبب">'+
                '<button onclick="saveAdjBalance(\''+userId+'\')" class="'+C.btn+' w-full py-2.5 rounded-lg font-bold btn">تنفيذ</button>'+
                '<button onclick="closeModal()" class="w-full py-2.5 rounded-lg border '+C.border+' '+C.text+' btn">إلغاء</button></div>');
        }

        function saveAdjBalance(userId) {
            var type = document.getElementById('adj-type').value;
            var amount = parseFloat(document.getElementById('adj-amount').value);
            var reason = document.getElementById('adj-reason').value.trim();
            if(!amount || amount < 0) { toast('أدخل مبلغاً صحيحاً','error'); return; }
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===userId;});
            if(!u) return;
            var oldBal = u.usdtBalance || 0;
            if(type==='add') u.usdtBalance = oldBal + amount;
            else if(type==='subtract') u.usdtBalance = Math.max(0, oldBal - amount);
            else u.usdtBalance = amount;
            DB.set('users', users);
            addLog(userId,'ADMIN_ADJUST',u.usdtBalance - oldBal,'USDT','تعديل رصيد من الإدارة: '+reason);
            closeModal();
            toast('تم تعديل الرصيد','success');
            render();
        }

        function toggleBlockUser(userId) {
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===userId;});
            if(!u) return;
            u.isBlocked = !u.isBlocked;
            DB.set('users', users);
            toast(u.isBlocked ? 'تم حظر المستخدم' : 'تم فك حظر المستخدم','success');
            render();
        }

        function deleteUser(userId) {
            showConfirm('🗑️','حذف المستخدم','هل أنت متأكد من حذف هذا المستخدم؟ هذا الإجراء لا يمكن التراجع عنه.','حذف','bg-danger text-white',function(yes){
                if(!yes) return;
                var users = DB.get('users').filter(function(u){return u.id!==userId;});
                DB.set('users', users);
                toast('تم حذف المستخدم','success');
                render();
            });
        }
        // ==================== ADMIN: DEPOSITS ====================
        function renderAdminDeposits(C) {
            var deposits = DB.get('deposits');
            deposits.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            var pendingCount = deposits.filter(function(d){return d.status==='PENDING';}).length;
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">💰 الإيداعات ('+deposits.length+')</h2>'+
                '<div class="flex gap-2 mb-4 flex-wrap">'+
                '<button onclick="filterAdminDeposits(\'ALL\')" class="px-3 py-1.5 rounded-lg text-sm btn '+C.btn+'">الكل</button>'+
                '<button onclick="filterAdminDeposits(\'PENDING\')" class="px-3 py-1.5 rounded-lg text-sm btn bg-warning text-dark-bg">معلق ('+pendingCount+')</button>'+
                '<button onclick="filterAdminDeposits(\'APPROVED\')" class="px-3 py-1.5 rounded-lg text-sm btn bg-success text-dark-bg">مقبول</button>'+
                '<button onclick="filterAdminDeposits(\'REJECTED\')" class="px-3 py-1.5 rounded-lg text-sm btn bg-danger text-white">مرفوض</button></div>'+
                '<div id="admin-deposits-list" class="space-y-3 max-h-[70vh] overflow-y-auto">'+renderAdminDepositsList(deposits, C)+'</div></div>';
        }

        function renderAdminDepositsList(deposits, C, filterStatus) {
            if(!C) C = getThemeColors();
            var filtered = deposits;
            if(filterStatus && filterStatus !== 'ALL') filtered = deposits.filter(function(d){return d.status===filterStatus;});
            if(filtered.length===0) return '<p class="'+C.muted+' text-center py-4">لا توجد إيداعات</p>';
            var users = DB.get('users');
            var pms = DB.get('paymentMethods');
            return filtered.map(function(d) {
                var u = users.find(function(x){return x.id===d.userId;});
                var pm = pms.find(function(x){return x.id===d.paymentMethodId;});
                var processorName = d.processedBy ? (users.find(function(x){return x.id===d.processedBy;})||{}).name||'تاجر' : '';
                var assignedMerchantName = '';
                if(d.assignedMerchantId) {
                    var assignedM = users.find(function(m){return m.id===d.assignedMerchantId;});
                    if(assignedM) assignedMerchantName = escHtml(assignedM.name);
                }
                return '<div class="p-4 rounded-lg border '+C.border+'">'+
                    '<div class="flex items-center justify-between mb-2">'+
                    '<div><p class="font-medium text-sm '+C.text+'">'+escHtml(u?u.name:'مستخدم محذوف')+'</p><p class="text-xs '+C.muted+'">'+fmtDate(d.createdAt)+'</p></div>'+
                    '<div class="text-left">'+statusBadge(d.status)+(d.processedBy?'<span class="text-xs '+C.muted+' mr-2"> بواسطة: '+escHtml((users.find(function(x){return x.id===d.processedBy;})||{}).name||'تاجر')+'</span>':'')+'</div></div>'+
                    '<div class="grid grid-cols-2 gap-2 text-xs mb-3">'+
                    '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">المبلغ</p><p class="font-bold">'+fmtNum(d.amount)+' '+(d.currency||'')+'</p></div>'+
                    '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">USDT</p><p class="font-bold text-success">'+fmtNum(d.usdtAmount||0)+'</p></div>'+
                    '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">الطريقة</p><p class="font-bold">'+escHtml(pm?pm.title:'—')+'</p></div>'+
                    '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">TXID</p><p class="font-mono">'+escHtml(d.txid||'—')+'</p></div></div>'+
                    (assignedMerchantName?'<p class="text-xs '+C.muted+' mb-2">🏪 التاجر المعين: <span class="text-primary font-medium">'+assignedMerchantName+'</span></p>':'')+
                    (d.receipt?'<div class="mb-3"><p class="text-xs '+C.muted+' mb-1">📄 صورة الإيصال (من المستخدم):</p><img src="'+d.receipt+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+d.id+'\',\'deposit\')"></div>':'')+
                    (d.approveProof?'<div class="mb-3"><p class="text-xs '+C.muted+' mb-1">✅ إثبات التنفيذ (من '+escHtml(processorName||'الإدارة')+'):</p><img src="'+d.approveProof+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showImageModal(this.src)"></div>':'')+
                    (d.notes?'<p class="text-xs '+C.muted+' mb-2">ملاحظات: '+escHtml(d.notes)+'</p>':'')+
                    (d.status==='PENDING'?'<div class="flex gap-2"><button onclick="approveDeposit(\''+d.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-success text-dark-bg text-sm">✅ قبول</button><button onclick="rejectDeposit(\''+d.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div>':'')+
                    '</div>';
            }).join('');
        }

        function filterAdminDeposits(status) {
            var deposits = DB.get('deposits');
            deposits.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            var C = getThemeColors();
            document.getElementById('admin-deposits-list').innerHTML = renderAdminDepositsList(deposits, C, status);
        }

        function approveDeposit(depId) {
            captureForFieldWithCallback('adminDepProof', function(proofImg) {
                showConfirm('✅','قبول الإيداع','هل تريد قبول هذا الإيداع وإضافة الرصيد؟ سيتم حفظ إثبات التنفيذ.','نعم، قبول','bg-success text-dark-bg',function(yes){
                    if(!yes) return;
                    var deposits = DB.get('deposits');
                    var d = deposits.find(function(x){return x.id===depId;});
                    if(!d) return;
                    d.status = 'APPROVED';
                    d.approveProof = proofImg;
                    var adminUser = getUser();
                    d.processedBy = adminUser ? adminUser.id : null;
                    var users = DB.get('users');
                    var u = users.find(function(x){return x.id===d.userId;});
                    if(u) {
                        u.usdtBalance = (u.usdtBalance||0) + (d.usdtAmount||0);
                        DB.set('users', users);
                        calculateAffiliateCommission(d.userId, d.usdtAmount || 0);
                    }
                    DB.set('deposits', deposits);
                    addLog(d.userId,'DEPOSIT_APPROVED',d.usdtAmount,'USDT','تم قبول إيداع '+fmtNum(d.usdtAmount)+' USDT');
                    addNotif(d.userId,'إيداع مقبول','تم قبول إيداعك بمبلغ '+fmtNum(d.usdtAmount)+' USDT','DEPOSIT');
                    toast('تم قبول الإيداع','success');
                    render();
                });
            });
        }

        function rejectDeposit(depId) {
            showConfirm('❌','رفض الإيداع','هل تريد رفض هذا الإيداع؟','نعم، رفض','bg-danger text-white',function(yes){
                if(!yes) return;
                var deposits = DB.get('deposits');
                var d = deposits.find(function(x){return x.id===depId;});
                if(!d) return;
                d.status = 'REJECTED';
                DB.set('deposits', deposits);
                addLog(d.userId,'DEPOSIT_REJECTED',d.usdtAmount,'USDT','تم رفض إيداع '+fmtNum(d.usdtAmount)+' USDT');
                addNotif(d.userId,'إيداع مرفوض','تم رفض إيداعك بمبلغ '+fmtNum(d.usdtAmount)+' USDT','DEPOSIT');
                toast('تم رفض الإيداع','success');
                render();
            });
        }

        function calculateAffiliateCommission(userId, amount) {
            var users = DB.get('users');
            var user = users.find(function(u){return u.id === userId;});
            if(!user || !user.referredBy) return;
            var referrer = users.find(function(u){return u.id === user.referredBy;});
            if(!referrer || referrer.affiliateStatus !== 'APPROVED') return;
            var l1Pct = parseFloat(DB.getSetting('aff_l1')) || 5;
            var commission = amount * l1Pct / 100;
            referrer.affiliateBalance = (referrer.affiliateBalance || 0) + commission;
            DB.set('users', users);
            addLog(referrer.id, 'AFFILIATE_EARNING', commission, 'USDT', 'عمولة إحالة من ' + (user.name || 'مستخدم'));
            addNotif(referrer.id, 'عمولة جديدة', 'حصلت على ' + fmtNum(commission) + ' USDT عمولة إحالة', 'AFFILIATE');
        }
        // ==================== ADMIN: WITHDRAWALS ====================
        function renderAdminWithdrawals(C) {
            var withdrawals = DB.get('withdrawals');
            withdrawals.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            var pendingCount = withdrawals.filter(function(w){return w.status==='PENDING';}).length;
            var processingCount = withdrawals.filter(function(w){return w.status==='PROCESSING';}).length;
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">🏧 السحوبات ('+withdrawals.length+')</h2>'+
                '<div class="flex gap-2 mb-4 flex-wrap">'+
                '<button onclick="filterAdminWithdrawals(\'ALL\')" class="px-3 py-1.5 rounded-lg text-sm btn '+C.btn+'">الكل</button>'+
                '<button onclick="filterAdminWithdrawals(\'PENDING\')" class="px-3 py-1.5 rounded-lg text-sm btn bg-warning text-dark-bg">معلق ('+pendingCount+')</button>'+
                '<button onclick="filterAdminWithdrawals(\'PROCESSING\')" class="px-3 py-1.5 rounded-lg text-sm btn bg-info text-white">قيد المعالجة ('+processingCount+')</button>'+
                '<button onclick="filterAdminWithdrawals(\'APPROVED\')" class="px-3 py-1.5 rounded-lg text-sm btn bg-success text-dark-bg">مقبول</button>'+
                '<button onclick="filterAdminWithdrawals(\'REJECTED\')" class="px-3 py-1.5 rounded-lg text-sm btn bg-danger text-white">مرفوض</button></div>'+
                '<div id="admin-withdrawals-list" class="space-y-3 max-h-[70vh] overflow-y-auto">'+renderAdminWithdrawalsList(withdrawals, C)+'</div></div>';
        }

        function renderAdminWithdrawalsList(withdrawals, C, filterStatus) {
            if(!C) C = getThemeColors();
            var filtered = withdrawals;
            if(filterStatus && filterStatus !== 'ALL') filtered = withdrawals.filter(function(w){return w.status===filterStatus;});
            if(filtered.length===0) return '<p class="'+C.muted+' text-center py-4">لا توجد سحوبات</p>';
            var users = DB.get('users');
            var wms = DB.get('userWithdrawalMethods');
            return filtered.map(function(w) {
                var u = users.find(function(x){return x.id===w.userId;});
                var method = wms.find(function(x){return x.id===w.withdrawalMethodId;});
                var methodInfo = '';
                var copyableFields = '';
                if(method) {
                    var bnkAddr = escHtml(method.accountNumber||'');
                    var bnkRcp = escHtml(method.recipientName||'');
                    var cryptoAddr = escHtml(method.address||'');
                    if(method.type==='BANK') {
                        methodInfo = escHtml(method.bankName||'');
                        copyableFields = '<div class="'+C.card+' rounded-lg p-3 mb-3 space-y-2 border '+C.border+'">'+
                            '<p class="text-xs font-bold '+C.text+'">🏦 تفاصيل التحويل البنكي:</p>'+
                            '<div class="flex items-center justify-between py-1"><span class="text-xs '+C.muted+'">البنك:</span><span class="text-xs font-medium '+C.text+'">'+escHtml(method.bankName||'—')+'</span></div>'+
                            '<div class="flex items-center justify-between py-1"><span class="text-xs '+C.muted+'">رقم الحساب:</span><div class="flex items-center gap-1"><span class="text-xs font-mono font-bold '+C.text+'">'+bnkAddr+'</span><button onclick="copyText(\''+bnkAddr.replace(/'/g,"\\'")+'\')" class="copy-btn">📋</button></div></div>'+
                            '<div class="flex items-center justify-between py-1"><span class="text-xs '+C.muted+'">اسم المستفيد:</span><div class="flex items-center gap-1"><span class="text-xs font-medium '+C.text+'">'+bnkRcp+'</span><button onclick="copyText(\''+bnkRcp.replace(/'/g,"\\'")+'\')" class="copy-btn">📋</button></div></div>'+
                            (method.subtype?'<div class="flex items-center justify-between py-1"><span class="text-xs '+C.muted+'">نوع الحساب:</span><span class="text-xs font-medium '+C.text+'">'+escHtml(method.subtype)+'</span></div>':'')+
                            '</div>';
                    } else {
                        methodInfo = escHtml(method.network||'');
                        copyableFields = '<div class="'+C.card+' rounded-lg p-3 mb-3 space-y-2 border '+C.border+'">'+
                            '<p class="text-xs font-bold '+C.text+'">💳 تفاصيل المحفظة الرقمية:</p>'+
                            '<div class="flex items-center justify-between py-1"><span class="text-xs '+C.muted+'">الشبكة:</span><span class="text-xs font-medium '+C.text+'">'+escHtml(method.network||'—')+'</span></div>'+
                            '<div class="py-1"><div class="flex items-center justify-between mb-1"><span class="text-xs '+C.muted+'">العنوان:</span><button onclick="copyText(\''+cryptoAddr.replace(/'/g,"\\'")+'\')" class="copy-btn">📋 نسخ</button></div><p class="font-mono text-xs '+C.text+' break-all rounded p-2 border '+C.border+'">'+cryptoAddr+'</p></div>'+
                            (method.currencyName?'<div class="flex items-center justify-between py-1"><span class="text-xs '+C.muted+'">العملة:</span><span class="text-xs font-medium text-primary">'+escHtml(method.currencyName)+'</span></div>':'')+
                            '</div>';
                    }
                }
                var processedBy = '';
                if(w.processedBy) {
                    var processor = users.find(function(x){return x.id===w.processedBy;});
                    if(processor) processedBy = '<span class="text-xs '+C.muted+'"> بواسطة: '+escHtml(processor.name)+'</span>';
                }
                var assignedMerchantName = '';
                if(w.assignedMerchantId) {
                    var assignedM = users.find(function(m){return m.id===w.assignedMerchantId;});
                    if(assignedM) assignedMerchantName = escHtml(assignedM.name);
                }
                return '<div class="p-4 rounded-lg border '+C.border+'">'+
                    '<div class="flex items-center justify-between mb-2">'+
                    '<div><p class="font-medium text-sm '+C.text+'">'+escHtml(u?u.name:'مستخدم محذوف')+'</p><p class="text-xs '+C.muted+'">'+fmtDate(w.createdAt)+'</p></div>'+
                    '<div class="text-left">'+statusBadge(w.status)+processedBy+'</div></div>'+
                    '<div class="grid grid-cols-3 gap-2 text-xs mb-3">'+
                    '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">المبلغ</p><p class="font-bold text-danger">'+fmtNum(w.amount)+'</p></div>'+
                    '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">الرسوم</p><p class="font-bold">'+fmtNum(w.fee||0)+'</p></div>'+
                    '<div class="'+C.card+' rounded p-2"><p class="'+C.muted+'">الصافي</p><p class="font-bold text-danger">'+fmtNum(w.net||0)+'</p></div></div>'+
                    (copyableFields ? copyableFields : (methodInfo?'<p class="text-xs '+C.muted+' mb-2">طريقة السحب: <span class="'+C.text+'">'+methodInfo+'</span></p>':''))+
                    (assignedMerchantName?'<p class="text-xs '+C.muted+' mb-2">🏪 التاجر المعين: <span class="text-primary font-medium">'+assignedMerchantName+'</span></p>':'')+
                    (w.notes?'<p class="text-xs '+C.muted+' mb-2">ملاحظات: '+escHtml(w.notes)+'</p>':'')+
                    (w.confirmScreenshot?'<div class="mb-3"><p class="text-xs '+C.muted+' mb-1">لقطة تأكيد التنفيذ:</p><img src="'+w.confirmScreenshot+'" class="h-24 rounded-lg border cursor-pointer object-cover" onclick="showImageModal(this.src)"></div>':'')+
                    (w.status==='PENDING'?'<div class="flex gap-2"><button onclick="adminStartProcessing(\''+w.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-info text-white text-sm">⚙️ معالجة</button><button onclick="adminRejectWithdrawal(\''+w.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div>':'')+
                    (w.status==='PROCESSING'?'<div class="flex gap-2"><button onclick="adminApproveWithdrawal(\''+w.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-success text-dark-bg text-sm">✅ موافقة وخصم</button><button onclick="adminRejectWithdrawal(\''+w.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div>':'')+
                    '</div>';
            }).join('');
        }

        function filterAdminWithdrawals(status) {
            var withdrawals = DB.get('withdrawals');
            withdrawals.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            var C = getThemeColors();
            document.getElementById('admin-withdrawals-list').innerHTML = renderAdminWithdrawalsList(withdrawals, C, status);
        }

        function adminStartProcessing(wdId) {
            var withdrawals = DB.get('withdrawals');
            var w = withdrawals.find(function(x){return x.id===wdId;});
            if(!w) return;
            var wdUserName = 'مستخدم';
            var allUsers = DB.get('users');
            var wdUser = allUsers.find(function(x){return x.id===w.userId;});
            if(wdUser) wdUserName = wdUser.name;
            showConfirm('⚙️','بدء معالجة السحب','هل تريد بدء معالجة سحب '+fmtNum(w.net||0)+' USDT للمستخدم '+escHtml(wdUserName)+'؟','نعم، ابدأ المعالجة','bg-info text-white',function(yes){
                if(!yes) return;
                var withdrawals = DB.get('withdrawals');
                var w = withdrawals.find(function(x){return x.id===wdId;});
                if(!w) return;
                w.status = 'PROCESSING';
                var adminUser = getUser();
                w.processedBy = adminUser ? adminUser.id : null;
                DB.set('withdrawals', withdrawals);
                addNotif(w.userId,'جاري معالجة سحبك','تم بدء معالجة سحبك بمبلغ '+fmtNum(w.net||0)+' USDT. سيتم إشعارك بالنتيجة.','INFO');
                toast('تم بدء معالجة السحب','success');
                render();
            });
        }

        function adminApproveWithdrawal(wdId) {
            var withdrawals = DB.get('withdrawals');
            var w = withdrawals.find(function(x){return x.id===wdId;});
            if(!w) return;
            var wdAmount = w.amount || 0;
            var wdUserName = 'مستخدم';
            var allUsers = DB.get('users');
            var wdUser = allUsers.find(function(x){return x.id===w.userId;});
            if(wdUser) wdUserName = wdUser.name;
            captureForFieldWithCallback('adminWdScreenshot', function(screenshot) {
                showConfirm('✅','تأكيد تنفيذ السحب','هل تم تحويل '+fmtNum(wdAmount)+' USDT بنجاح إلى حساب المستخدم '+escHtml(wdUserName)+'؟ سيتم خصم '+fmtNum(wdAmount)+' USDT من رصيد المستخدم.','نعم، تم التحويل','bg-success text-dark-bg',function(yes){
                    if(!yes) return;
                    var withdrawals = DB.get('withdrawals');
                    var w = withdrawals.find(function(x){return x.id===wdId;});
                    if(!w) return;
                    w.status = 'APPROVED';
                    w.confirmScreenshot = screenshot;
                    var adminUser = getUser();
                    w.processedBy = adminUser ? adminUser.id : w.processedBy;
                    var users = DB.get('users');
                    var u = users.find(function(x){return x.id===w.userId;});
                    if(u) {
                        u.usdtBalance = Math.max(0, (u.usdtBalance||0) - (w.amount||0));
                        DB.set('users', users);
                    }
                    DB.set('withdrawals', withdrawals);
                    addLog(w.userId,'WITHDRAW_APPROVED',w.net,'USDT','تم قبول سحب '+fmtNum(w.net)+' USDT');
                    addNotif(w.userId,'سحب مقبول','تم قبول سحبك بمبلغ '+fmtNum(w.net)+' USDT','WITHDRAW');
                    toast('تم قبول السحب وخصم الرصيد','success');
                    render();
                });
            });
        }

        function adminRejectWithdrawal(wdId) {
            showConfirm('❌','رفض السحب','سيتم استرداد الرصيد للمستخدم. متابعة؟','نعم، رفض','bg-danger text-white',function(yes){
                if(!yes) return;
                var withdrawals = DB.get('withdrawals');
                var w = withdrawals.find(function(x){return x.id===wdId;});
                if(!w) return;
                w.status = 'REJECTED';
                var users = DB.get('users');
                var u = users.find(function(x){return x.id===w.userId;});
                if(u) { u.usdtBalance = (u.usdtBalance||0) + (w.amount||0); DB.set('users', users); }
                DB.set('withdrawals', withdrawals);
                addLog(w.userId,'WITHDRAW_REJECTED',w.amount,'USDT','تم رفض السحب واسترداد '+fmtNum(w.amount)+' USDT');
                addNotif(w.userId,'سحب مرفوض','تم رفض سحبك. تم استرداد المبلغ إلى رصيدك.','WITHDRAW');
                toast('تم رفض السحب واسترداد الرصيد','success');
                render();
            });
        }

        // ==================== DYNAMIC IMAGE MODAL ====================
        function showDynamicImageModal(id, collection) {
            var imgSrc = '';
            if(collection === 'deposit') { var d = DB.get('deposits').find(function(x){return x.id===id;}); if(d) imgSrc = d.receipt; }
            else if(collection === 'kyc-front') { var k = DB.get('kycDocuments').find(function(x){return x.id===id;}); if(k) imgSrc = k.frontId; }
            else if(collection === 'kyc-back') { var k2 = DB.get('kycDocuments').find(function(x){return x.id===id;}); if(k2) imgSrc = k2.backId; }
            else if(collection === 'kyc-selfie') { var k3 = DB.get('kycDocuments').find(function(x){return x.id===id;}); if(k3) imgSrc = k3.selfieWithId; }
            else if(collection === 'merch-front') { var m1 = DB.get('merchantRequests').find(function(x){return x.id===id;}); if(m1) imgSrc = m1.frontId; }
            else if(collection === 'merch-back') { var m2 = DB.get('merchantRequests').find(function(x){return x.id===id;}); if(m2) imgSrc = m2.backId; }
            else if(collection === 'merch-selfie') { var m3 = DB.get('merchantRequests').find(function(x){return x.id===id;}); if(m3) imgSrc = m3.selfieWithId; }
            else if(collection === 'merch-address') { var m4 = DB.get('merchantRequests').find(function(x){return x.id===id;}); if(m4) imgSrc = m4.proofOfAddress; }
            if(imgSrc) showImageModal(imgSrc);
        }
        // ==================== ADMIN: KYC ====================
        function renderAdminKYC(C) {
            var docs = DB.get('kycDocuments');
            var pending = docs.filter(function(k){return k.status==='PENDING';});
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">🪪 توثيق الهوية ('+pending.length+' معلق)</h2>'+
                (pending.length===0 ? '<p class="'+C.muted+' text-center py-8">لا توجد طلبات توثيق معلقة</p>' :
                '<div class="space-y-4 max-h-[70vh] overflow-y-auto">'+pending.map(function(k) {
                    var u = DB.get('users').find(function(x){return x.id===k.userId;});
                    return '<div class="p-4 rounded-lg border '+C.border+'">'+
                        '<div class="flex items-center justify-between mb-3"><div><p class="font-medium text-sm '+C.text+'">'+escHtml(u?u.name:'مستخدم محذوف')+'</p><p class="text-xs '+C.muted+'">'+escHtml(u?u.email:'')+' | '+fmtDate(k.createdAt)+'</p></div>'+statusBadge('PENDING')+'</div>'+
                        '<div class="grid grid-cols-3 gap-3 mb-4">'+
                        '<div><p class="text-xs '+C.muted+' mb-1">الوجه الأمامي</p><img src="'+k.frontId+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+k.id+'\',\'kyc-front\')"></div>'+
                        '<div><p class="text-xs '+C.muted+' mb-1">الوجه الخلفي</p><img src="'+k.backId+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+k.id+'\',\'kyc-back\')"></div>'+
                        '<div><p class="text-xs '+C.muted+' mb-1">سيلفي مع الهوية</p><img src="'+k.selfieWithId+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+k.id+'\',\'kyc-selfie\')"></div></div>'+
                        '<div class="flex gap-2"><button onclick="approveKYC(\''+k.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-success text-dark-bg text-sm">✅ قبول</button><button onclick="rejectKYC(\''+k.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div></div>';
                }).join('')+'</div>')+'</div>';
        }

        function approveKYC(kycId) {
            var docs = DB.get('kycDocuments');
            var k = docs.find(function(x){return x.id===kycId;});
            if(!k) return;
            k.status = 'APPROVED';
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===k.userId;});
            if(u) { u.kycStatus = 'APPROVED'; DB.set('users', users); }
            DB.set('kycDocuments', docs);
            addNotif(k.userId,'توثيق مقبول','تم قبول توثيق هويتك بنجاح','KYC');
            toast('تم قبول التوثيق','success');
            render();
        }

        function rejectKYC(kycId) {
            var C = getThemeColors();
            showModal('<h3 class="text-lg font-bold '+C.text+' mb-4">❌ رفض التوثيق</h3>'+
                '<textarea id="kyc-reject-reason" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none h-24" placeholder="سبب الرفض..."></textarea>'+
                '<button onclick="confirmRejectKYC(\''+kycId+'\')" class="bg-danger text-white w-full py-2.5 rounded-lg font-bold btn mt-3">تأكيد الرفض</button></div>');
        }

        function confirmRejectKYC(kycId) {
            var reason = document.getElementById('kyc-reject-reason').value.trim();
            if(!reason) { toast('أدخل سبب الرفض','error'); return; }
            var docs = DB.get('kycDocuments');
            var k = docs.find(function(x){return x.id===kycId;});
            if(!k) return;
            k.status = 'REJECTED'; k.rejectReason = reason;
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===k.userId;});
            if(u) { u.kycStatus = 'NOT_SUBMITTED'; DB.set('users', users); }
            DB.set('kycDocuments', docs);
            addNotif(k.userId,'توثيق مرفوض','تم رفض توثيق هويتك. السبب: '+reason,'KYC');
            closeModal();
            toast('تم رفض التوثيق','success');
            render();
        }

        // ==================== ADMIN: PAYMENT METHODS ====================
        function renderAdminPaymentMethods(C) {
            var pms = DB.get('paymentMethods');
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<div class="flex items-center justify-between mb-4"><h2 class="text-xl font-bold '+C.text+'">💳 طرق الدفع</h2>'+
                '<button onclick="showAddPmModal()" class="'+C.btn+' px-4 py-2 rounded-lg font-bold btn text-sm">+ إضافة طريقة</button></div>'+
                (pms.length===0 ? '<p class="'+C.muted+' text-center py-4">لا توجد طرق دفع</p>' :
                '<div class="space-y-3">'+pms.map(function(pm) {
                    var typeLabel = pm.type==='CRYPTO'?'عملات رقمية':'تحويل بنكي';
                    return '<div class="p-4 rounded-lg border '+C.border+' '+(pm.isActive?'':'opacity-50')+'">'+
                        '<div class="flex items-center justify-between mb-2">'+
                        '<div><p class="font-medium text-sm '+C.text+'">'+escHtml(pm.title)+'</p><p class="text-xs '+C.muted+'">'+typeLabel+(pm.network?' ('+escHtml(pm.network)+')':'')+'</p></div>'+
                        '<div class="flex items-center gap-2">'+statusBadge(pm.isActive?'ACTIVE':'BLOCKED')+
                        '<button onclick="togglePmActive(\''+pm.id+'\')" class="text-xs px-2 py-1 rounded border '+C.border+' '+C.text+' btn">'+(pm.isActive?'تعطيل':'تفعيل')+'</button></div></div>'+
                        '<div class="flex gap-2"><button onclick="showEditPmModal(\''+pm.id+'\')" class="px-3 py-1.5 rounded-lg border '+C.border+' '+C.text+' btn text-xs">✏️ تعديل</button>'+
                        '<button onclick="deletePm(\''+pm.id+'\')" class="px-3 py-1.5 rounded-lg btn text-xs bg-danger text-white">🗑️ حذف</button></div></div>';
                }).join('')+'</div>')+'</div>';
        }

        function showAddPmModal() {
            var C = getThemeColors();
            showModal('<h3 class="text-lg font-bold '+C.text+' mb-4">إضافة طريقة دفع</h3>'+
                '<div class="space-y-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">النوع</label><select id="pm-add-type" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" onchange="toggleAddPmFields()"><option value="CRYPTO">عملات رقمية</option><option value="BANK">تحويل بنكي</option></select></div>'+
                '<div id="pm-add-crypto-fields"><div class="space-y-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">العملة</label><input type="text" value="USDT" readonly class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none opacity-70"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">الشبكة</label><select id="pm-add-network" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"><option value="TRC20">TRC20</option><option value="BEP20">BEP20</option><option value="ERC20">ERC20</option></select></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">عنوان الشبكة</label><input type="text" id="pm-add-address" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="عنوان المحفظة"></div></div></div>'+
                '<div id="pm-add-bank-fields" class="hidden"><div class="space-y-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">نوع التحويل</label><select id="pm-add-subtype" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" onchange="toggleAddPmSubFields()"><option value="wallet">إيداع لمحفظة</option><option value="transfer">تحويل</option></select></div>'+
                '<div id="pm-add-wallet-fields"><div class="space-y-3">'+
                '<input type="text" id="pm-add-bank-name" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اسم المحفظة">'+
                '<input type="text" id="pm-add-account" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="رقم الحساب">'+
                '<input type="text" id="pm-add-recipient" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اسم صاحب الحساب"></div></div>'+
                '<div id="pm-add-transfer-fields" class="hidden"><div class="space-y-3">'+
                '<input type="text" id="pm-add-beneficiary" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اسم المستفيد">'+
                '<input type="text" id="pm-add-tel" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="رقم الهاتف">'+
                '<input type="text" id="pm-add-net-name" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اسم الشبكة"></div></div></div></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">اسم الطريقة (عنوان)</label><input type="text" id="pm-add-title" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="مثال: USDT TRC20"></div>'+
                '<div class="grid grid-cols-2 gap-3">'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">حد أدنى للإيداع</label><input type="number" id="pm-add-min-dep" value="0" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">حد أدنى للسحب</label><input type="number" id="pm-add-min-wd" value="0" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div></div>'+
                '<button onclick="saveAddPm()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn">حفظ</button>'+
                '<button onclick="closeModal()" class="w-full py-2.5 rounded-lg border '+C.border+' '+C.text+' btn">إلغاء</button></div>');
        }

        function toggleAddPmFields() {
            var type = document.getElementById('pm-add-type').value;
            document.getElementById('pm-add-crypto-fields').classList.toggle('hidden', type !== 'CRYPTO');
            document.getElementById('pm-add-bank-fields').classList.toggle('hidden', type !== 'BANK');
        }
        function toggleAddPmSubFields() {
            var subtype = document.getElementById('pm-add-subtype').value;
            document.getElementById('pm-add-wallet-fields').classList.toggle('hidden', subtype !== 'wallet');
            document.getElementById('pm-add-transfer-fields').classList.toggle('hidden', subtype !== 'transfer');
        }

        function saveAddPm() {
            var type = document.getElementById('pm-add-type').value;
            var title = document.getElementById('pm-add-title').value.trim();
            var minDep = parseFloat(document.getElementById('pm-add-min-dep').value) || 0;
            var minWd = parseFloat(document.getElementById('pm-add-min-wd').value) || 0;
            if(!title) { toast('أدخل اسم الطريقة','error'); return; }
            var pms = DB.get('paymentMethods');
            var pm = { id: DB.uid(), title: title, type: type, subtype: '', network: '', address: '', recipientName: '', accountNumber: '', bankName: '', isActive: true, sortOrder: pms.length, minDeposit: minDep, minWithdraw: minWd };
            if(type === 'CRYPTO') {
                pm.network = document.getElementById('pm-add-network').value;
                pm.address = document.getElementById('pm-add-address').value.trim();
                if(!pm.address) { toast('أدخل عنوان الشبكة','error'); return; }
            } else {
                var subtype = document.getElementById('pm-add-subtype').value;
                pm.subtype = subtype;
                if(subtype === 'wallet') {
                    pm.bankName = document.getElementById('pm-add-bank-name').value.trim();
                    pm.accountNumber = document.getElementById('pm-add-account').value.trim();
                    pm.recipientName = document.getElementById('pm-add-recipient').value.trim();
                    if(!pm.bankName || !pm.accountNumber || !pm.recipientName) { toast('أكمل جميع حقول المحفظة','error'); return; }
                } else {
                    pm.recipientName = document.getElementById('pm-add-beneficiary').value.trim();
                    pm.accountNumber = document.getElementById('pm-add-tel').value.trim();
                    pm.bankName = document.getElementById('pm-add-net-name').value.trim();
                    if(!pm.recipientName || !pm.accountNumber) { toast('أكمل حقول التحويل','error'); return; }
                }
            }
            pms.push(pm);
            DB.set('paymentMethods', pms);
            closeModal();
            toast('تم إضافة طريقة الدفع','success');
            render();
        }

        function showEditPmModal(pmId) {
            var pm = DB.get('paymentMethods').find(function(x){return x.id===pmId;});
            if(!pm) return;
            var C = getThemeColors();
            showModal('<h3 class="text-lg font-bold '+C.text+' mb-4">✏️ تعديل طريقة الدفع</h3>'+
                '<div class="space-y-3">'+
                '<p class="text-sm '+C.muted+'">النوع: '+(pm.type==='CRYPTO'?'عملات رقمية':'تحويل بنكي')+'</p>'+
                '<div><label class="block text-sm font-medium '+C.text+' mb-1">اسم الطريقة</label><input type="text" id="pm-edit-title" value="'+escHtml(pm.title)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>'+
                (pm.type==='CRYPTO'?'<div><label class="block text-sm font-medium '+C.text+' mb-1">عنوان الشبكة</label><input type="text" id="pm-edit-address" value="'+escHtml(pm.address)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>':'')+
                (pm.type==='BANK'?'<div class="space-y-2"><input type="text" id="pm-edit-bank-name" value="'+escHtml(pm.bankName)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="البنك/المحفظة"><input type="text" id="pm-edit-account" value="'+escHtml(pm.accountNumber)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="رقم الحساب"><input type="text" id="pm-edit-recipient" value="'+escHtml(pm.recipientName)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="اسم صاحب الحساب"></div>':'')+
                '<div class="grid grid-cols-2 gap-3"><div><label class="block text-sm font-medium '+C.text+' mb-1">حد أدنى للإيداع</label><input type="number" id="pm-edit-min-dep" value="'+(pm.minDeposit||0)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div><div><label class="block text-sm font-medium '+C.text+' mb-1">حد أدنى للسحب</label><input type="number" id="pm-edit-min-wd" value="'+(pm.minWithdraw||0)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div></div>'+
                '<button onclick="saveEditPm(\''+pmId+'\')" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn">حفظ</button>'+
                '<button onclick="closeModal()" class="w-full py-2.5 rounded-lg border '+C.border+' '+C.text+' btn">إلغاء</button></div>');
        }

        function saveEditPm(pmId) {
            var pms = DB.get('paymentMethods');
            var pm = pms.find(function(x){return x.id===pmId;});
            if(!pm) return;
            pm.title = document.getElementById('pm-edit-title').value.trim();
            if(pm.type==='CRYPTO') pm.address = document.getElementById('pm-edit-address').value.trim();
            if(pm.type==='BANK') {
                pm.bankName = document.getElementById('pm-edit-bank-name').value.trim();
                pm.accountNumber = document.getElementById('pm-edit-account').value.trim();
                pm.recipientName = document.getElementById('pm-edit-recipient').value.trim();
            }
            pm.minDeposit = parseFloat(document.getElementById('pm-edit-min-dep').value) || 0;
            pm.minWithdraw = parseFloat(document.getElementById('pm-edit-min-wd').value) || 0;
            DB.set('paymentMethods', pms);
            closeModal();
            toast('تم تحديث طريقة الدفع','success');
            render();
        }

        function togglePmActive(pmId) {
            var pms = DB.get('paymentMethods');
            var pm = pms.find(function(x){return x.id===pmId;});
            if(!pm) return;
            pm.isActive = !pm.isActive;
            DB.set('paymentMethods', pms);
            toast(pm.isActive?'تم تفعيل الطريقة':'تم تعطيل الطريقة','success');
            render();
        }

        function deletePm(pmId) {
            showConfirm('🗑️','حذف طريقة الدفع','هل أنت متأكد؟','حذف','bg-danger text-white',function(yes){
                if(!yes) return;
                var pms = DB.get('paymentMethods').filter(function(x){return x.id!==pmId;});
                DB.set('paymentMethods', pms);
                toast('تم حذف طريقة الدفع','success');
                render();
            });
        }
        // ==================== ADMIN: AFFILIATE ====================
        function renderAdminAffiliate(C) {
            var users = DB.get('users');
            var pending = users.filter(function(u){return u.affiliateStatus==='PENDING';});
            var active = users.filter(function(u){return u.affiliateStatus==='APPROVED';});
            var l1 = DB.getSetting('aff_l1') || '5';
            var l2 = DB.getSetting('aff_l2') || '3';
            var l3 = DB.getSetting('aff_l3') || '1';
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">🔗 نظام العمولة</h2>'+
                '<div class="grid grid-cols-3 gap-3 mb-4">'+
                '<div class="'+C.card+' rounded-lg p-3 text-center border '+C.border+'"><p class="'+C.muted+' text-xs">مستوى 1</p><p class="font-bold text-primary">'+l1+'%</p></div>'+
                '<div class="'+C.card+' rounded-lg p-3 text-center border '+C.border+'"><p class="'+C.muted+' text-xs">مستوى 2</p><p class="font-bold text-primary">'+l2+'%</p></div>'+
                '<div class="'+C.card+' rounded-lg p-3 text-center border '+C.border+'"><p class="'+C.muted+' text-xs">مستوى 3</p><p class="font-bold text-primary">'+l3+'%</p></div></div>';
            if(pending.length>0) {
                html += '<h3 class="font-bold '+C.text+' mb-3">طلبات الانضمام ('+pending.length+')</h3><div class="space-y-2 mb-6">';
                pending.forEach(function(u) {
                    html += '<div class="flex items-center justify-between p-3 rounded-lg border '+C.border+'">'+
                        '<div><p class="text-sm font-medium '+C.text+'">'+escHtml(u.name)+'</p><p class="text-xs '+C.muted+'">'+escHtml(u.email)+'</p></div>'+
                        '<div class="flex gap-2"><button onclick="approveAffiliate(\''+u.id+'\')" class="px-3 py-1.5 rounded-lg btn bg-success text-dark-bg text-xs">✅ قبول</button><button onclick="rejectAffiliate(\''+u.id+'\')" class="px-3 py-1.5 rounded-lg btn bg-danger text-white text-xs">❌ رفض</button></div></div>';
                });
                html += '</div>';
            }
            if(active.length>0) {
                html += '<h3 class="font-bold '+C.text+' mb-3">المسوقين النشطين ('+active.length+')</h3><div class="space-y-2">';
                active.forEach(function(u) {
                    var refs = users.filter(function(r){return r.referredBy===u.id;});
                    html += '<div class="p-3 rounded-lg border '+C.border+'">'+
                        '<div class="flex items-center justify-between mb-1"><p class="text-sm font-medium '+C.text+'">'+escHtml(u.name)+'</p><span class="font-mono text-xs text-primary">'+escHtml(u.affiliateCode)+'</span></div>'+
                        '<p class="text-xs '+C.muted+'">المدعوين: '+refs.length+' | رصيد العمولات: '+fmtNum(u.affiliateBalance||0)+' USDT</p></div>';
                });
                html += '</div>';
            }
            html += '</div>';
            return html;
        }

        function approveAffiliate(userId) {
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===userId;});
            if(!u) return;
            u.affiliateStatus = 'APPROVED';
            DB.set('users', users);
            addNotif(userId,'عمولة مقبولة','تم قبول طلبك في نظام العمولة','AFFILIATE');
            toast('تم قبول طلب العمولة','success');
            render();
        }

        function rejectAffiliate(userId) {
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===userId;});
            if(!u) return;
            u.affiliateStatus = 'REJECTED'; u.affiliateCode = null;
            DB.set('users', users);
            addNotif(userId,'عمولة مرفوضة','تم رفض طلبك في نظام العمولة','AFFILIATE');
            toast('تم رفض طلب العمولة','success');
            render();
        }

        // ==================== ADMIN: CHAT (FIXED) ====================
        function renderAdminChat(C) {
            var users = DB.get('users').filter(function(u){return u.role!=='ADMIN';});
            var messages = DB.get('messages');
            // FIX: Initialize activeChatUserId on state if not set
            if(!state.activeChatUserId && users.length > 0) {
                state.activeChatUserId = users[0].id;
            }
            var chatUserId = state.activeChatUserId;
            var chatUser = users.find(function(u){return u.id===chatUserId;});
            var userListHtml = users.map(function(u) {
                var unread = messages.filter(function(m){return m.fromId===u.id && m.toId==='admin1' && !m.isRead;}).length;
                var lastMsg = messages.filter(function(m){return (m.fromId===u.id&&m.toId==='admin1')||(m.fromId==='admin1'&&m.toId===u.id);}).sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);})[0];
                var lastText = lastMsg ? (lastMsg.text||'').substr(0,30) : 'لا توجد رسائل';
                var isActive = chatUserId === u.id;
                return '<button onclick="state.activeChatUserId=\''+u.id+'\';render()" class="w-full text-right p-3 rounded-lg border '+C.border+' btn '+(isActive?'border-primary bg-primary/10':'hover:bg-primary/5')+' mb-2">'+
                    '<div class="flex items-center justify-between"><p class="text-sm font-medium '+C.text+'">'+escHtml(u.name)+'</p>'+(unread>0?'<span class="bg-primary text-dark-bg text-xs w-5 h-5 rounded-full flex items-center justify-center">'+unread+'</span>':'')+'</div>'+
                    '<p class="text-xs '+C.muted+' mt-1 truncate">'+escHtml(lastText)+'</p></button>';
            }).join('');
            var chatMsgs = [];
            if(chatUserId) {
                chatMsgs = messages.filter(function(m){return (m.fromId===chatUserId&&m.toId==='admin1')||(m.fromId==='admin1'&&m.toId===chatUserId);}).sort(function(a,b){return new Date(a.createdAt)-new Date(b.createdAt);});
                // Mark messages as read
                var unreadAdmin = chatMsgs.filter(function(m){return m.fromId===chatUserId && !m.isRead;});
                if(unreadAdmin.length>0) {
                    var allMsgs = DB.get('messages');
                    unreadAdmin.forEach(function(m) {
                        var idx = allMsgs.findIndex(function(x){return x.id===m.id;});
                        if(idx>=0) allMsgs[idx].isRead = true;
                    });
                    DB.set('messages', allMsgs);
                }
            }
            var msgsHtml = '';
            if(!chatUser) msgsHtml = '<p class="'+C.muted+' text-center py-8">لا يوجد مستخدمين</p>';
            else if(chatMsgs.length===0) msgsHtml = '<p class="'+C.muted+' text-center py-8 text-sm">لا توجد رسائل</p>';
            else {
                chatMsgs.forEach(function(m) {
                    var isMe = m.fromId === 'admin1';
                    msgsHtml += '<div class="flex '+(isMe?'justify-end':'justify-start')+' mb-3">'+
                        '<div class="max-w-[75%] px-4 py-2.5 rounded-xl '+(isMe?'chat-bubble-me':'chat-bubble-other')+'"><p>'+escHtml(m.text)+'</p><p class="text-[10px] opacity-60 mt-1">'+fmtDate(m.createdAt)+'</p></div></div>';
                });
            }
            setTimeout(function(){
                var chatBox = document.getElementById('admin-chat-messages');
                if(chatBox) chatBox.scrollTop = chatBox.scrollHeight;
            }, 100);
            return '<div class="flex gap-4 h-[calc(100vh - 160px)]">'+
                '<div class="w-64 shrink-0 '+C.card+' rounded-xl border '+C.border+' overflow-y-auto p-3 hidden lg:block">'+
                '<h3 class="font-bold '+C.text+' mb-3">المحادثات</h3>'+userListHtml+'</div>'+
                '<div class="flex-1 '+C.card+' rounded-xl border '+C.border+' flex flex-col">'+
                '<div class="p-4 border-b '+C.border+'"><p class="font-bold '+C.text+'">'+(chatUser?'محادثة مع '+escHtml(chatUser.name):'اختر مستخدم')+'</p></div>'+
                '<div id="admin-chat-messages" class="flex-1 overflow-y-auto p-4">'+msgsHtml+'</div>'+
                (chatUser?'<div class="p-3 border-t '+C.border+' flex gap-2"><input type="text" id="admin-chat-input" class="flex-1 px-4 py-2.5 rounded-lg border '+C.input+' outline-none text-sm" placeholder="اكتب رسالتك..." onkeydown="if(event.key===\'Enter\')sendAdminChat()">'+
                '<button onclick="sendAdminChat()" class="'+C.btn+' px-5 py-2.5 rounded-lg btn text-sm">إرسال</button></div>':'')+'</div></div>';
        }

        function sendAdminChat() {
            var input = document.getElementById('admin-chat-input');
            if(!input || !state.activeChatUserId) return;
            var text = input.value.trim();
            if(!text) return;
            var msgs = DB.get('messages');
            msgs.push({id:DB.uid(),fromId:'admin1',toId:state.activeChatUserId,text:text,isRead:false,createdAt:new Date().toISOString()});
            DB.set('messages', msgs);
            input.value = '';
            render();
        }

        // ==================== ADMIN: MERCHANTS ====================
        function renderAdminMerchants(C) {
            var reqs = DB.get('merchantRequests');
            var pending = reqs.filter(function(r){return r.status==='PENDING';});
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">🏪 طلبات التجار ('+pending.length+' معلق)</h2>'+
                (reqs.length===0 ? '<p class="'+C.muted+' text-center py-8">لا توجد طلبات</p>' :
                '<div class="space-y-4 max-h-[70vh] overflow-y-auto">'+reqs.map(function(r) {
                    var u = DB.get('users').find(function(x){return x.id===r.userId;});
                    return '<div class="p-4 rounded-lg border '+C.border+'">'+
                        '<div class="flex items-center justify-between mb-3"><div><p class="font-medium text-sm '+C.text+'">'+escHtml(u?u.name:'مستخدم محذوف')+'</p><p class="text-xs '+C.muted+'">'+escHtml(u?u.email:'')+' | '+fmtDate(r.createdAt)+'</p></div>'+statusBadge(r.status)+'</div>'+
                        (r.status==='REJECTED'&&r.rejectReason?'<p class="text-danger text-xs mb-3">سبب الرفض: '+escHtml(r.rejectReason)+'</p>':'')+
                        '<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">'+
                        '<div><p class="text-xs '+C.muted+' mb-1">الهوية (أمام)</p><img src="'+r.frontId+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+r.id+'\',\'merch-front\')"></div>'+
                        '<div><p class="text-xs '+C.muted+' mb-1">الهوية (خلف)</p><img src="'+r.backId+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+r.id+'\',\'merch-back\')"></div>'+
                        '<div><p class="text-xs '+C.muted+' mb-1">سيلفي مع الهوية</p><img src="'+r.selfieWithId+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+r.id+'\',\'merch-selfie\')"></div>'+
                        '<div><p class="text-xs '+C.muted+' mb-1">إثبات العنوان</p><img src="'+r.proofOfAddress+'" class="h-32 rounded-lg border cursor-pointer object-cover" onclick="showDynamicImageModal(\''+r.id+'\',\'merch-address\')"></div></div>'+
                        (r.status==='PENDING'?'<div class="flex gap-2"><button onclick="approveMerchant(\''+r.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-success text-dark-bg text-sm">✅ قبول</button><button onclick="rejectMerchant(\''+r.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div>':'')+
                        '</div>';
                }).join('')+'</div>')+'</div>';
        }

        function approveMerchant(reqId) {
            var reqs = DB.get('merchantRequests');
            var r = reqs.find(function(x){return x.id===reqId;});
            if(!r) return;
            r.status = 'APPROVED';
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===r.userId;});
            if(u) {
                u.role = 'MERCHANT';
                u.merchantStatus = 'APPROVED';
                DB.set('users', users);
            }
            DB.set('merchantRequests', reqs);
            addNotif(r.userId,'طلب تاجر مقبول','تم قبول طلبك كتاجر في ForexYemeni. تم تحويل حسابك إلى حساب تاجر. قم بتسجيل الخروج ثم تسجيل الدخول للوصول إلى لوحة التحكم.','MERCHANT');
            toast('تم قبول طلب التاجر - تم تحويل الحساب إلى حساب تاجر','success');
            render();
        }

        function rejectMerchant(reqId) {
            var C = getThemeColors();
            showModal('<h3 class="text-lg font-bold '+C.text+' mb-4">❌ رفض طلب التاجر</h3>'+
                '<textarea id="merch-reject-reason" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none h-24" placeholder="سبب الرفض..."></textarea>'+
                '<button onclick="confirmRejectMerchant(\''+reqId+'\')" class="bg-danger text-white w-full py-2.5 rounded-lg font-bold btn mt-3">تأكيد الرفض</button></div>');
        }

        function confirmRejectMerchant(reqId) {
            var reason = document.getElementById('merch-reject-reason').value.trim();
            if(!reason) { toast('أدخل سبب الرفض','error'); return; }
            var reqs = DB.get('merchantRequests');
            var r = reqs.find(function(x){return x.id===reqId;});
            if(!r) return;
            r.status = 'REJECTED'; r.rejectReason = reason;
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===r.userId;});
            if(u) { u.merchantStatus = 'NONE'; DB.set('users', users); }
            DB.set('merchantRequests', reqs);
            addNotif(r.userId,'طلب تاجر مرفوض','تم رفض طلبك كتاجر. السبب: '+reason,'MERCHANT');
            closeModal();
            toast('تم رفض طلب التاجر','success');
            render();
        }

        // ==================== ADMIN: MERCHANT TRANSACTIONS ====================
        function renderAdminMerchantTransactions(C) {
            var txns = DB.get('merchantTransactions');
            txns.sort(function(a,b){return new Date(b.createdAt)-new Date(a.createdAt);});
            if(txns.length===0) return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+' text-center"><p class="text-4xl mb-4">📊</p><p class="'+C.muted+'">لا توجد معاملات تجار حالياً</p></div>';
            var html = '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'"><h2 class="text-xl font-bold '+C.text+' mb-4">📊 معاملات التجار ('+txns.length+')</h2><div class="space-y-3 max-h-[70vh] overflow-y-auto">';
            var users = DB.get('users');
            txns.forEach(function(t) {
                var merchant = users.find(function(u){return u.id===t.merchantId;});
                var user = users.find(function(u){return u.id===t.userId;});
                var isDep = t.type === 'DEPOSIT';
                html += '<div class="p-3 rounded-lg border '+C.border+' flex items-center justify-between">'+
                    '<div><p class="text-sm font-medium '+C.text+'">'+(isDep?'💰':'🏧')+' '+(isDep?'إيداع':'سحب')+'</p>'+
                    '<p class="text-xs '+C.muted+'">التاجر: '+escHtml(merchant?merchant.name:'—')+' | المستخدم: '+escHtml(user?user.name:'—')+'</p>'+
                    '<p class="text-xs '+C.muted+'">'+fmtDate(t.createdAt)+'</p></div>'+
                    '<div class="text-left"><p class="font-bold text-sm '+(isDep?'text-success':'text-danger')+'">'+fmtNum(t.amount)+' USDT</p>'+statusBadge(t.status)+'</div></div>';
            });
            html += '</div></div>';
            return html;
        }
        // ==================== ADMIN: PROFILE CHANGES ====================
        function renderAdminProfileChanges(C) {
            var requests = DB.get('profileChangeRequests');
            var pending = requests.filter(function(r){return r.status==='PENDING';});
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">📝 طلبات تغيير البيانات ('+pending.length+' معلق)</h2>'+
                (requests.length===0 ? '<p class="'+C.muted+' text-center py-8">لا توجد طلبات</p>' :
                '<div class="space-y-3 max-h-[70vh] overflow-y-auto">'+requests.map(function(r) {
                    var u = DB.get('users').find(function(x){return x.id===r.userId;});
                    var typeLabels = {'CHANGE_PHONE':'تغيير رقم الهاتف','CHANGE_EMAIL':'تغيير البريد','DELETE_WD_METHOD':'حذف طريقة سحب'};
                    var typeLabel = typeLabels[r.type] || r.type;
                    return '<div class="p-4 rounded-lg border '+C.border+'">'+
                        '<div class="flex items-center justify-between mb-3"><div><p class="font-medium text-sm '+C.text+'">'+escHtml(u?u.name:'مستخدم محذوف')+'</p><p class="text-xs '+C.muted+'">'+typeLabel+' | '+fmtDate(r.createdAt)+'</p></div>'+statusBadge(r.status)+'</div>'+
                        (r.type!=='DELETE_WD_METHOD'?'<p class="text-sm '+C.muted+' mb-2">القيمة الجديدة: <span class="'+C.text+' font-medium">'+escHtml(r.newValue||'—')+'</span></p>':'')+
                        (r.selfie?'<div class="mb-3"><p class="text-xs '+C.muted+' mb-1">صورة التحقق:</p><img src="'+r.selfie+'" class="h-28 rounded-lg border cursor-pointer object-cover" onclick="showImageModal(this.src)"></div>':'')+
                        (r.status==='PENDING'?'<div class="flex gap-2"><button onclick="approveProfileChange(\''+r.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-success text-dark-bg text-sm">✅ قبول</button><button onclick="rejectProfileChange(\''+r.id+'\')" class="flex-1 py-2 rounded-lg font-bold btn bg-danger text-white text-sm">❌ رفض</button></div>':'')+
                        '</div>';
                }).join('')+'</div>')+'</div>';
        }

        function approveProfileChange(reqId) {
            var requests = DB.get('profileChangeRequests');
            var r = requests.find(function(x){return x.id===reqId;});
            if(!r) return;
            r.status = 'APPROVED';
            var users = DB.get('users');
            var u = users.find(function(x){return x.id===r.userId;});
            if(u) {
                if(r.type==='CHANGE_PHONE') u.phone = r.newValue;
                else if(r.type==='CHANGE_EMAIL') u.email = r.newValue;
                else if(r.type==='DELETE_WD_METHOD') {
                    var wms = DB.get('userWithdrawalMethods').filter(function(w){return w.id!==r.targetId;});
                    DB.set('userWithdrawalMethods', wms);
                }
                DB.set('users', users);
            }
            DB.set('profileChangeRequests', requests);
            var typeLabels = {'CHANGE_PHONE':'رقم الهاتف','CHANGE_EMAIL':'البريد الإلكتروني','DELETE_WD_METHOD':'طريقة السحب'};
            addNotif(r.userId,'تم قبول الطلب','تم قبول طلب تغيير '+(typeLabels[r.type]||'البيانات'),'INFO');
            toast('تم قبول الطلب','success');
            render();
        }

        function rejectProfileChange(reqId) {
            var requests = DB.get('profileChangeRequests');
            var r = requests.find(function(x){return x.id===reqId;});
            if(!r) return;
            r.status = 'REJECTED';
            DB.set('profileChangeRequests', requests);
            addNotif(r.userId,'تم رفض الطلب','تم رفض طلب تغيير البيانات','INFO');
            toast('تم رفض الطلب','success');
            render();
        }

        // ==================== ADMIN: REPORTS ====================
        function renderAdminReports(C) {
            var users = DB.get('users').filter(function(u){return u.role!=='ADMIN';});
            var deposits = DB.get('deposits');
            var withdrawals = DB.get('withdrawals');
            var totalDep = deposits.filter(function(d){return d.status==='APPROVED';}).reduce(function(s,d){return s+(d.usdtAmount||0);},0);
            var totalWd = withdrawals.filter(function(w){return w.status==='APPROVED';}).reduce(function(s,w){return s+(w.net||0);},0);
            var pendingDep = deposits.filter(function(d){return d.status==='PENDING';}).reduce(function(s,d){return s+(d.usdtAmount||0);},0);
            var pendingWd = withdrawals.filter(function(w){return w.status==='PENDING';}).reduce(function(s,w){return s+(w.net||0);},0);
            var totalBalance = users.reduce(function(s,u){return s+(u.usdtBalance||0);},0);
            var rate = parseFloat(DB.getSetting('exchange_rate')) || 535;
            var totalFees = withdrawals.filter(function(w){return w.status==='APPROVED';}).reduce(function(s,w){return s+(w.fee||0);},0);
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-4">📈 التقارير المالية</h2>'+
                '<div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">إجمالي المستخدمين</p><p class="text-2xl font-bold text-primary">'+users.length+'</p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">إجمالي أرصدة المستخدمين</p><p class="text-2xl font-bold text-success">'+fmtNum(totalBalance)+' <span class="text-sm">USDT</span></p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">المعادل YER</p><p class="text-2xl font-bold text-primary">'+fmtInt(Math.round(totalBalance*rate))+'</p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">إجمالي الإيداعات (مقبولة)</p><p class="text-2xl font-bold text-success">'+fmtNum(totalDep)+' <span class="text-sm">USDT</span></p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">إجمالي السحوبات (مقبولة)</p><p class="text-2xl font-bold text-danger">'+fmtNum(totalWd)+' <span class="text-sm">USDT</span></p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">إجمالي الرسوم المحصلة</p><p class="text-2xl font-bold text-warning">'+fmtNum(totalFees)+' <span class="text-sm">USDT</span></p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">إيداعات معلقة</p><p class="text-2xl font-bold text-warning">'+fmtNum(pendingDep)+' <span class="text-sm">USDT</span></p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">سحوبات معلقة</p><p class="text-2xl font-bold text-warning">'+fmtNum(pendingWd)+' <span class="text-sm">USDT</span></p></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' text-center"><p class="'+C.muted+' text-xs mb-1">صافي التدفق</p><p class="text-2xl font-bold '+(totalDep-totalWd>=0?'text-success':'text-danger')+'">'+fmtNum(totalDep-totalWd)+' <span class="text-sm">USDT</span></p></div></div></div>';
        }

        // ==================== ADMIN: DB CONFIG (IMPROVED) ====================
        window._dbTestSuccess = false;
        window._pendingConfig = null;

        function parseFirebaseConfigSnippet(raw) {
            raw = raw.trim();
            // Try direct JSON parse first
            try { return JSON.parse(raw); } catch(e) {}
            // Try extracting from JavaScript snippet: const firebaseConfig = { ... }; or var firebaseConfig = { ... };
            var patterns = [
                /(?:const|var|let)\s+\w+\s*=\s*(\{[\s\S]*?\})\s*;/,
                /(\{[\s\S]*?"apiKey"[\s\S]*?\})/,
                /(\{[\s\S]*?"projectId"[\s\S]*?\})/
            ];
            for (var i = 0; i < patterns.length; i++) {
                var match = raw.match(patterns[i]);
                if (match) {
                    var jsonStr = match[1].trim();
                    // Replace unquoted keys with quoted keys for JSON.parse
                    jsonStr = jsonStr.replace(/(\w+)\s*:/g, '"$1":');
                    // Fix double-quoted keys that were already quoted
                    jsonStr = jsonStr.replace(/""/g, '"');
                    try { var parsed = JSON.parse(jsonStr); return parsed; } catch(e2) {
                        // Try eval as last resort for JS object syntax
                        try {
                            var obj = (new Function('return ' + match[1].trim()))();
                            if (obj && typeof obj === 'object') return obj;
                        } catch(e3) {}
                    }
                }
            }
            return null;
        }

        function renderAdminDbConfig(C) {
            var isEdit = state.dbConfigEditMode;
            var cfg = firebaseConfig || {};
            var keys = [
                {key:'apiKey',label:'API Key',placeholder:'AIzaSy...'},
                {key:'authDomain',label:'Auth Domain',placeholder:'your-project.firebaseapp.com'},
                {key:'projectId',label:'Project ID',placeholder:'your-project-id'},
                {key:'storageBucket',label:'Storage Bucket',placeholder:'your-project.appspot.com'},
                {key:'messagingSenderId',label:'Messaging Sender ID',placeholder:'123456789'},
                {key:'appId',label:'App ID',placeholder:'1:123456789:web:abcdef'}
            ];
            var inputClass = isEdit ? C.input : C.input + ' opacity-70';
            var roAttr = isEdit ? '' : 'readonly ';
            var fieldsHtml = keys.map(function(f) {
                var val = cfg[f.key] || '';
                return '<div><label class="block text-xs '+C.muted+' mb-1">'+escHtml(f.label)+'</label>'+
                    '<input type="text" id="dbcfg-'+f.key+'" value="'+escHtml(val)+'" class="w-full px-3 py-2 rounded-lg border '+inputClass+' outline-none text-xs font-mono" placeholder="'+escHtml(f.placeholder)+'" '+roAttr+'></div>';
            }).join('');
            return '<div class="'+C.card+' rounded-xl p-6 border '+C.border+' max-w-2xl mx-auto">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-2 text-center">🗄️ إعدادات قاعدة البيانات</h2>'+
                '<p class="'+C.muted+' text-xs text-center mb-6">قم بتعديل إعدادات Firebase أو الصق كود Config من Firebase Console مباشرة</p>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' mb-6">'+
                '<div class="flex items-center gap-3 mb-3"><span class="text-2xl">☁️</span><div><h3 class="font-bold '+C.text+'">الاتصال الحالي</h3><p class="text-xs '+C.muted+'">Firebase Firestore</p></div></div>'+
                '<div class="grid grid-cols-2 gap-3">'+
                '<div class="p-3 rounded-lg border '+C.border+'"><p class="text-xs '+C.muted+' mb-1">Project ID</p><p class="font-mono text-sm '+C.text+' break-all">'+escHtml(firebaseConfig.projectId||'')+'</p></div>'+
                '<div class="p-3 rounded-lg border '+C.border+'"><p class="text-xs '+C.muted+' mb-1">API Key</p><p class="font-mono text-xs '+C.text+' break-all">'+escHtml((firebaseConfig.apiKey||'').substr(0,30))+'...</p></div></div></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' mb-4">'+
                '<div class="flex items-center justify-between mb-3"><h3 class="font-bold text-sm '+C.text+'">⚙️ حقول الإعدادات</h3>'+
                '<div class="flex gap-2">'+
                (isEdit?'<button onclick="state.dbConfigEditMode=false;window._dbTestSuccess=false;render()" class="text-xs px-3 py-1.5 rounded-lg border '+C.border+' '+C.text+' btn">🔒 إغلاق</button>':'<button onclick="state.dbConfigEditMode=true;render()" class="text-xs px-3 py-1.5 rounded-lg border '+C.border+' '+C.text+' btn">✏️ تعديل</button>')+
                '<button onclick="pasteFromClipboard()" class="text-xs px-3 py-1.5 rounded-lg border '+C.border+' '+C.text+' btn">📋 لصق من الحافظة</button>'+
                '<button onclick="document.getElementById(\'db-config-snippet\').value=\'\';render()" class="text-xs px-3 py-1.5 rounded-lg border '+C.border+' '+C.text+' btn">↩️ إعادة الحالي</button></div></div>'+
                '<div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">'+fieldsHtml+'</div>'+
                '</div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+' mb-4">'+
                '<label class="block text-sm font-medium '+C.text+' mb-2">📋 أو الصق كود Firebase Config كاملاً</label>'+
                '<textarea id="db-config-snippet" class="w-full px-4 py-3 rounded-lg border '+C.input+' outline-none h-32 font-mono text-xs leading-relaxed" placeholder="يمكنك لصق الكود كاملاً من Firebase Console:\n\nconst firebaseConfig = {\n  apiKey: \"AIzaSy...\",\n  authDomain: \"your-project.firebaseapp.com\",\n  projectId: \"your-project-id\",\n  ...\n};"></textarea>'+
                '<button onclick="applyDbConfigSnippet()" class="mt-2 px-4 py-2 rounded-lg border '+C.border+' '+C.text+' btn text-sm font-medium">📥 تطبيق الكود المُلصق</button></div>'+
                '<div id="db-config-result" class="mb-4"></div>'+
                '<div class="flex gap-3">'+
                '<button onclick="testDbConnection()" class="flex-1 py-2.5 rounded-lg font-bold btn bg-info text-white">🔌 تجربة الاتصال</button>'+
                '<button onclick="saveDbConfig()" class="flex-1 py-2.5 rounded-lg font-bold btn '+(window._dbTestSuccess?'bg-success text-dark-bg':'opacity-50 cursor-not-allowed')+'" '+(window._dbTestSuccess?'':'disabled')+' id="save-db-config-btn">💾 حفظ وتفعيل</button>'+
                '<button onclick="restoreDefaultConfig()" class="flex-1 py-2.5 rounded-lg font-bold btn bg-warning text-dark-bg">↩️ افتراضي</button></div></div>';
        }

        function applyDbConfigSnippet() {
            var snippet = document.getElementById('db-config-snippet');
            if (!snippet || !snippet.value.trim()) { toast('الصق كود Firebase Config أولاً','error'); return; }
            var parsed = parseFirebaseConfigSnippet(snippet.value);
            if (!parsed) { toast('فشل تحليل الكود. تأكد من صحة التنسيق.','error'); return; }
            // Fill the individual fields
            var fields = ['apiKey','authDomain','projectId','storageBucket','messagingSenderId','appId'];
            fields.forEach(function(f) {
                var el = document.getElementById('dbcfg-' + f);
                if (el && parsed[f]) el.value = parsed[f];
            });
            state.dbConfigEditMode = true;
            window._dbTestSuccess = false;
            toast('تم استخراج الإعدادات بنجاح','success',false);
            render();
        }

        function pasteFromClipboard() {
            if(navigator.clipboard && navigator.clipboard.readText) {
                navigator.clipboard.readText().then(function(text) {
                    if(text) {
                        var snippetEl = document.getElementById('db-config-snippet');
                        if(snippetEl) { snippetEl.value = text.trim(); window._dbTestSuccess = false; toast('تم اللصق','success',false); }
                    }
                }).catch(function() { toast('لا يمكن الوصول للحافظة','warning',false); });
            } else { toast('المتصفح لا يدعم لصق الحافظة','warning',false); }
        }

        function getDbConfigFromFields() {
            var fields = ['apiKey','authDomain','projectId','storageBucket','messagingSenderId','appId'];
            var cfg = {};
            fields.forEach(function(f) {
                var el = document.getElementById('dbcfg-' + f);
                if (el) cfg[f] = el.value.trim();
            });
            return cfg;
        }

        function testDbConnection() {
            // First check if there's a snippet to parse
            var snippetEl = document.getElementById('db-config-snippet');
            var newConfig = null;
            if (snippetEl && snippetEl.value.trim()) {
                newConfig = parseFirebaseConfigSnippet(snippetEl.value);
            }
            // Otherwise read from individual fields
            if (!newConfig) {
                newConfig = getDbConfigFromFields();
            }
            var resultEl = document.getElementById('db-config-result');
            if(!resultEl) return;
            if(!newConfig || !newConfig.apiKey || !newConfig.projectId) { resultEl.innerHTML = '<div class="p-3 rounded-lg bg-danger/20 border border-danger/30 text-danger text-sm">❌ أدخل إعدادات Firebase صحيحة (يجب وجود apiKey و projectId)</div>'; return; }
            resultEl.innerHTML = '<div class="p-3 rounded-lg bg-warning/20 border border-warning/30 text-warning text-sm">⏳ جاري اختبار الاتصال بقاعدة البيانات...</div>';
            window._dbTestSuccess = false;
            try {
                var testAppName = 'test-' + Date.now();
                var testApp = firebase.initializeApp(newConfig, testAppName);
                var testDb = firebase.firestore(testApp);
                var startTime = Date.now();
                testDb.collection('appData').doc('settings').get().then(function(doc) {
                    var elapsed = Date.now() - startTime;
                    var dbSize = doc.exists ? 'تحتوي بيانات' : 'فارغة (جديدة)';
                    resultEl.innerHTML = '<div class="p-3 rounded-lg bg-success/20 border border-success/30 text-success text-sm">'+
                        '<p class="font-bold mb-1">✅ الاتصال ناجح!</p>'+
                        '<p class="text-xs">📡 Project: '+escHtml(newConfig.projectId)+'</p>'+
                        '<p class="text-xs">⏱️ زمن الاستجابة: '+elapsed+'ms</p>'+
                        '<p class="text-xs">📊 حالة: '+dbSize+'</p></div>';
                    window._dbTestSuccess = true;
                    window._pendingConfig = newConfig;
                    testApp.delete().catch(function(){});
                    render();
                }).catch(function(err) {
                    var errStr = err.message || '';
                    var isPermission = errStr.indexOf('permission')>=0 || errStr.indexOf('PERMISSION')>=0;
                    resultEl.innerHTML = '<div class="p-3 rounded-lg bg-danger/20 border border-danger/30 text-danger text-sm">'+
                        '<p class="font-bold mb-1">❌ فشل الاتصال</p>'+
                        '<p class="text-xs">'+escHtml(errStr)+'</p>'+
                        (isPermission?'<p class="text-xs mt-1">💡 تلميح: تأكد من تفعيل Cloud Firestore في Firebase Console وتفعيل صلاحيات القراءة</p>':'')+'</div>';
                    window._dbTestSuccess = false;
                    try { testApp.delete().catch(function(){}); } catch(e) {}
                });
            } catch(e) {
                var errMsg = e.message || '';
                var hint = '';
                if(errMsg.indexOf('Unexpected token')>=0 || errMsg.indexOf('JSON')>=0) hint = '<p class="text-xs mt-1">💡 تأكد من أن النص المُدخل هو كود JSON صالح أو كود JavaScript صالح.</p>';
                resultEl.innerHTML = '<div class="p-3 rounded-lg bg-danger/20 border border-danger/30 text-danger text-sm">'+
                    '<p class="font-bold mb-1">❌ خطأ في تحليل الإعدادات</p>'+
                    '<p class="text-xs">'+escHtml(errMsg)+'</p>'+hint+'</div>';
                window._dbTestSuccess = false;
            }
        }

        function saveDbConfig() {
            if(!window._dbTestSuccess || !window._pendingConfig) { toast('يجب اختبار الاتصال بنجاح أولاً','error'); return; }
            showConfirm('💾','حفظ الإعدادات','سيتم حفظ الإعدادات الجديدة وسيتم إعادة تحميل الصفحة. متابعة؟','نعم، حفظ','bg-success text-dark-bg',function(yes){
                if(!yes) return;
                localStorage.setItem('fy_firebase_config', JSON.stringify(window._pendingConfig));
                toast('تم حفظ الإعدادات. جاري إعادة التحميل...','success',false);
                setTimeout(function(){ location.reload(); }, 1500);
            });
        }

        function restoreDefaultConfig() {
            showConfirm('↩️','استعادة الافتراضي','سيتم استعادة الإعدادات الافتراضية وإعادة تحميل الصفحة.','نعم','bg-warning text-dark-bg',function(yes){
                if(!yes) return;
                localStorage.removeItem('fy_firebase_config');
                toast('جاري استعادة الإعدادات الافتراضية...','success',false);
                setTimeout(function(){ location.reload(); }, 1500);
            });
        }

        // ==================== ADMIN: SETTINGS ====================
        function renderAdminSettings(C) {
            var rate = DB.getSetting('exchange_rate');
            var fee = DB.getSetting('exchange_fee');
            var l1 = DB.getSetting('aff_l1');
            var l2 = DB.getSetting('aff_l2');
            var l3 = DB.getSetting('aff_l3');
            var adminPhone = DB.getSetting('admin_phone');
            var adminWA = DB.getSetting('admin_whatsapp');
            var merchantComm = DB.getSetting('merchant_commission');
            var users = DB.get('users');
            var adminUser = users.find(function(u){return u.role==='ADMIN';});
            return '<div class="'+C.card+' rounded-xl p-6 max-w-2xl mx-auto border '+C.border+'">'+
                '<h2 class="text-xl font-bold '+C.text+' mb-6 text-center">⚙️ الإعدادات العامة</h2>'+
                '<div class="space-y-6">'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">💱 العملات والرسوم</h3><div class="space-y-3">'+
                '<div class="grid grid-cols-2 gap-3">'+
                '<div><label class="block text-sm '+C.muted+' mb-1">سعر الصرف (1 USDT = ? YER)</label><input type="number" id="set-rate" value="'+rate+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>'+
                '<div><label class="block text-sm '+C.muted+' mb-1">رسوم السحب (%)</label><input type="number" id="set-fee" value="'+fee+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" min="0" max="100"></div></div>'+
                '<div><label class="block text-sm '+C.muted+' mb-1">عمولة التاجر (%)</label><input type="number" id="set-merch-comm" value="'+merchantComm+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" min="0" max="100"></div></div></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">🔗 نسب العمولة</h3><div class="grid grid-cols-3 gap-3">'+
                '<div><label class="block text-sm '+C.muted+' mb-1">المستوى 1 (%)</label><input type="number" id="set-l1" value="'+l1+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" min="0" max="100"></div>'+
                '<div><label class="block text-sm '+C.muted+' mb-1">المستوى 2 (%)</label><input type="number" id="set-l2" value="'+l2+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" min="0" max="100"></div>'+
                '<div><label class="block text-sm '+C.muted+' mb-1">المستوى 3 (%)</label><input type="number" id="set-l3" value="'+l3+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" min="0" max="100"></div></div></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">📞 بيانات التواصل (تظهر للمستخدمين)</h3><div class="space-y-3">'+
                '<div><label class="block text-sm '+C.muted+' mb-1">رقم الهاتف</label><input type="text" id="set-admin-phone" value="'+escHtml(adminPhone)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="+967..."></div>'+
                '<div><label class="block text-sm '+C.muted+' mb-1">رقم واتساب</label><input type="text" id="set-admin-wa" value="'+escHtml(adminWA)+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="+967..."></div></div></div>'+
                '<div class="'+C.card+' rounded-lg p-4 border '+C.border+'"><h3 class="font-bold '+C.text+' mb-3">🔐 بيانات المدير</h3><div class="space-y-3">'+
                '<div><label class="block text-sm '+C.muted+' mb-1">بريد المدير</label><input type="email" id="set-admin-email" value="'+escHtml(adminUser?adminUser.email:'')+'" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none"></div>'+
                '<div><label class="block text-sm '+C.muted+' mb-1">كلمة المرور الجديدة (اتركها فارغة لعدم التغيير)</label><input type="password" id="set-admin-pass" class="w-full px-4 py-2.5 rounded-lg border '+C.input+' outline-none" placeholder="كلمة المرور الجديدة"></div></div></div>'+
                '<button onclick="saveAdminSettings()" class="'+C.btn+' w-full py-3 rounded-lg font-bold btn text-lg">💾 حفظ جميع الإعدادات</button></div></div>';
        }

        function saveAdminSettings() {
            DB.setSetting('exchange_rate', document.getElementById('set-rate').value);
            DB.setSetting('exchange_fee', document.getElementById('set-fee').value);
            DB.setSetting('aff_l1', document.getElementById('set-l1').value);
            DB.setSetting('aff_l2', document.getElementById('set-l2').value);
            DB.setSetting('aff_l3', document.getElementById('set-l3').value);
            DB.setSetting('admin_phone', document.getElementById('set-admin-phone').value.trim());
            DB.setSetting('admin_whatsapp', document.getElementById('set-admin-wa').value.trim());
            DB.setSetting('merchant_commission', document.getElementById('set-merch-comm').value);
            var adminEmail = document.getElementById('set-admin-email').value.trim();
            var adminPass = document.getElementById('set-admin-pass').value;
            var users = DB.get('users');
            var adminUser = users.find(function(u){return u.role==='ADMIN';});
            if(adminUser) {
                if(adminEmail) adminUser.email = adminEmail;
                if(adminPass) adminUser.password = adminPass;
                DB.set('users', users);
            }
            toast('تم حفظ جميع الإعدادات','success');
            render();
        }

        // ==================== INIT ====================
        var dataLoaded = 0;
        var totalDataKeys = Object.keys(window.appData).length;

        function checkDataReady() {
            dataLoaded++;
            if(dataLoaded >= totalDataKeys) {
                var savedAuth = null;
                try { savedAuth = JSON.parse(localStorage.getItem('fy_auth_user')); } catch(e) {}
                if(savedAuth && savedAuth.id) {
                    var user = DB.get('users').find(function(u){return u.id===savedAuth.id;});
                    if(user) {
                        if(user.isBlocked) { state.user = null; localStorage.removeItem('fy_auth_user'); setView('login'); toast('هذا الحساب محظور','error'); return; }
                        DB.ensureUserFields(user);
                        state.user = {id: user.id};
                        if(user.role === 'ADMIN') setView('admin-home');
                        else if(user.merchantStatus === 'APPROVED') setView('merchant-dashboard');
                        else setView('user-home');
                        return;
                    }
                }
                setView('login');
            }
        }

        async function initData() {
            var keys = Object.keys(window.appData);
            for(var i = 0; i < keys.length; i++) {
                (function(key) {
                    db.collection('appData').doc(key).get().then(function(doc) {
                        if(doc.exists && doc.data()) {
                            window.appData[key] = doc.data().data;
                        } else {
                            window.appData[key] = getDefaultData(key);
                            db.collection('appData').doc(key).set({ data: window.appData[key] }).catch(console.error);
                        }
                        checkDataReady();
                    }).catch(function(err) {
                        console.error('Error loading ' + key + ':', err);
                        window.appData[key] = getDefaultData(key);
                        checkDataReady();
                    });
                })(keys[i]);
            }
            db.collection('appData').onSnapshot(function(snapshot) {
                snapshot.docChanges().forEach(function(change) {
                    if(change.type === 'modified') {
                        var key = change.doc.id;
                        if(window.appData.hasOwnProperty(key) && change.doc.data()) {
                            window.appData[key] = change.doc.data().data;
                        }
                    }
                });
            });
        }

        initData();

        // Handle window resize for responsive sidebar
        window.addEventListener('resize', function() { if(window.innerWidth >= 1024) { state.sidebarOpen = false; } });
        document.addEventListener('keydown', function(e) { if(e.key === 'Escape') { closeModal(); document.getElementById('confirm-container').classList.add('hidden'); } });

        // Service Worker Registration for PWA
        if('serviceWorker' in navigator) { window.addEventListener('load', function() { navigator.serviceWorker.register('sw.js').catch(function(){}); }); }

        // Online/Offline detection
        window.addEventListener('online', function() { toast('تم استعادة الاتصال بالإنترنت','success',false); });
        window.addEventListener('offline', function() { toast('فقدت الاتصال بالإنترنت','warning',true); });

        // Data migration helper
        function migrateData() {
            var users = DB.get('users');
            var migrated = false;
            users.forEach(function(u) {
                if(u.pendingEmail === undefined) { u.pendingEmail = null; migrated = true; }
                if(u.merchantStatus === undefined) { u.merchantStatus = 'NONE'; migrated = true; }
                if(u.localBalance === undefined) { u.localBalance = 0; migrated = true; }
            });
            if(migrated) { DB.set('users', users); }
        }
        setTimeout(migrateData, 5000);

        // Notification permission request
        setTimeout(function() { if('Notification' in window && Notification.permission === 'default') { Notification.requestPermission(); } }, 5000);

        console.log('%c ForexYemeni Wallet v2.0 ', 'background: #F0B90B; color: #0B0E11; font-size: 16px; font-weight: bold; padding: 8px 16px; border-radius: 4px;');
    </script>
</body>
</html>
